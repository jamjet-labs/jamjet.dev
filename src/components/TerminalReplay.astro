---
interface Props {
  lines: string[];
  title?: string;
}
const { lines, title = 'terminal' } = Astro.props;
const linesHtml = lines.map((line, i) => {
  const escaped = line.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  return `<span class="terminal-line" style="--line-index: ${i}; --line-chars: ${line.length}">${escaped}\n</span>`;
}).join('');
---

<div class="terminal-replay" data-terminal>
  <div class="terminal-header">
    <span class="terminal-dots">
      <span></span><span></span><span></span>
    </span>
    <span class="terminal-title">{title}</span>
  </div>
  <pre class="terminal-body" set:html={linesHtml} />
</div>

<style>
  .terminal-replay {
    background: var(--bg-code);
    border-radius: 10px;
    overflow: hidden;
  }
  .terminal-header {
    display: flex; align-items: center; gap: 12px;
    padding: 12px 20px;
    background: #141413;
  }
  .terminal-dots {
    display: flex; gap: 6px;
  }
  .terminal-dots span {
    width: 8px; height: 8px; border-radius: 50%;
    background: rgba(255,255,255,0.15);
  }
  .terminal-title {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
  }
  .terminal-body {
    margin: 0; padding: 24px;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.85;
    color: #e5e4df;
    background: transparent;
    overflow-x: auto;
  }
  .terminal-line {
    display: inline-block;
    overflow: hidden;
    white-space: pre;
    width: 0;
    animation: type-line 0.4s steps(var(--line-chars, 30), end) forwards;
    animation-delay: calc(var(--line-index) * 0.45s);
    animation-play-state: paused;
  }
  .terminal-replay.playing .terminal-line {
    animation-play-state: running;
  }

  @keyframes type-line {
    from { width: 0; }
    to { width: 100%; }
  }

  @media (prefers-reduced-motion: reduce) {
    .terminal-line {
      width: 100% !important;
      animation: none !important;
    }
  }
</style>

<script is:inline>
  (function() {
    var terminals = document.querySelectorAll('[data-terminal]');
    function onIntersect(entries) {
      for (var i = 0; i < entries.length; i++) {
        if (entries[i].isIntersecting) {
          entries[i].target.classList.add('playing');
        }
      }
    }
    var opts = { threshold: 0.3 };
    var observer = new IntersectionObserver(onIntersect, opts);
    for (var i = 0; i < terminals.length; i++) {
      observer.observe(terminals[i]);
    }
  })();
</script>
