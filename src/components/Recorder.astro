---
/*
  Recorder.astro — the JamJet Flight Recorder.

  One dark instrument inset into the warm-paper cover. It plays back a single
  agent run as a scrubbable black box: a node track that crashes and recovers,
  a tape of tool calls with verdicts, and the signed receipt that materialises
  when an approved action is sealed. All state derives from `timeline.ts`.

  The whole demo is the interaction: press play, or drag the scrubber.
*/
import { NODES, LEDGER, RECEIPT_LINES, CUE_TICKS, DURATION } from './recorder/timeline';

const R = 13;
const edges = NODES.slice(1).map((n, i) => ({
  x1: NODES[i].x + R,
  x2: n.x - R,
  y: NODES[i].y,
}));
const scheduler = { x: 360, y: 12, r: 7 };
const ticks = CUE_TICKS.map((t) => (t / DURATION) * 100);
---

<figure class="rec" data-recorder aria-label="JamJet flight recorder: a replayable agent run. Use the play button or the scrubber to step through it.">
  <!-- Header / chrome -->
  <figcaption class="rec-head">
    <span class="rec-rec-dot" data-rec-dot aria-hidden="true"></span>
    <span class="rec-id">jamjet.recorder</span>
    <span class="rec-sep">·</span>
    <span class="rec-run">research-pipeline</span>
    <span class="rec-timecode" data-timecode>00:00 / 00:09</span>
  </figcaption>

  <!-- Node track -->
  <div class="rec-stage">
    <svg class="rec-track" viewBox="0 0 720 84" role="img"
         aria-label="Five-step run: Plan, Research, Analyze, Review, Synthesize. Analyze crashes and the scheduler resumes it.">
      <g class="rec-edges">
        {edges.map((e) => (
          <line x1={e.x1} y1={e.y} x2={e.x2} y2={e.y} class="rec-edge" />
        ))}
      </g>

      <line x1={scheduler.x} y1={scheduler.y + 7} x2={scheduler.x} y2={NODES[2].y - R} class="rec-recovery" data-recovery />
      <circle cx={scheduler.x} cy={scheduler.y} r={scheduler.r} class="rec-scheduler" data-scheduler />
      <text x={scheduler.x + 14} y={scheduler.y + 3} class="rec-scheduler-label" data-scheduler-label>scheduler</text>

      {NODES.map((n, i) => (
        <g class="rec-node is-idle" data-node={i}>
          <circle cx={n.x} cy={n.y} r={R} class="rec-node-ring" />
          <text x={n.x} y={n.y + 28} class="rec-node-label">{n.label}</text>
        </g>
      ))}

      <circle class="rec-dot" data-dot r="4" cx={NODES[0].x} cy={NODES[0].y} />
    </svg>

    <p class="rec-status" data-status><span class="rec-status-glyph" aria-hidden="true">▸</span><span data-status-text>ready</span></p>
  </div>

  <!-- Transport -->
  <div class="rec-transport">
    <button type="button" class="rec-play" data-play aria-label="Play the run">
      <svg viewBox="0 0 24 24" aria-hidden="true" class="rec-play-icon" data-play-icon><path d="M8 5v14l11-7z"/></svg>
    </button>
    <div class="rec-scrub">
      <div class="rec-scrub-ticks" aria-hidden="true">
        {ticks.map((p) => (<span class="rec-tick" style={`left:${p}%`}></span>))}
      </div>
      <input class="rec-range" data-range type="range" min="0" max="1000" value="0" step="1"
             aria-label="Scrub the run" aria-valuetext="00:00" />
    </div>
  </div>

  <!-- Tape (ledger of tool calls) + receipt -->
  <div class="rec-readout">
    <div class="rec-tape" aria-label="Tool calls captured during the run">
      <div class="rec-tape-head">the tape · tool calls</div>
      <ol class="rec-tape-rows">
        {LEDGER.map((e, i) => (
          <li class="rec-row" data-row={i}>
            <span class="rec-row-time">{e.time}</span>
            <span class="rec-row-cap">{e.capability}</span>
            <span class={`rec-verdict is-${e.verdict}`} data-verdict-label>{e.label}</span>
          </li>
        ))}
      </ol>
    </div>

    <div class="rec-receipt" data-receipt hidden>
      <div class="rec-receipt-cap">
        <span class="rec-receipt-name">action_receipt.json</span>
        <span class="rec-sep">·</span>
        <span class="rec-receipt-meta" data-receipt-meta>awaiting approval</span>
      </div>
      <pre class="rec-receipt-body"><code data-receipt-code></code></pre>
      <div class="rec-receipt-foot" data-receipt-foot aria-live="polite"></div>
    </div>
  </div>
</figure>

<style>
  /* ── Outer: dark instrument lifted off warm paper ── */
  .rec {
    margin: 0 0 40px;
    max-width: min(760px, 100%);
    width: 100%;
    background: var(--rec-bg);
    color: var(--rec-text);
    border-radius: 8px;
    box-shadow: var(--rec-glow);
    overflow: hidden;
    box-sizing: border-box;
    position: relative;
    /* faint instrument scanlines */
    background-image: repeating-linear-gradient(
      to bottom,
      rgba(245,244,240,0.018) 0px,
      rgba(245,244,240,0.018) 1px,
      transparent 1px,
      transparent 3px
    );
  }

  /* Header */
  .rec-head {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 11px 16px;
    background: var(--rec-bg-2);
    border-bottom: 1px solid var(--rec-line);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--rec-dim);
  }
  .rec-rec-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--rec-faint);
    box-shadow: none;
    transition: background 0.2s;
  }
  .rec-rec-dot.is-on {
    background: var(--rec-rec);
    box-shadow: 0 0 0 3px rgba(224,106,94,0.18);
    animation: rec-blink 1.1s steps(1, end) infinite;
  }
  @keyframes rec-blink { 50% { opacity: 0.35; } }
  .rec-id { color: var(--rec-text); font-weight: 500; }
  .rec-sep { color: var(--rec-faint); }
  .rec-run { color: var(--rec-dim); }
  .rec-timecode {
    margin-left: auto;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.06em;
    color: var(--rec-dim);
  }

  /* Node track */
  .rec-stage { padding: 22px 18px 6px; }
  .rec-track { width: 100%; height: auto; display: block; overflow: visible; }

  .rec-edge { stroke: var(--rec-line-2); stroke-width: 1.25; }
  .rec-node-ring {
    fill: none;
    stroke: var(--rec-faint);
    stroke-width: 1.5;
    transition: stroke 0.35s ease, fill 0.35s ease;
  }
  .rec-node-label {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.04em;
    fill: var(--rec-faint);
    text-anchor: middle;
    transition: fill 0.35s ease;
  }
  .rec-node.is-active  .rec-node-ring { fill: var(--rec-text); stroke: var(--rec-text); }
  .rec-node.is-active  .rec-node-label { fill: var(--rec-dim); }
  .rec-node.is-crashed .rec-node-ring { stroke: var(--v-block); fill: rgba(224,106,94,0.18); animation: rec-shake 0.4s ease; }
  .rec-node.is-crashed .rec-node-label { fill: var(--v-block); }
  .rec-node.is-recovered .rec-node-ring { stroke: var(--v-allow); fill: rgba(111,207,151,0.16); }
  .rec-node.is-recovered .rec-node-label { fill: var(--rec-dim); }
  .rec-node.is-completed .rec-node-ring { stroke: var(--v-allow); fill: var(--v-allow); }
  .rec-node.is-completed .rec-node-label { fill: var(--v-allow); }
  @keyframes rec-shake {
    0%,100% { transform: translateX(0); }
    25% { transform: translateX(-1.5px); }
    75% { transform: translateX(1.5px); }
  }

  .rec-dot { fill: var(--rec-text); opacity: 0; }
  .rec-dot.is-visible { opacity: 1; }

  .rec-scheduler { fill: none; stroke: var(--rec-dim); stroke-width: 1.25; opacity: 0; transition: opacity 0.3s; }
  .rec-scheduler.is-visible { opacity: 1; }
  .rec-scheduler-label {
    font-family: var(--font-mono); font-size: 8px; letter-spacing: 0.06em;
    fill: var(--rec-dim); opacity: 0; transition: opacity 0.3s;
  }
  .rec-scheduler-label.is-visible { opacity: 1; }
  .rec-recovery { stroke: var(--rec-dim); stroke-width: 1.25; stroke-dasharray: 3 3; opacity: 0; transition: opacity 0.3s; }
  .rec-recovery.is-visible { opacity: 1; }

  .rec-status {
    margin: 12px 2px 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.03em;
    color: var(--rec-dim);
    display: flex; align-items: center; gap: 7px;
    min-height: 16px;
  }
  .rec-status-glyph { color: var(--rec-faint); }
  .rec-status.is-error   { color: var(--v-block); }
  .rec-status.is-error   .rec-status-glyph { color: var(--v-block); }
  .rec-status.is-success { color: var(--v-allow); }
  .rec-status.is-success .rec-status-glyph { color: var(--v-allow); }

  /* Transport */
  .rec-transport {
    display: flex; align-items: center; gap: 14px;
    padding: 12px 18px 16px;
  }
  .rec-play {
    flex-shrink: 0;
    width: 34px; height: 34px;
    border-radius: 50%;
    border: 1px solid var(--rec-line-2);
    background: var(--rec-bg-2);
    color: var(--rec-text);
    display: grid; place-items: center;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s, transform 0.1s;
  }
  .rec-play:hover { border-color: var(--rec-text); }
  .rec-play:active { transform: scale(0.94); }
  .rec-play-icon { width: 15px; height: 15px; fill: currentColor; }

  .rec-scrub { position: relative; flex: 1; height: 22px; display: flex; align-items: center; }
  .rec-scrub-ticks { position: absolute; inset: 0; pointer-events: none; }
  .rec-tick {
    position: absolute; top: 50%; width: 1px; height: 8px;
    transform: translateY(-50%);
    margin-left: -0.5px;
    background: var(--rec-line-2);
  }
  .rec-range {
    -webkit-appearance: none; appearance: none;
    width: 100%; height: 3px; margin: 0;
    background: transparent; cursor: pointer;
  }
  .rec-range::-webkit-slider-runnable-track {
    height: 3px; border-radius: 2px;
    background: linear-gradient(to right,
      var(--rec-text) 0%, var(--rec-text) calc(var(--rec-playhead, 0) * 100%),
      var(--rec-line-2) calc(var(--rec-playhead, 0) * 100%), var(--rec-line-2) 100%);
  }
  .rec-range::-moz-range-track { height: 3px; border-radius: 2px; background: var(--rec-line-2); }
  .rec-range::-moz-range-progress { height: 3px; border-radius: 2px; background: var(--rec-text); }
  .rec-range::-webkit-slider-thumb {
    -webkit-appearance: none; appearance: none;
    width: 12px; height: 12px; border-radius: 50%; margin-top: -4.5px;
    background: var(--rec-text); border: 2px solid var(--rec-bg);
    box-shadow: 0 0 0 1px var(--rec-line-2);
  }
  .rec-range::-moz-range-thumb {
    width: 12px; height: 12px; border-radius: 50%;
    background: var(--rec-text); border: 2px solid var(--rec-bg);
  }
  .rec-range:focus-visible { outline: none; }
  .rec-range:focus-visible::-webkit-slider-thumb { box-shadow: 0 0 0 3px rgba(232,161,58,0.5); }
  .rec-range:focus-visible::-moz-range-thumb { box-shadow: 0 0 0 3px rgba(232,161,58,0.5); }

  /* Readout: tape + receipt */
  .rec-readout { border-top: 1px solid var(--rec-line); }
  .rec-tape { padding: 14px 18px 8px; }
  .rec-tape-head {
    font-family: var(--font-mono); font-size: 9.5px; text-transform: uppercase;
    letter-spacing: 0.14em; color: var(--rec-faint); margin-bottom: 10px;
  }
  .rec-tape-rows { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 2px; }
  .rec-row {
    display: grid;
    grid-template-columns: 64px 1fr auto;
    align-items: center;
    gap: 12px;
    padding: 5px 0;
    font-family: var(--font-mono);
    font-size: 12px;
    opacity: 0;
    transform: translateY(3px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .rec-row.is-visible { opacity: 1; transform: none; }
  .rec-row-time { color: var(--rec-faint); font-variant-numeric: tabular-nums; }
  .rec-row-cap { color: var(--rec-text); }
  .rec-verdict {
    justify-self: end;
    font-size: 10px; font-weight: 600; letter-spacing: 0.08em;
    padding: 2px 8px; border-radius: 3px; white-space: nowrap;
    border: 1px solid currentColor;
  }
  .rec-verdict.is-allow    { color: var(--v-allow);    background: rgba(111,207,151,0.10); }
  .rec-verdict.is-approval { color: var(--v-approval); background: rgba(232,161,58,0.12); }
  .rec-verdict.is-block    { color: var(--v-block);    background: rgba(224,106,94,0.12); }

  /* Receipt */
  .rec-receipt { border-top: 1px solid var(--rec-line); background: rgba(0,0,0,0.18); }
  .rec-receipt[hidden] { display: none; }
  .rec-receipt-cap {
    display: flex; align-items: center; gap: 8px;
    padding: 10px 18px;
    font-family: var(--font-mono); font-size: 10.5px;
    letter-spacing: 0.04em; color: var(--rec-dim);
    border-bottom: 1px solid var(--rec-line);
  }
  .rec-receipt-name { color: var(--rec-text); font-weight: 500; }
  .rec-receipt-body {
    margin: 0; padding: 14px 18px;
    font-family: var(--font-mono); font-size: 11px; line-height: 1.7;
    color: var(--rec-dim); overflow-x: auto; white-space: pre;
    min-height: 1.7em;
  }
  .rec-receipt-body code { color: inherit; background: transparent; padding: 0; font-size: inherit; }
  .rec-receipt-foot {
    padding: 9px 18px; border-top: 1px solid var(--rec-line);
    font-family: var(--font-mono); font-size: 10.5px; min-height: 14px;
    color: var(--rec-dim);
  }
  .rec-receipt-foot.is-verified { color: var(--v-allow); }
  .rec-receipt-foot.is-pending  { color: var(--v-approval); }

  @media (max-width: 640px) {
    .rec-stage { padding: 18px 12px 4px; }
    .rec-node-label { font-size: 8px; }
    .rec-row { grid-template-columns: 56px 1fr auto; font-size: 11px; gap: 8px; }
    .rec-receipt-body { font-size: 10px; }
  }
</style>

<script>
  import {
    renderState, hashDisplay, RECEIPT_HASH, RECEIPT_LINES, DURATION,
    type RecorderState,
  } from './recorder/timeline';

  const HASH_LINE_INDEX = RECEIPT_LINES.findIndex((l) => l.includes(RECEIPT_HASH));

  function initRecorder(root: HTMLElement) {
    const q = <T extends Element>(sel: string) => root.querySelector(sel) as T | null;

    const recDot = q<HTMLElement>('[data-rec-dot]');
    const timecode = q<HTMLElement>('[data-timecode]');
    const nodes = Array.from(root.querySelectorAll<HTMLElement>('[data-node]'));
    const dot = q<SVGCircleElement>('[data-dot]');
    const scheduler = q<SVGElement>('[data-scheduler]');
    const schedulerLabel = q<SVGElement>('[data-scheduler-label]');
    const recovery = q<SVGElement>('[data-recovery]');
    const statusWrap = q<HTMLElement>('[data-status]');
    const statusText = q<HTMLElement>('[data-status-text]');
    const rows = Array.from(root.querySelectorAll<HTMLElement>('[data-row]'));
    const playBtn = q<HTMLButtonElement>('[data-play]');
    const playIcon = q<SVGElement>('[data-play-icon]');
    const range = q<HTMLInputElement>('[data-range]');
    const receipt = q<HTMLElement>('[data-receipt]');
    const receiptCode = q<HTMLElement>('[data-receipt-code]');
    const receiptMeta = q<HTMLElement>('[data-receipt-meta]');
    const receiptFoot = q<HTMLElement>('[data-receipt-foot]');
    if (!range || !timecode || !statusText) return;

    const PLAY_ICON = 'M8 5v14l11-7z';
    const PAUSE_ICON = 'M7 5h3v14H7zM14 5h3v14h-3z';
    const REPLAY_ICON = 'M12 5V1L7 6l5 5V7a5 5 0 1 1-5 5H5a7 7 0 1 0 7-7z';

    let t = 0;
    let playing = false;
    let raf = 0;
    let last = 0;

    function fmt(ms: number): string {
      const s = Math.floor(ms / 1000);
      return `${String(Math.floor(s / 60)).padStart(2, '0')}:${String(s % 60).padStart(2, '0')}`;
    }

    function paint(state: RecorderState) {
      // Header
      if (recDot) recDot.classList.toggle('is-on', state.recording);
      timecode!.textContent = `${state.timecode} / ${fmt(DURATION)}`;

      // Nodes (SVG <g>: always use setAttribute so it works in every browser)
      state.nodes.forEach((ns, i) => {
        nodes[i]?.setAttribute('class', `rec-node is-${ns}`);
      });

      // Dot
      if (dot) {
        dot.setAttribute('cx', String(state.dot.x));
        dot.setAttribute('cy', String(state.dot.y));
        dot.classList.toggle('is-visible', state.dot.visible);
      }

      // Scheduler + recovery edge
      scheduler?.classList.toggle('is-visible', state.scheduler);
      schedulerLabel?.classList.toggle('is-visible', state.scheduler);
      recovery?.classList.toggle('is-visible', state.scheduler);

      // Status
      statusText!.textContent = state.status.text;
      if (statusWrap) {
        statusWrap.classList.toggle('is-error', state.status.tone === 'error');
        statusWrap.classList.toggle('is-success', state.status.tone === 'success');
      }

      // Tape rows
      state.ledger.forEach((l, i) => {
        const row = rows[i];
        if (!row) return;
        row.classList.toggle('is-visible', l.visible);
        const label = row.querySelector('[data-verdict-label]');
        if (label && label.textContent !== l.label) label.textContent = l.label;
      });

      // Receipt
      if (receipt) {
        if (state.receipt) {
          receipt.hidden = false;
          if (receiptCode) {
            const lines = state.receipt.lines.slice();
            if (lines.length > HASH_LINE_INDEX && HASH_LINE_INDEX >= 0) {
              lines[HASH_LINE_INDEX] = lines[HASH_LINE_INDEX].replace(
                RECEIPT_HASH,
                hashDisplay(state.receipt.hashProgress, state.t),
              );
            }
            receiptCode.textContent = lines.join('\n');
          }
          if (receiptMeta) {
            receiptMeta.textContent = state.receipt.verified === 'pending'
              ? 'awaiting approval'
              : 'signed';
          }
          if (receiptFoot) {
            if (state.receipt.verified === 'verified') {
              receiptFoot.textContent = '✓ verified · anyone can check';
              receiptFoot.className = 'rec-receipt-foot is-verified';
            } else if (state.receipt.verified === 'approved') {
              receiptFoot.textContent = '✓ approved by alex@acme.com';
              receiptFoot.className = 'rec-receipt-foot is-verified';
            } else {
              receiptFoot.textContent = '⏸ waiting for a human';
              receiptFoot.className = 'rec-receipt-foot is-pending';
            }
          }
        } else {
          receipt.hidden = true;
        }
      }

      // Scrubber
      const frac = state.fraction;
      root.style.setProperty('--rec-playhead', String(frac));
      const v = Math.round(frac * 1000);
      if (Number(range!.value) !== v) range!.value = String(v);
      range!.setAttribute('aria-valuetext', state.timecode);
    }

    function setIcon(d: string) { playIcon?.querySelector('path')?.setAttribute('d', d); }

    function update() { paint(renderState(t)); }

    function tick(now: number) {
      if (!playing) return;
      const dt = last ? now - last : 16;
      last = now;
      t += dt;
      if (t >= DURATION) {
        t = DURATION;
        update();
        stop(true);
        return;
      }
      update();
      raf = requestAnimationFrame(tick);
    }

    function play() {
      if (t >= DURATION) t = 0; // replay
      playing = true;
      last = 0;
      setIcon(PAUSE_ICON);
      playBtn?.setAttribute('aria-label', 'Pause the run');
      raf = requestAnimationFrame(tick);
    }
    function stop(ended = false) {
      playing = false;
      cancelAnimationFrame(raf);
      setIcon(ended ? REPLAY_ICON : PLAY_ICON);
      playBtn?.setAttribute('aria-label', ended ? 'Replay the run' : 'Play the run');
    }

    playBtn?.addEventListener('click', () => (playing ? stop() : play()));

    range.addEventListener('input', () => {
      if (playing) stop();
      t = (Number(range.value) / 1000) * DURATION;
      setIcon(t >= DURATION ? REPLAY_ICON : PLAY_ICON);
      update();
    });

    // Autoplay once when scrolled into view; pause when off-screen.
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    update();

    if (reduced) {
      t = DURATION;
      update();
      stop(true);
      return;
    }

    const KEY = 'jamjet:recorder:autoplayed';
    let autoplayed = false;
    try { autoplayed = sessionStorage.getItem(KEY) === '1'; } catch {}

    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting && !autoplayed && t === 0) {
          autoplayed = true;
          try { sessionStorage.setItem(KEY, '1'); } catch {}
          play();
        } else if (!e.isIntersecting && playing) {
          stop();
        }
      }
    }, { threshold: 0.4 });
    io.observe(root);
  }

  function boot() {
    document.querySelectorAll<HTMLElement>('[data-recorder]').forEach(initRecorder);
  }
  boot();
  document.addEventListener('astro:after-swap', boot);
</script>
