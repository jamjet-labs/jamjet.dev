---
import type { Props } from '@astrojs/starlight/props';
import config from 'virtual:starlight/user-config';
import Search from 'virtual:starlight/components/Search';
import MobileMenuFooter from 'virtual:starlight/components/MobileMenuFooter';
import SidebarPersister from '@astrojs/starlight/components/SidebarPersister.astro';
import SidebarSublist from '@astrojs/starlight/components/SidebarSublist.astro';

const { sidebar } = Astro.props;
const shouldRenderSearch =
  config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';
---

{shouldRenderSearch && (
  <div class="sidebar-search">
    <Search {...Astro.props} />
  </div>
)}

<SidebarPersister {...Astro.props}>
  <SidebarSublist sublist={sidebar} />
</SidebarPersister>

<div class="md:sl-hidden">
  <MobileMenuFooter {...Astro.props} />
</div>

<style>
  .sidebar-search {
    padding: 0 1rem 1rem;
    border-bottom: 1px solid rgba(26,26,24,0.06);
    margin-bottom: 0.75rem;
  }
  .sidebar-search :global(button[data-open-modal]) {
    width: 100% !important;
    background: rgba(26,26,24,0.04) !important;
    border: 1px solid rgba(26,26,24,0.08) !important;
    border-radius: 6px !important;
    color: #8b8578 !important;
    font-size: 0.82rem !important;
    padding: 8px 12px !important;
    height: auto !important;
  }
  .sidebar-search :global(button[data-open-modal] svg) {
    color: #b0ac9f !important;
  }
  .sidebar-search :global(button[data-open-modal] kbd) {
    background: rgba(26,26,24,0.04) !important;
    border-color: rgba(26,26,24,0.08) !important;
    color: #b0ac9f !important;
    font-size: 0.65rem !important;
  }
</style>
