---
import type { Props } from '@astrojs/starlight/props';
---

<div class="docs-header">
  <a href="/" class="docs-logo">JamJet</a>
  <ul class="docs-links">
    <li><a href="/quickstart">Docs</a></li>
    <li><a href="/usecases">Use Cases</a></li>
    <li><a href="/benchmarks">Benchmarks</a></li>
    <li><a href="/examples">Examples</a></li>
    <li><a href="/blog">Blog</a></li>
    <li>
      <a href="https://github.com/jamjet-labs/jamjet" target="_blank" rel="noopener" class="docs-github" aria-label="GitHub">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>
    </li>
  </ul>
</div>

<style>
  .docs-header {
    display: flex;
    align-items: center;
    gap: 32px;
    height: 100%;
    width: 100%;
  }

  .docs-logo {
    text-decoration: none;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 1rem;
    font-weight: 600;
    color: #1a1a18;
    flex-shrink: 0;
  }

  .docs-links {
    display: flex;
    align-items: center;
    gap: 20px;
    list-style: none;
    margin: 0;
    padding: 0;
    margin-left: auto;
  }

  .docs-links a {
    color: #6b6b63;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.2s;
  }
  .docs-links a:hover { color: #1a1a18; }

  .docs-github {
    display: flex;
    align-items: center;
    color: #8b8578 !important;
  }
  .docs-github:hover { color: #1a1a18 !important; }

  @media (max-width: 768px) {
    .docs-links li:not(:last-child) { display: none; }
  }
</style>
