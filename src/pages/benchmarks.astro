---
import BaseLayout from '../layouts/BaseLayout.astro';

const hubLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "JamJet Benchmarks — Memory leaderboard, framework overhead, reproducible measurements",
  "description": "Reproducible benchmarks with full methodology. Engram LongMemEval-S leaderboard, framework overhead vs raw and LangGraph, and more.",
  "datePublished": "2026-03-08",
  "author": { "@type": "Person", "name": "Sunil Prakash" },
  "publisher": { "@type": "Organization", "name": "JamJet" },
};
---

<BaseLayout
  title="JamJet Benchmarks — Memory leaderboard, framework overhead, reproducible measurements"
  description="Reproducible benchmarks with full methodology. Engram LongMemEval-S leaderboard, framework overhead vs raw and LangGraph, and more."
  canonical="https://jamjet.dev/benchmarks/"
>
<Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify(hubLd)}></script>
</Fragment>

<div class="bench-hub">
  <h1>JamJet benchmarks</h1>
  <p class="subtitle">
    Reproducible measurements with full methodology and code. Each deep-dive includes the reproduction script, the raw numbers, and the competitive context where it matters.
  </p>

  <section class="benchmarks-deep-dives">
    <h2>Deep-dives</h2>
    <div class="dd-grid">
      <a class="dd-card" href="/benchmarks/engram-longmemeval/">
        <span class="dd-eyebrow">Memory &middot; LongMemEval-S</span>
        <h3>Engram v0.1.0 on the LongMemEval-S leaderboard</h3>
        <p>Engram alongside Chronos, Mastra, OMEGA, and Zep &mdash; judged on the same methodology, compared on the axes that matter beyond raw accuracy.</p>
        <span class="dd-arrow">Read &rarr;</span>
      </a>
      <a class="dd-card" href="/benchmarks/framework-overhead/">
        <span class="dd-eyebrow">Runtime &middot; Framework tax</span>
        <h3>JamJet adds zero observable overhead vs raw LLM calls</h3>
        <p>Reproducible llama3.2 + qwen3:8b measurements with the same OpenAI-compatible client. JamJet vs raw vs LangGraph, three way, statistically tied.</p>
        <span class="dd-arrow">Read &rarr;</span>
      </a>
    </div>
  </section>

  <p class="bench-see-also">
    <strong>See also:</strong> <a href="/compare/">JamJet comparisons</a> &mdash; how JamJet fits with LangGraph, CrewAI, Temporal, Microsoft AGT, and the rest of your stack.
  </p>
</div>

</BaseLayout>

<style>
  .bench-hub {
    max-width: 1000px;
    margin: 0 auto;
    padding: 3rem 24px 5rem;
  }
  .bench-hub h1 {
    font-size: 2.2rem;
    margin-bottom: 0.5rem;
  }
  .subtitle {
    color: var(--text-secondary);
    font-size: 0.95rem;
    margin-bottom: 3rem;
    line-height: 1.7;
  }

  .benchmarks-deep-dives {
    margin-top: 0;
  }
  .benchmarks-deep-dives h2 {
    font-size: clamp(1.3rem, 2.5vw, 1.8rem);
    margin-bottom: 20px;
  }
  .dd-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 16px;
    margin-bottom: 0;
  }
  .dd-card {
    display: block;
    padding: 24px;
    border: 1px solid var(--border);
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s;
  }
  .dd-card:hover { border-color: var(--accent); }
  .dd-eyebrow {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    display: block;
    margin-bottom: 8px;
  }
  .dd-card h3 {
    font-size: 1.05rem;
    margin: 0 0 8px;
  }
  .dd-card p {
    color: var(--text-secondary);
    font-size: 0.92rem;
    line-height: 1.6;
    margin: 0 0 12px;
  }
  .dd-arrow {
    color: var(--accent);
    font-size: 0.9rem;
  }

  .bench-see-also {
    margin-top: 32px;
    padding-top: 16px;
    border-top: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.92rem;
    line-height: 1.6;
  }
  .bench-see-also a { color: var(--accent); }
</style>
