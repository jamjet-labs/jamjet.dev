            <td>2.1s</td>
            <td>$0.002</td>
          </tr>
          <tr>
            <td>plan_and_execute</td>
            <td>0.78 &plusmn; 0.03</td>
            <td>1,890</td>
            <td>3.4s</td>
            <td>$0.003</td>
          </tr>
          <tr>
            <td>critic</td>
            <td>0.82 &plusmn; 0.05</td>
            <td>2,410</td>
            <td>4.2s</td>
            <td>$0.004</td>
          </tr>
          <tr>
            <td>reflection</td>
            <td>0.84 &plusmn; 0.02</td>
            <td>3,100</td>
            <td>5.8s</td>
            <td>$0.005</td>
          </tr>
          <tr>
            <td>consensus</td>
