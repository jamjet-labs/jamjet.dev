<!-- ── Target Communities ── -->
<section style="background: var(--bg-alt);">
  <div class="container">
    <span class="section-label">Communities</span>
    <h2 class="section-title">Built for how you work</h2>
    <div class="r-communities">
      <div class="r-community">
        <h3>Multi-agent systems</h3>
        <p>AAMAS, NeurIPS workshops</p>
        <span class="r-comm-arrow">Orchestration + evaluation + reproducibility</span>
      </div>
      <div class="r-community">
        <h3>LLM reasoning</h3>
        <p>CoT, ToT, debate, reflection</p>
        <span class="r-comm-arrow">Strategy parameter makes A/B testing trivial</span>
      </div>
      <div class="r-community">
        <h3>Tool-augmented LLMs</h3>
        <p>ReAct, Toolformer</p>
        <span class="r-comm-arrow">MCP-native tool integration</span>
      </div>
      <div class="r-community">
        <h3>AI safety &amp; alignment</h3>
        <p>HITL, guardrails</p>
