---
import BaseLayout from '../layouts/BaseLayout.astro';

const examples = [
  {
    slug: 'hello-agent',
    title: 'Hello Agent',
    description: 'The minimal JamJet workflow — one model node, one answer. Start here.',
    tags: ['beginner', 'yaml', 'model'],
    github: 'https://github.com/jamjet-labs/examples/tree/main/hello-agent',
  },
  {
    slug: 'research-agent',
    title: 'Research Agent',
    description: 'Web search + synthesis using Brave Search via MCP. Multi-step pipeline with retry.',
    tags: ['mcp', 'multi-step', 'yaml'],
    github: 'https://github.com/jamjet-labs/examples/tree/main/research-agent',
  },
  {
    slug: 'vertex-ai',
    title: 'Vertex AI (Gemini)',
    description: 'Run Gemini 2.0 Flash and Pro on Vertex AI. Zero custom integration — JamJet uses the OpenAI-compatible endpoint.',
    tags: ['vertex ai', 'gemini', 'google cloud', 'python'],
    github: 'https://github.com/jamjet-labs/examples/tree/main/vertex-ai',
    highlight: true,
  },
  {
    slug: 'code-reviewer',
    title: 'Code Reviewer',
    description: 'GitHub PR review with quality scoring. MCP tool node + eval node + automatic retry on low scores.',
    tags: ['mcp', 'eval', 'yaml'],
    github: 'https://github.com/jamjet-labs/examples/tree/main/code-reviewer',
  },
  {
    slug: 'support-bot',
    title: 'Support Bot',
    description: 'Customer support ticket handler with classification and routing. Python SDK style.',
    tags: ['python', 'routing', 'classification'],
    github: 'https://github.com/jamjet-labs/examples/tree/main/support-bot',
  },
  {
    slug: 'approval-workflow',
    title: 'Approval Workflow',
    description: 'Human-in-the-loop approval gate. Suspends durably for up to 24h — survives restarts.',
    tags: ['hitl', 'durable', 'yaml'],
    github: 'https://github.com/jamjet-labs/examples/tree/main/approval-workflow',
  },
  {
    slug: 'orchestrator',
    title: 'Multi-Agent Orchestrator',
    description: 'Delegate tasks to specialised agents via A2A. Parallel execution, result aggregation.',
    tags: ['a2a', 'multi-agent', 'parallel'],
    github: 'https://github.com/jamjet-labs/examples/tree/main/orchestrator',
  },
  {
    slug: 'data-pipeline',
    title: 'Data Pipeline',
    description: 'Extract, transform, load with checkpointing. Crash mid-run and resume without re-fetching.',
    tags: ['durable', 'parallel', 'yaml'],
    github: 'https://github.com/jamjet-labs/examples/tree/main/data-pipeline',
  },
  {
    slug: 'sql-agent',
    title: 'SQL Agent',
    description: 'Natural language to SQL via PostgreSQL MCP server. Schema-aware, safe read-only queries.',
    tags: ['mcp', 'postgres', 'sql'],
    github: 'https://github.com/jamjet-labs/examples/tree/main/sql-agent',
  },
];

const tagColors: Record<string, string> = {
  beginner: '#2d7d46',
  yaml: '#4a7ab5',
  python: '#8b7ab5',
  mcp: '#8b7355',
  'a2a': '#a06940',
  durable: '#3a8a8a',
  hitl: '#a05a7a',
  eval: '#5a8a3a',
  'multi-agent': '#a06940',
  parallel: '#3a8a8a',
  gemini: '#4a7ab5',
  'vertex ai': '#4a7ab5',
  'google cloud': '#2d7d46',
};
---

<BaseLayout
  title="Examples — JamJet"
  description="Ready-to-run JamJet examples — Vertex AI, MCP, A2A, human-in-the-loop, eval, and more."
  canonical="https://jamjet.dev/examples"
  currentPage="examples"
>

<section class="examples-hero">
  <span class="section-label">Examples</span>
  <h1>Ready-to-run examples</h1>
  <p>Self-contained examples for every JamJet feature. Clone, set your API key, run.</p>
  <a href="https://github.com/jamjet-labs/examples" class="btn-secondary" target="_blank" rel="noopener" style="margin-top: 16px;">
    <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
    jamjet-labs/examples
  </a>
</section>

<div class="examples-grid">
  {examples.map((ex) => (
    <a href={ex.github} class={`ex-card${ex.highlight ? ' highlight' : ''}`} target="_blank" rel="noopener">
      <div>
        <div class="ex-header">
          <h3>{ex.title}</h3>
          {ex.highlight && <span class="new-badge">new</span>}
        </div>
        <p>{ex.description}</p>
      </div>
      <div class="ex-tags">
        {ex.tags.map((tag) => (
          <span class="ex-tag" style={tagColors[tag] ? `color:${tagColors[tag]};background:${tagColors[tag]}12` : ''}>{tag}</span>
        ))}
      </div>
      <div class="ex-gh">
        <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
        View on GitHub
      </div>
    </a>
  ))}
</div>

</BaseLayout>

<style>
  .examples-hero {
    padding: 80px 24px 48px;
    text-align: center;
  }
  .examples-hero h1 { font-size: clamp(2rem, 5vw, 3rem); font-weight: 700; margin-bottom: 16px; }
  .examples-hero p { color: var(--text-secondary); font-size: 1.05rem; max-width: 560px; margin: 0 auto; }

  .examples-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 24px 80px;
  }

  .ex-card {
    background: var(--bg);
    border: 1px solid var(--border-strong);
    border-radius: 12px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: border-color 0.15s;
    text-decoration: none;
    color: inherit;
  }
  .ex-card:hover { border-color: var(--accent); }
  .ex-card.highlight {
    border-color: rgba(74,122,181,0.3);
    background: linear-gradient(135deg, var(--bg) 0%, rgba(74,122,181,0.04) 100%);
  }
  .ex-card.highlight:hover { border-color: #4a7ab5; }

  .ex-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
  .ex-card h3 { font-size: 1.05rem; font-weight: 600; color: var(--text); margin: 0; }
  .ex-card p { font-size: 0.9rem; color: var(--text-secondary); margin: 0; line-height: 1.55; flex: 1; }

  .ex-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .ex-tag {
    font-size: 0.7rem; font-weight: 600;
    padding: 2px 8px; border-radius: 99px;
    background: var(--accent-bg);
    color: var(--text-muted);
    text-transform: uppercase; letter-spacing: 0.04em;
  }

  .ex-gh {
    font-size: 0.78rem; color: var(--text-muted);
    display: flex; align-items: center; gap: 4px;
  }

  .new-badge {
    font-size: 0.65rem; font-weight: 700;
    padding: 2px 7px; border-radius: 99px;
    background: rgba(74,122,181,0.12);
    color: #4a7ab5;
    text-transform: uppercase; letter-spacing: 0.05em;
  }
</style>
