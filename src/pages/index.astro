<!-- ── Comparison ── -->
<section>
  <div class="container">
    <div style="margin-bottom:48px">
      <div class="section-tag">comparison</div>
      <h2>Not another agent library.</h2>
      <p style="color:var(--text-muted); margin-top:12px; font-size:1.05rem;">JamJet is a runtime. Built for production, not prototyping.</p>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Capability</th>
            <th class="jam">JamJet</th>
            <th>LangChain</th>
            <th>AutoGen</th>
            <th>CrewAI</th>
          </tr>
        </thead>
        <tbody>
          <tr><td class="name">Durable execution (crash-safe)</td><td class="jam chk">✅ event-sourced</td><td class="no">❌ ephemeral</td><td class="no">❌ ephemeral</td><td class="no">❌ ephemeral</td></tr>
          <tr><td class="name">Human-in-the-loop</td><td class="jam chk">✅ native node type</td><td class="par">🟡 callbacks</td><td class="par">🟡 conversational</td><td class="par">🟡 manual</td></tr>
          <tr><td class="name">MCP support</td><td class="jam chk">✅ client + server</td><td class="par">🟡 client only</td><td class="par">🟡 client only</td><td class="par">🟡 client only</td></tr>
          <tr><td class="name">A2A protocol</td><td class="jam chk">✅ client + server</td><td class="no">❌</td><td class="no">❌</td><td class="no">❌</td></tr>
          <tr><td class="name">Enforced cost / iteration limits</td><td class="jam chk">✅ compile-time guards</td><td class="no">❌</td><td class="par">🟡 partial</td><td class="par">🟡 partial</td></tr>
          <tr><td class="name">Typed state schemas</td><td class="jam chk">✅ Pydantic / JSON Schema</td><td class="par">🟡 optional</td><td class="par">🟡 optional</td><td class="par">🟡 partial</td></tr>
          <tr><td class="name">Native eval harness</td><td class="jam chk">✅ LLM-judge, CI mode</td><td class="par">🟡 LangSmith (SaaS)</td><td class="no">❌</td><td class="no">❌</td></tr>
          <tr><td class="name">Full OTel observability</td><td class="jam chk">✅ GenAI traces + replay</td><td class="par">🟡 LangSmith</td><td class="no">❌</td><td class="no">❌</td></tr>
          <tr><td class="name">Agent identity + discovery</td><td class="jam chk">✅ Agent Cards + A2A</td><td class="no">❌</td><td class="no">❌</td><td class="no">❌</td></tr>
          <tr><td class="name">Runtime language</td><td class="jam">Rust + Python authoring</td><td>Python</td><td>Python</td><td>Python</td></tr>
        </tbody>
      </table>
    </div>
    <p style="font-size:0.72rem; color:var(--text-dim); margin-top:12px; text-align:right;">Data as of early 2026. Frameworks evolve — verify against current docs.</p>
  </div>
</section>

