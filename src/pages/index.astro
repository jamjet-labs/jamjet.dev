  }
  @media (max-width: 640px) {
    .zn-cred-sep {
      display: none;
    }
    .zn-credentials {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
  }
  .zn-cover-foot {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 18px;
    margin-bottom: 0;
  }
  .zn-cta-row { display: inline-flex; gap: 12px; flex-wrap: wrap; }
  .zn-cta-center { justify-content: center; }
  .zn-cta-aside {
    margin: 12px 0 0;
    font-size: 0.88rem;
    color: var(--text-muted);
  }
  .zn-cta-aside a { color: var(--text); border-bottom: 1px solid var(--border); text-decoration: none; }
  .zn-cta-aside a:hover { border-bottom-color: var(--text); }

  /* ─────────  MANIFESTO  ───────── */
  .zn-manifesto { padding: 88px 0; background: var(--bg-alt); border-bottom: 1px solid var(--border); }
  .zn-grid-asym {
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: 64px;
    align-items: start;
  }
  .zn-grid-asym-flip {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: center;
  }
  .zn-side {}
  .zn-stack { width: 100%; height: auto; color: var(--text); }
  .zn-stack .lay rect {
    fill: var(--bg);
    stroke: var(--border);
    stroke-width: 1;
  }
  .zn-stack .lay text {
    font-size: 12px;
    fill: var(--text);
    font-family: var(--font-sans);
    font-weight: 500;
  }
  .zn-stack .lay-tag {
    font-size: 9px;
    fill: var(--text-muted);
    font-family: var(--font-sans);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .zn-stack .lay-jam rect { fill: var(--text); stroke: var(--text); }
  .zn-stack .lay-jam-title { font-size: 14px; fill: var(--bg); font-family: var(--font-sans); font-weight: 600; }
  .zn-stack .lay-jam-sub {
    font-size: 9px; fill: var(--bg); opacity: 0.7;
    font-family: var(--font-sans); text-transform: uppercase; letter-spacing: 0.1em;
  }
  .zn-stack .lay-chip rect { fill: var(--bg); opacity: 0.18; }
  .zn-stack .lay-chip text {
    font-size: 9px; fill: var(--bg);
    font-family: var(--font-sans); font-weight: 500;
  }

  .zn-essay {}
  .zn-dropcap {
    float: left;
    font-size: 4.6rem;
    line-height: 0.9;
    padding-right: 12px;
    padding-top: 4px;
    font-weight: 600;
    font-style: italic;
    color: var(--text);
  }

  /* ─────────  ADAPTERS GRID  ───────── */
  .zn-adapters {
    padding: 88px 0;
    border-bottom: 1px solid var(--border);
  }
  .zn-adapters-head { max-width: 720px; margin-bottom: 48px; }
  .zn-adapters-head .zn-essay-body { margin-top: 16px; }
  .zn-adapters-head code {
    font-family: var(--font-mono);
    font-size: 0.92em;
    background: var(--bg-alt);
    padding: 1px 6px;
    border-radius: 3px;
  }
  .zn-adapter-list {
    list-style: none;
    padding: 0;
    margin: 0 0 32px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    border-top: 1px solid var(--border);
  }
  .zn-adapter {
    border-bottom: 1px solid var(--border);
  }
  .zn-adapter:nth-child(odd) { border-right: 1px solid var(--border); }
  .zn-adapter-link {
    display: block;
    padding: 22px 24px;
    text-decoration: none;
    color: inherit;
    transition: background 0.12s;
  }
  .zn-adapter-link:hover { background: var(--bg-alt); }
  .zn-adapter-name {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--text);
    font-weight: 500;
    margin-bottom: 6px;
  }
  .zn-adapter-host {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 10px;
  }
  .zn-adapter-install {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-secondary, var(--text-muted));
    background: var(--bg-alt);
    padding: 6px 10px;
    border-radius: 4px;
  }

  /* ─────────  DARK BAND (failure modes)  ───────── */
  .zn-dark {
    padding: 96px 0;
    background: #141413;
    color: #eae8e1;
  }
  .zn-dark-head { max-width: 720px; margin-bottom: 56px; }
  .zn-dark-head .zn-h2 { color: #eae8e1; }
  .zn-dark-sub {
    color: rgba(255,255,255,0.7);
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 60ch;
    margin: 0;
  }
  .zn-failures {
    list-style: none;
    padding: 0;
    margin: 0 0 48px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px 56px;
  }
  .zn-failure {
    display: grid;
    grid-template-columns: 4px 84px 1fr;
    gap: 8px;
    padding-top: 24px;
    border-top: 1px solid rgba(255,255,255,0.18);
  }
  .zn-failure-bar {
    grid-column: 1 / 2;
    grid-row: 1 / span 2;
    width: 3px;
    height: 100%;
    background: rgba(255, 255, 255, 0.25);
    border-radius: 1px;
    margin-right: 6px;
  }
  .zn-failure-tone-warning .zn-failure-bar { background: var(--warning); }
  .zn-failure-tone-error   .zn-failure-bar { background: var(--error); }
  .zn-failure-tone-neutral .zn-failure-bar { background: rgba(255, 255, 255, 0.25); }
  .zn-failure-num {
    font-size: 3.4rem;
    line-height: 1;
    font-weight: 500;
    font-style: italic;
    color: rgba(255,255,255,0.7);
  }
  .zn-failure-title {
    display: block;
    font-size: 1.15rem;
    margin-bottom: 6px;
    color: #fff;
    font-weight: 500;
  }
  .zn-failure-line {
    color: rgba(255,255,255,0.72);
    font-size: 0.95rem;
    line-height: 1.65;
    margin: 0;
  }
  .zn-dark-foot { padding-top: 16px; border-top: 1px solid rgba(255,255,255,0.18); }

  /* ─────────  PULL QUOTE  ───────── */
