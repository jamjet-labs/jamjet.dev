<!-- ── Hero ── -->
<section class="hero yglow">
  <div class="hero-inner">
    <div class="hero-badge">
      <span class="dot"></span>
      v0.1.0 · Open source · Apache 2.0
    </div>

    <h1>Build agents that<br/><span class="gradient-text">actually work</span><br/>in production</h1>

    <p class="hero-sub">
      JamJet is the agent-native runtime — durable execution, native MCP + A2A,
      full observability, enforced autonomy limits. Built in Rust, authored in Python.
    </p>

    <div class="hero-actions">
      <a href="/docs/quickstart" class="btn-primary">
        Read the docs
        <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8z"/></svg>
      </a>
      <a href="https://github.com/jamjet-labs/jamjet" class="btn-secondary" target="_blank" rel="noopener">
        <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
        Star on GitHub
      </a>
    </div>

    <div class="install-cmd">
      <span class="prompt">$</span>
      <span class="cmd">pip install jamjet</span>
      <button class="copy-btn" onclick="navigator.clipboard.writeText('pip install jamjet').then(()=>{this.textContent='copied!';setTimeout(()=>this.textContent='copy',1500)})">copy</button>
    </div>

    <!-- Terminal -->
    <div class="terminal">
      <div class="term-bar">
        <div class="term-dot" style="background:#ef4444"></div>
        <div class="term-dot" style="background:#f59e0b"></div>
        <div class="term-dot" style="background:#22c55e"></div>
        <span class="term-title">terminal — jamjet demo</span>
      </div>
      <div class="term-body">
        <div><span class="t-d"># scaffold a project</span></div>
        <div><span class="t-y">❯</span> <span class="t-w">jamjet init my-agent &amp;&amp; cd my-agent</span></div>
