---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroAnimation from '../components/HeroAnimation.astro';
import TerminalReplay from '../components/TerminalReplay.astro';

const terminalLines = [
  '$ jamjet run research-pipeline.yaml',
  '▸ Starting execution exec_7f3a...',
  '▸ [Plan]       ✓ completed  420ms',
  '▸ [Research]   ✓ completed  1.2s',
  '▸ [Analyze]    ✗ worker crashed',
  '▸ Lease expired · reclaiming...',
  '▸ [Analyze]    ✓ resumed    890ms',
  '▸ [Review]     ✓ completed  650ms',
  '▸ [Synthesize] ✓ completed  1.1s',
  '▸ Execution complete · 5/5 nodes · 0 events lost',
];

const failures = [
  { num: '01', title: 'Lost progress', line: 'A worker dies mid-run. JamJet replays the event log and resumes at the failed node.' },
  { num: '02', title: 'Unsafe tool', line: 'An agent reaches for a tool it shouldn’t. The 4-level policy hierarchy blocks the call before execution.' },
  { num: '03', title: 'Skipped approval', line: 'A high-risk action waits for a human. The run survives restarts. The decision lands in audit.' },
  { num: '04', title: 'Runaway cost', line: 'A reflection loop won’t stop spending. The runtime halts the loop before it crosses the cap.' },
  { num: '05', title: 'Missing audit', line: 'Compliance asks what happened. Every decision is in a signed, exportable evidence package.' },
  { num: '06', title: 'Forgotten context', line: 'The agent forgets across sessions. Engram surfaces durable facts — not raw chat history.' },
];

const log = [
  { date: 'Apr 25', body: 'Java runtime v0.1.1 — embed durable execution directly in your JVM. @DurableAgent crash recovery, MCP native, 8.9x faster than the REST sidecar in our benchmark.', href: '/blog/zero-sidecar-durable-agents-java/' },
  { date: 'Apr 8',  body: 'Engram Spring Boot Starter on Maven Central. One dependency, inject EngramClient, done.', href: 'https://central.sonatype.com/artifact/dev.jamjet/engram-spring-boot-starter' },
  { date: 'Apr 7',  body: 'Engram v0.3.1 — fact extraction, conflict detection, hybrid retrieval, consolidation. Published as jamjet-engram on crates.io and bundled with dev.jamjet:jamjet-sdk.', href: '/blog/engram-agent-memory/' },
  { date: 'Mar 29', body: 'JamJet Spring Boot Starter on Maven Central. Crash recovery, audit, replay testing, and HITL gates for any Spring AI app.', href: '/blog/jamjet-spring-boot-starter/' },
];

const homeLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "JamJet",
  "description": "The open-source safety layer for AI agents. Policy checks, audit trails, human approval, crash recovery, cost limits, and memory — without cloud or framework lock-in. Works with any framework through MCP and A2A.",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Linux, macOS, Windows",
  "url": "https://jamjet.dev",
  "downloadUrl": "https://pypi.org/project/jamjet/",
  "softwareVersion": "0.3.1",
  "license": "https://www.apache.org/licenses/LICENSE-2.0",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
};
---

<BaseLayout
  title="JamJet — The safety layer behind your AI agents"
  description="Open-source safety layer for AI agents. Policy checks, audit trails, human approval, crash recovery, cost limits, and memory — without cloud or framework lock-in."
  canonical="https://jamjet.dev/"
>
<Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify(homeLd)}></script>
</Fragment>

<!-- ────────────────────────  COVER ──────────────────────── -->
<section class="zn-cover">
  <div class="zn-shell">
    <div class="zn-masthead">
      <span class="zn-vol">JamJet · Vol. 1 · Apr 2026</span>
      <span class="zn-issue">Field notes from a runtime</span>
    </div>

    <h1 class="zn-display">
      Agents that don’t<br/>
      <span class="zn-display-italic">lose control.</span>
    </h1>

    <p class="zn-lead">
      JamJet is the open-source safety layer for AI agents — policy checks, audit trails,
      human approval, crash recovery, cost limits, memory, and MCP/A2A interoperability,
      without cloud or framework lock-in.
    </p>

    <div class="zn-cover-foot">
      <div class="zn-cta-row">
        <a href="#failure-modes" class="zn-btn zn-btn-primary">See what JamJet controls &darr;</a>
        <a href="https://docs.jamjet.dev/en/docs/quickstart" class="zn-btn zn-btn-ghost">Get started in 60s</a>
      </div>
      <div class="zn-install">
        <span class="zn-prompt">$</span>
        <span class="zn-cmd">pip install jamjet</span>
        <button class="zn-copy" id="copy-install" type="button">copy</button>
      </div>
    </div>

    <div class="zn-rule"></div>

    <p class="zn-marginal">
      Not another agent framework. The safety layer behind them. Keep your stack —
      add JamJet when runs need to be replayable, auditable, and controlled.
    </p>
  </div>
</section>

<!-- ────────────────────  MANIFESTO + STACK ──────────────────── -->
<section class="zn-manifesto">
  <div class="zn-shell zn-grid-asym">
    <aside class="zn-side">
      <span class="zn-eyebrow">A. Where it sits</span>
      <svg class="zn-stack" viewBox="0 0 360 280" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Three-layer stack diagram: your agent framework, JamJet safety layer in the middle, models and tools at the bottom">
        <g class="lay">
          <rect x="14" y="14" width="332" height="48" rx="6"/>
          <text x="180" y="42" text-anchor="middle">your agent framework</text>
        </g>
        <text x="32" y="74" class="lay-tag">LangGraph</text>
        <text x="118" y="74" class="lay-tag">CrewAI</text>
        <text x="180" y="74" class="lay-tag">ADK</text>
        <text x="232" y="74" class="lay-tag">OpenAI Agents</text>
        <text x="328" y="74" class="lay-tag">Spring AI</text>

        <g class="lay-jam">
          <rect x="14" y="92" width="332" height="96" rx="8"/>
          <text x="180" y="118" text-anchor="middle" class="lay-jam-title">JamJet</text>
          <text x="180" y="132" text-anchor="middle" class="lay-jam-sub">safety layer</text>
          <g class="lay-chip"><rect x="32"  y="144" width="62" height="18" rx="3"/><text x="63"  y="156" text-anchor="middle">policy</text></g>
          <g class="lay-chip"><rect x="100" y="144" width="62" height="18" rx="3"/><text x="131" y="156" text-anchor="middle">audit</text></g>
          <g class="lay-chip"><rect x="168" y="144" width="62" height="18" rx="3"/><text x="199" y="156" text-anchor="middle">approval</text></g>
          <g class="lay-chip"><rect x="32"  y="166" width="62" height="18" rx="3"/><text x="63"  y="178" text-anchor="middle">recovery</text></g>
          <g class="lay-chip"><rect x="100" y="166" width="62" height="18" rx="3"/><text x="131" y="178" text-anchor="middle">cost</text></g>
          <g class="lay-chip"><rect x="168" y="166" width="62" height="18" rx="3"/><text x="199" y="178" text-anchor="middle">memory</text></g>
        </g>

        <g class="lay">
          <rect x="14" y="218" width="332" height="48" rx="6"/>
          <text x="180" y="246" text-anchor="middle">models &middot; tools &middot; MCP &middot; A2A</text>
        </g>
        <text x="32" y="208" class="lay-tag">Claude</text>
        <text x="100" y="208" class="lay-tag">OpenAI</text>
        <text x="160" y="208" class="lay-tag">Gemini</text>
        <text x="220" y="208" class="lay-tag">Postgres</text>
        <text x="298" y="208" class="lay-tag">your APIs</text>
      </svg>
    </aside>

    <article class="zn-essay">
      <span class="zn-eyebrow">B. Why we built it</span>
      <p class="zn-essay-body">
        <span class="zn-dropcap">M</span>ost of what breaks an AI agent in the real world isn’t model quality.
        It’s the boring stuff: a worker dies, a tool gets called wrong, a budget runs out,
        an audit team asks what happened. We built JamJet to make those things controllable,
        recordable, and recoverable — without forcing you to abandon LangGraph or CrewAI or
        whatever’s already working.
      </p>
      <p class="zn-essay-body">
        The runtime sits between your agent and everything it touches. Models, tools, memory,
        other agents — every interaction passes through a layer that can block, wait,
        record, and resume. Open source. Apache 2.0. Cloud-neutral.
      </p>
      <p class="zn-essay-cta">
        <a href="/compare">How it fits with what you use &rarr;</a>
      </p>
    </article>
  </div>
</section>

<!-- ────────────────────  SIX FAILURE MODES (DARK) ──────────────────── -->
<section class="zn-dark" id="failure-modes">
  <div class="zn-shell">
    <div class="zn-dark-head">
      <span class="zn-eyebrow zn-eyebrow-light">C. What goes wrong, and what stops it</span>
      <h2 class="zn-h2">Six failure modes.<br/>Six gates.</h2>
      <p class="zn-dark-sub">
        Other tools observe what agents do. JamJet actively prevents unsafe behavior,
        recovers from failures, and creates audit evidence — at the runtime layer.
      </p>
    </div>

    <ol class="zn-failures">
      {failures.map(f => (
        <li class="zn-failure">
          <span class="zn-failure-num">{f.num}</span>
          <div>
            <strong class="zn-failure-title">{f.title}</strong>
            <p class="zn-failure-line">{f.line}</p>
          </div>
        </li>
      ))}
    </ol>

    <div class="zn-dark-foot">
      <a href="/showcase" class="zn-btn zn-btn-light">See each failure mode in action &rarr;</a>
    </div>
  </div>
</section>

<!-- ────────────────────  PULL QUOTE 1 ──────────────────── -->
<section class="zn-pq">
  <div class="zn-shell zn-pq-shell">
    <span class="zn-pq-mark">“</span>
    <p class="zn-pq-text">
      Production isn’t a milestone. It’s the moment your code has to defend itself.
    </p>
    <span class="zn-pq-attr">— a thing every serious engineer has learned the hard way</span>
  </div>
</section>

<!-- ────────────────────  CRASH RECOVERY DEMO ──────────────────── -->
<section class="zn-demo">
  <div class="zn-shell zn-grid-asym-flip">
    <article class="zn-demo-text">
      <span class="zn-eyebrow">D. Watch one survive</span>
      <h2 class="zn-h2 zn-h2-tight">Your agents crash.<br/>Ours recover.</h2>
      <p class="zn-essay-body">
        Every step is checkpointed as it happens. When a worker dies mid-run,
        the scheduler reclaims the lease and resumes from exactly where it stopped.
        No reruns. No duplicate side effects. No lost events.
      </p>
      <ul class="zn-demo-list">
        <li><strong>Worker crashes</strong> — the Analyze step fails unexpectedly.</li>
        <li><strong>Lease reclaimed</strong> — scheduler detects the failure.</li>
        <li><strong>Resume from checkpoint</strong> — completed steps stay completed.</li>
        <li><strong>Zero events lost</strong> — full execution integrity preserved.</li>
      </ul>
      <p class="zn-essay-cta">
        <a href="https://docs.jamjet.dev/en/docs/quickstart#try-crash-recovery-in-90-seconds">Run this demo &rarr;</a>
      </p>
    </article>

    <aside class="zn-demo-stage">
      <HeroAnimation />
      <TerminalReplay lines={terminalLines} title="jamjet · crash recovery" />
    </aside>
  </div>
</section>

<!-- ────────────────────  CODE MOMENT ──────────────────── -->
<section class="zn-code-section">
  <div class="zn-shell">
    <div class="zn-code-head">
      <span class="zn-eyebrow">E. Same runtime guarantees, two languages</span>
      <h2 class="zn-h2">Write Python or Java.<br/>JamJet handles replay, policy, and recovery.</h2>
    </div>

    <div class="zn-code-grid">
      <figure class="zn-code-fig">
        <figcaption class="zn-code-cap">
          <span>pipeline.py</span>
          <span class="zn-code-tag">Python</span>
        </figcaption>
        <pre class="zn-code-body" is:raw><span class="t-kw">from</span> <span class="t-w">jamjet</span> <span class="t-kw">import</span> <span class="t-w">task</span><span class="t-p">,</span> <span class="t-w">workflow</span><span class="t-p">,</span> <span class="t-w">approval</span>

<span class="t-p">@</span><span class="t-b">task</span><span class="t-p">(</span><span class="t-w">model</span><span class="t-p">=</span><span class="t-s">"claude-sonnet-4-6"</span><span class="t-p">,</span> <span class="t-w">max_cost</span><span class="t-p">=</span><span class="t-y">0.50</span><span class="t-p">)</span>
<span class="t-kw">async def</span> <span class="t-b">analyze</span><span class="t-p">(</span><span class="t-w">data</span><span class="t-p">:</span> <span class="t-y">dict</span><span class="t-p">) -&gt;</span> <span class="t-y">Report</span><span class="t-p">:</span>
    <span class="t-s">"""checkpointed, cost-capped"""</span>

<span class="t-p">@</span><span class="t-b">workflow</span>
<span class="t-kw">async def</span> <span class="t-b">pipeline</span><span class="t-p">(</span><span class="t-w">raw</span><span class="t-p">):</span>
    <span class="t-w">report</span> <span class="t-p">=</span> <span class="t-kw">await</span> <span class="t-b">analyze</span><span class="t-p">(</span><span class="t-w">raw</span><span class="t-p">)</span>     <span class="t-d"># crash-safe</span>
    <span class="t-kw">await</span> <span class="t-b">approval</span><span class="t-p">(</span><span class="t-w">report</span><span class="t-p">)</span>          <span class="t-d"># durable pause</span>
    <span class="t-kw">return await</span> <span class="t-b">publish</span><span class="t-p">(</span><span class="t-w">report</span><span class="t-p">)</span></pre>
      </figure>

      <figure class="zn-code-fig">
        <figcaption class="zn-code-cap">
          <span>Pipeline.java</span>
          <span class="zn-code-tag">Java</span>
        </figcaption>
        <pre class="zn-code-body" is:raw><span class="t-y">Agent</span> <span class="t-w">analyst</span> <span class="t-p">=</span> <span class="t-y">Agent</span><span class="t-p">.</span><span class="t-b">builder</span><span class="t-p">()</span>
    <span class="t-p">.</span><span class="t-b">name</span><span class="t-p">(</span><span class="t-s">"analyst"</span><span class="t-p">)</span>
    <span class="t-p">.</span><span class="t-b">model</span><span class="t-p">(</span><span class="t-s">"claude-sonnet-4-6"</span><span class="t-p">)</span>
    <span class="t-p">.</span><span class="t-b">strategy</span><span class="t-p">(</span><span class="t-y">Strategy</span><span class="t-p">.</span><span class="t-w">REFLECTION</span><span class="t-p">)</span>
    <span class="t-p">.</span><span class="t-b">maxCost</span><span class="t-p">(</span><span class="t-y">0.50</span><span class="t-p">)</span>                   <span class="t-d">// budget enforced</span>
    <span class="t-p">.</span><span class="t-b">build</span><span class="t-p">();</span>

<span class="t-y">WorkflowGraph</span> <span class="t-w">pipeline</span> <span class="t-p">=</span> <span class="t-y">WorkflowGraph</span><span class="t-p">.</span><span class="t-b">builder</span><span class="t-p">()</span>
    <span class="t-p">.</span><span class="t-b">node</span><span class="t-p">(</span><span class="t-w">analyst</span><span class="t-p">)</span>                    <span class="t-d">// crash-safe</span>
    <span class="t-p">.</span><span class="t-b">node</span><span class="t-p">(</span><span class="t-y">ApprovalGate</span><span class="t-p">.</span><span class="t-b">create</span><span class="t-p">())</span>     <span class="t-d">// durable pause</span>
    <span class="t-p">.</span><span class="t-b">node</span><span class="t-p">(</span><span class="t-w">publisher</span><span class="t-p">)</span>
    <span class="t-p">.</span><span class="t-b">build</span><span class="t-p">();</span></pre>
      </figure>
    </div>

    <p class="zn-marginal zn-marginal-center">
      Both compile to the same IR and run on the same Rust runtime.
      Java has its own native runtime too — zero sidecar, virtual threads,
      <a href="/benchmarks">8.9× faster than the REST sidecar</a> in our benchmark.
    </p>
  </div>
</section>

<!-- ────────────────────  CLOUD + ENGRAM SIDE-BY-SIDE ──────────────────── -->
<section class="zn-pair">
  <div class="zn-shell zn-pair-grid">
    <article class="zn-pair-card zn-pair-cloud">
      <span class="zn-eyebrow">F. When the team needs the cockpit</span>
      <h3 class="zn-pair-title">JamJet Cloud</h3>
      <p>
        The hosted control plane for agent runs. Trace timeline, policy violations,
        approval queue, cost guardrails, audit export, hosted Engram — across your team.
      </p>
      <div class="zn-pair-actions">
        <a href="/cloud" class="zn-btn zn-btn-primary">View Cloud</a>
        <a href="https://app.jamjet.dev" class="zn-btn zn-btn-ghost">Sign up free</a>
      </div>
    </article>

    <article class="zn-pair-card zn-pair-engram">
      <span class="zn-eyebrow">G. Need memory first?</span>
      <h3 class="zn-pair-title">Start with Engram.</h3>
      <p>
        Open-source memory for MCP-native AI agents. Fact extraction, conflict detection,
        hybrid retrieval, consolidation. Use it standalone with Claude, Cursor, or any MCP client.
      </p>
      <div class="zn-pair-actions">
        <a href="/engram" class="zn-btn zn-btn-primary">Add memory</a>
        <a href="https://github.com/jamjet-labs/jamjet/tree/main/runtime/engram-server" class="zn-btn zn-btn-ghost" target="_blank" rel="noopener">Source</a>
      </div>
    </article>
  </div>
</section>

<!-- ────────────────────  PULL QUOTE 2 ──────────────────── -->
<section class="zn-pq">
  <div class="zn-shell zn-pq-shell">
    <span class="zn-pq-mark">“</span>
    <p class="zn-pq-text">
      We don’t replace your framework. We sit underneath it, like a seatbelt.
    </p>
    <span class="zn-pq-attr">— the design intent, in one sentence</span>
  </div>
</section>

<!-- ────────────────────  RUNNING LOG ──────────────────── -->
<section class="zn-log">
  <div class="zn-shell">
    <div class="zn-log-head">
      <span class="zn-eyebrow">H. Running log</span>
      <h2 class="zn-h2 zn-h2-small">What we shipped lately.</h2>
    </div>
    <ol class="zn-log-list">
      {log.map(entry => (
        <li class="zn-log-entry">
          <time class="zn-log-date">{entry.date}</time>
          <a class="zn-log-link" href={entry.href}>
            <p class="zn-log-body">{entry.body}</p>
            <span class="zn-log-arrow">read &rarr;</span>
          </a>
        </li>
      ))}
    </ol>
    <p class="zn-log-foot">
      <a href="/blog">Full blog &rarr;</a>
    </p>
  </div>
</section>

<!-- ────────────────────  COLOPHON / CLOSING ──────────────────── -->
<section class="zn-close">
  <div class="zn-shell zn-close-shell">
    <h2 class="zn-close-tag">
      Make agent runs<br/>
      <span class="zn-close-italic">replayable, auditable,<br/>and controlled.</span>
    </h2>
    <div class="zn-install zn-install-center">
      <span class="zn-prompt">$</span>
      <span class="zn-cmd">pip install jamjet</span>
      <button class="zn-copy" id="copy-final" type="button">copy</button>
    </div>
    <div class="zn-cta-row zn-cta-center">
      <a href="https://docs.jamjet.dev/en/docs/quickstart" class="zn-btn zn-btn-primary">Run the quickstart</a>
      <a href="/cloud" class="zn-btn zn-btn-ghost">View JamJet Cloud</a>
      <a href="https://github.com/jamjet-labs/jamjet" class="zn-btn zn-btn-ghost" target="_blank" rel="noopener">GitHub</a>
    </div>
    <p class="zn-colophon">
      Apache 2.0 · Cloud-neutral · Framework-neutral ·
      Built in Rust, Python, and Java.
    </p>
  </div>
</section>

</BaseLayout>

<style>
  /* ─────────  shared scaffolding  ───────── */
  .zn-shell { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
  .zn-rule {
    margin: 36px 0;
    border-top: 1px solid var(--border);
  }
  .zn-eyebrow {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--text-muted);
    margin-bottom: 16px;
  }
  .zn-eyebrow-light { color: rgba(255,255,255,0.65); }
  .zn-marginal {
    font-style: italic;
    color: var(--text-muted);
    font-size: 0.92rem;
    line-height: 1.7;
    max-width: 640px;
  }
  .zn-marginal-center { text-align: center; margin: 32px auto 0; }
  .zn-marginal a {
    color: var(--text);
    border-bottom: 1px solid var(--border);
    text-decoration: none;
  }
  .zn-h2 {
    font-size: clamp(1.7rem, 3.6vw, 2.4rem);
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin: 4px 0 16px;
    font-weight: 600;
  }
  .zn-h2-tight { line-height: 1.05; }
  .zn-h2-small { font-size: clamp(1.4rem, 2.8vw, 1.8rem); }
  .zn-essay-body {
    color: var(--text);
    font-size: 1.05rem;
    line-height: 1.85;
    margin: 0 0 18px;
    max-width: 60ch;
  }
  .zn-essay-cta {
    margin-top: 24px;
    font-family: var(--font-sans);
    font-size: 0.92rem;
  }
  .zn-essay-cta a {
    color: var(--text);
    border-bottom: 1px solid var(--text);
    text-decoration: none;
    padding-bottom: 1px;
  }

  /* ─────────  buttons + install  ───────── */
  .zn-btn {
    font-family: var(--font-sans);
    font-size: 0.92rem;
    font-weight: 500;
    padding: 10px 18px;
    border-radius: 6px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    transition: transform 0.12s, background 0.12s, border-color 0.12s;
  }
  .zn-btn-primary {
    background: var(--text);
    color: var(--bg);
    border: 1px solid var(--text);
  }
  .zn-btn-primary:hover { transform: translateY(-1px); }
  .zn-btn-ghost {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border);
  }
  .zn-btn-ghost:hover { border-color: var(--text); }
  .zn-btn-light {
    background: var(--bg);
    color: var(--text);
    border: 1px solid var(--bg);
  }
  .zn-btn-light:hover { transform: translateY(-1px); }

  .zn-install {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: var(--bg-code, #0e1116);
    color: #eae8e1;
    padding: 8px 14px;
    border-radius: 6px;
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }
