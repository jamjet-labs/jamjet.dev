<!-- ── CTA ── -->
<section class="cta-section" style="padding: 100px 24px">
  <div class="cta-glow"></div>
  <div class="cta-inner">
    <div class="section-tag" style="justify-content:center">start building</div>
    <h2>Production agents<br/>start <span class="gradient-text">here</span></h2>
    <p style="margin-top:16px">Get a durable workflow running locally in under 10 minutes.<br/>No Docker, no servers — just <kbd style="background:var(--bg-3);border:1px solid var(--border);padding:2px 8px;border-radius:4px;font-size:0.85em">jamjet dev</kbd>.</p>

    <div class="install-cmd" style="margin:32px auto;width:fit-content">
      <span class="prompt">$</span>
      <span class="cmd">pip install jamjet</span>
      <button class="copy-btn" data-copy-install>copy</button>
    </div>

