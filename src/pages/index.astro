        <rect x="5"  y="16" width="5" height="4" fill="#f5c518"/>
        <rect x="10" y="16" width="5" height="4" fill="#f5c518"/>
        <rect x="15" y="16" width="5" height="4" fill="#f5c518"/>
        <rect x="20" y="16" width="5" height="4" fill="#f5c518"/>
