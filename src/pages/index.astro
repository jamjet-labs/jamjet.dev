---
// JamJet marketing landing page — yellow pixel theme
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#f5c518" />
  <title>JamJet — The Agent-Native Runtime</title>
  <meta name="description" content="Production-grade orchestration for AI agents. Durable execution, native MCP + A2A, full observability. Built in Rust. Authored in Python." />
  <meta property="og:title" content="JamJet — The Agent-Native Runtime" />
  <meta property="og:description" content="Durable execution, native MCP + A2A, full observability for AI agents." />
  <meta property="og:image" content="https://jamjet.dev/og.png" />
  <meta property="og:url" content="https://jamjet.dev" />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@jamjetdev" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    :root {
      --yellow:       #f5c518;
      --yellow-light: #fde68a;
      --yellow-dark:  #d97706;
      --yellow-dim:   rgba(245,197,24,0.12);
      --yellow-glow:  rgba(245,197,24,0.20);
      --bg:           #0a0a0e;
      --bg-2:         #111118;
      --bg-3:         #18181f;
      --border:       rgba(245,197,24,0.12);
      --border-sub:   rgba(255,255,255,0.06);
      --text:         #e8e8f0;
      --text-muted:   #6b7280;
      --text-dim:     #374151;
      --success:      #22c55e;
      --warning:      #f59e0b;
      --error:        #ef4444;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
      overflow-x: hidden;
    }
    code, pre, kbd { font-family: 'JetBrains Mono', monospace; }

    /* Pixel grid background */
    .pixelgrid {
      background-image:
        linear-gradient(rgba(245,197,24,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(245,197,24,0.03) 1px, transparent 1px);
      background-size: 24px 24px;
    }

    /* Yellow glow radial */
    .yglow::before {
      content: '';
      position: absolute; inset: 0; pointer-events: none;
      background: radial-gradient(ellipse 70% 50% at 50% 0%, var(--yellow-glow), transparent 70%);
    }

    /* ── Typography ── */
    h1, h2, h3 { line-height: 1.1; letter-spacing: -0.03em; }
    h1 { font-size: clamp(2.4rem, 6vw, 4.8rem); font-weight: 900; }
    h2 { font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 800; }
    h3 { font-size: 1rem; font-weight: 700; }

    .yellow { color: var(--yellow); }
    .yellow-bg { background: var(--yellow); color: #000; }

    .gradient-text {
      background: linear-gradient(135deg, var(--yellow) 0%, var(--yellow-light) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* ── Layout helpers ── */
    .container { max-width: 1160px; margin: 0 auto; padding: 0 24px; }
    section { padding: 88px 0; }
    .section-tag {
      font-size: 0.72rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.12em; color: var(--yellow);
      display: inline-flex; align-items: center; gap: 8px;
      margin-bottom: 14px;
    }
    .section-tag::before { content: '//'; opacity: 0.5; }

    /* ── Nav ── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      backdrop-filter: blur(20px) saturate(1.5);
      background: rgba(10,10,14,0.88);
      border-bottom: 1px solid var(--border-sub);
    }
    .nav-inner {
      max-width: 1160px; margin: 0 auto;
      padding: 0 24px; height: 60px;
      display: flex; align-items: center; gap: 32px;
    }

    /* Pixel logo in nav */
    .nav-logo {
      text-decoration: none; display: flex; align-items: center; gap: 12px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 1.1rem; font-weight: 700; color: var(--yellow);
      flex-shrink: 0;
    }
    .pixel-icon {
      display: grid; grid-template-columns: repeat(6,5px); grid-template-rows: repeat(8,4px);
      gap: 1px;
    }
    .px { background: var(--yellow); }
    .px-off { background: transparent; }

    .nav-links {
      display: flex; align-items: center; gap: 28px; list-style: none;
      margin-left: 8px; flex: 1;
    }
    .nav-links a {
      color: var(--text-muted); text-decoration: none;
      font-size: 0.875rem; font-weight: 500;
      transition: color 0.15s;
    }
    .nav-links a:hover { color: var(--yellow); }

    .nav-right { display: flex; align-items: center; gap: 12px; }
    .btn-nav-ghost {
      color: var(--text-muted); font-size: 0.85rem; font-weight: 500;
      text-decoration: none; padding: 7px 14px; border-radius: 6px;
      transition: all 0.15s; border: 1px solid transparent;
    }
    .btn-nav-ghost:hover { color: var(--text); border-color: var(--border-sub); }
    .btn-nav-cta {
      background: var(--yellow); color: #000;
      font-size: 0.85rem; font-weight: 700;
      text-decoration: none; padding: 8px 18px;
      border-radius: 6px; transition: all 0.15s;
    }
    .btn-nav-cta:hover { background: var(--yellow-light); transform: translateY(-1px); }

    /* ── Hero ── */
    .hero {
      min-height: 100vh;
      padding: 120px 24px 80px;
      display: flex; align-items: center;
      position: relative; overflow: hidden;
    }
    .hero-inner { max-width: 860px; margin: 0 auto; text-align: center; position: relative; z-index: 1; }

    .hero-badge {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--yellow-dim);
      border: 1px solid rgba(245,197,24,0.25);
      border-radius: 4px; padding: 5px 14px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.78rem; font-weight: 500; color: var(--yellow);
      margin-bottom: 32px;
    }
    .hero-badge .dot { width: 6px; height: 6px; background: var(--yellow); border-radius: 50%; animation: pulse 2s infinite; }
    @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }

    h1 { margin-bottom: 24px; }
    .hero-sub {
      font-size: clamp(1rem, 2.5vw, 1.25rem);
      color: var(--text-muted); max-width: 600px; margin: 0 auto 44px;
      font-weight: 400; line-height: 1.65;
    }
    .hero-actions {
      display: flex; justify-content: center; gap: 12px; flex-wrap: wrap;
      margin-bottom: 48px;
    }
    .btn-primary {
      background: var(--yellow); color: #000;
      font-weight: 700; font-size: 0.95rem;
      text-decoration: none; padding: 13px 26px;
      border-radius: 6px; transition: all 0.2s;
      display: inline-flex; align-items: center; gap: 8px;
    }
    .btn-primary:hover { background: var(--yellow-light); transform: translateY(-2px); box-shadow: 0 8px 32px rgba(245,197,24,0.3); }
    .btn-secondary {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.1);
      color: var(--text); font-weight: 600; font-size: 0.95rem;
      text-decoration: none; padding: 13px 26px;
      border-radius: 6px; transition: all 0.2s;
      display: inline-flex; align-items: center; gap: 8px;
    }
    .btn-secondary:hover { border-color: var(--border); background: var(--yellow-dim); }

    /* ── Install command ── */
    .install-cmd {
      display: inline-flex; align-items: center; gap: 16px;
      background: var(--bg-2); border: 1px solid var(--border);
      border-radius: 6px; padding: 12px 20px;
      font-family: 'JetBrains Mono', monospace; font-size: 0.9rem;
    }
    .install-cmd .prompt { color: var(--yellow); }
    .install-cmd .cmd { color: var(--text); }
    .copy-btn {
      background: none; border: none; cursor: pointer;
      color: var(--text-muted); font-size: 0.78rem;
      padding: 2px 8px; border-radius: 4px;
      transition: all 0.15s; font-family: inherit;
    }
    .copy-btn:hover { color: var(--yellow); background: var(--yellow-dim); }

    /* ── Terminal ── */
    .terminal {
      max-width: 700px; margin: 52px auto 0;
      background: var(--bg-2);
      border: 1px solid var(--border);
      border-radius: 8px; overflow: hidden;
      box-shadow: 0 0 0 1px var(--border), 0 32px 80px rgba(0,0,0,0.6), 0 0 80px rgba(245,197,24,0.06);
    }
    .term-bar {
      background: var(--bg-3); border-bottom: 1px solid var(--border-sub);
      padding: 10px 16px;
      display: flex; align-items: center; gap: 8px;
    }
    .term-dot { width: 10px; height: 10px; border-radius: 50%; }
    .term-title {
      margin: 0 auto; font-family: 'JetBrains Mono', monospace;
      font-size: 0.72rem; color: var(--text-dim);
    }
    .term-body { padding: 20px 22px; font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; line-height: 1.85; }
    .t-y { color: var(--yellow); }
    .t-g { color: var(--success); }
    .t-b { color: #60a5fa; }
    .t-m { color: var(--text-muted); }
    .t-w { color: var(--text); }
    .t-d { color: var(--text-dim); }

    /* ── Section dividers ── */
    .sep { border: none; border-top: 1px solid var(--border-sub); margin: 0; }

    /* ── Problems ── */
    .problems-bg { background: var(--bg-2); }
    .problems-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 2px; /* pixel joints */
      border: 1px solid var(--border); border-radius: 8px; overflow: hidden;
    }
    .problem-card {
      background: var(--bg); padding: 28px;
      border: none;
      transition: background 0.2s;
    }
    .problem-card:hover { background: var(--bg-2); }
    .prob-label { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-dim); margin-bottom: 8px; }
    .problem-card h3 { font-size: 0.95rem; color: var(--text); margin-bottom: 8px; }
    .problem-card .prob-desc { font-size: 0.83rem; color: var(--text-muted); line-height: 1.55; margin-bottom: 14px; }
    .problem-card .prob-ans { font-size: 0.8rem; color: var(--yellow); font-weight: 600; font-family: 'JetBrains Mono', monospace; }

    /* ── Features ── */
    .features-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 16px;
    }
    .feat-card {
      background: var(--bg-2); border: 1px solid var(--border-sub);
      border-radius: 8px; padding: 26px;
      transition: all 0.2s; position: relative; overflow: hidden;
    }
    .feat-card::after {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
      background: linear-gradient(90deg, var(--yellow), transparent);
      opacity: 0; transition: opacity 0.2s;
    }
    .feat-card:hover { border-color: var(--border); }
    .feat-card:hover::after { opacity: 1; }
    .feat-tag {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem; color: var(--yellow-dark);
      background: var(--yellow-dim); border: 1px solid rgba(245,197,24,0.2);
      border-radius: 3px; padding: 2px 8px; display: inline-block; margin-bottom: 14px;
    }
    .feat-card h3 { color: var(--text); margin-bottom: 8px; font-size: 0.95rem; }
    .feat-card p { font-size: 0.83rem; color: var(--text-muted); line-height: 1.6; }

    /* ── Code tabs ── */
    .code-wrap {
      background: var(--bg-2); border: 1px solid var(--border);
      border-radius: 8px; overflow: hidden;
    }
    .tab-strip {
      display: flex; overflow-x: auto; scrollbar-width: none;
      background: var(--bg-3); border-bottom: 1px solid var(--border-sub);
    }
    .tab-strip::-webkit-scrollbar { display: none; }
    .tab {
      padding: 10px 18px; font-size: 0.78rem; font-weight: 600;
      font-family: 'JetBrains Mono', monospace;
      color: var(--text-dim); cursor: pointer; white-space: nowrap;
      border-bottom: 2px solid transparent; transition: all 0.15s;
      background: none; border-top: none; border-left: none; border-right: none;
    }
    .tab.active { color: var(--yellow); border-bottom-color: var(--yellow); }
    .tab:hover:not(.active) { color: var(--text-muted); }

    .tab-pane { display: none; padding: 24px; }
    .tab-pane.active { display: block; }
    pre.code {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.8rem; line-height: 1.75;
      overflow-x: auto; color: var(--text);
    }
    .kw  { color: #f97316; }
    .str { color: #86efac; }
    .cmt { color: var(--text-dim); font-style: italic; }
    .fn  { color: #60a5fa; }
    .cls { color: #c084fc; }
    .dec { color: var(--yellow); }
    .typ { color: #34d399; }
    .op  { color: var(--yellow-dark); }

    /* ── Comparison table ── */
    .table-wrap { overflow-x: auto; border-radius: 8px; border: 1px solid var(--border); }
    table { width: 100%; border-collapse: collapse; font-size: 0.83rem; }
    th {
      padding: 12px 16px; text-align: left; font-weight: 700;
      background: var(--bg-3); border-bottom: 1px solid var(--border-sub);
      white-space: nowrap; font-family: 'JetBrains Mono', monospace; font-size: 0.75rem;
    }
    th.jam { color: var(--yellow); }
    td { padding: 10px 16px; border-bottom: 1px solid rgba(255,255,255,0.03); color: var(--text-muted); }
    td.name { color: var(--text); font-weight: 500; }
    td.jam { color: var(--text); }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: rgba(245,197,24,0.02); }
    .chk { color: var(--success); font-weight: 700; }
    .par { color: var(--warning); }
    .no  { color: var(--text-dim); }

    /* ── CTA ── */
    .cta-section {
      text-align: center; position: relative;
      border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
      background: var(--bg-2);
    }
    .cta-glow {
      position: absolute; width: 600px; height: 400px;
      background: radial-gradient(circle, rgba(245,197,24,0.1), transparent 70%);
      top: 50%; left: 50%; transform: translate(-50%, -50%);
      pointer-events: none;
    }
    .cta-inner { max-width: 600px; margin: 0 auto; position: relative; z-index: 1; }
    .cta-inner h2 { margin-bottom: 16px; }
    .cta-inner p { color: var(--text-muted); margin-bottom: 36px; font-size: 1.05rem; }

    /* ── Footer ── */
    footer { padding: 48px 0; border-top: 1px solid var(--border-sub); }
    .footer-grid {
      display: grid; grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 40px; margin-bottom: 40px;
    }
    .footer-desc { font-size: 0.83rem; color: var(--text-dim); margin-top: 14px; line-height: 1.6; }
    .footer-col h4 {
      font-size: 0.72rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.12em; color: var(--text-dim); margin-bottom: 14px;
      font-family: 'JetBrains Mono', monospace;
    }
    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 9px; }
    .footer-col a { font-size: 0.83rem; color: var(--text-dim); text-decoration: none; transition: color 0.15s; }
    .footer-col a:hover { color: var(--yellow); }
    .footer-bottom {
      display: flex; justify-content: space-between; align-items: center;
      padding-top: 24px; border-top: 1px solid var(--border-sub);
      font-size: 0.78rem; color: var(--text-dim); flex-wrap: wrap; gap: 12px;
    }
    .footer-bottom a { color: var(--text-dim); text-decoration: none; }
    .footer-bottom a:hover { color: var(--text-muted); }

    /* ── Responsive ── */
    @media (max-width: 768px) {
      .nav-links { display: none; }
      .footer-grid { grid-template-columns: 1fr 1fr; }
      .problems-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 480px) {
      .footer-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body class="pixelgrid">

<!-- ── Navigation ── -->
<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="JamJet home">
      <!-- Pixel art bolt: 6×8 grid of 4px squares -->
      <svg width="30" height="36" viewBox="0 0 30 36" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="10" y="0"  width="5" height="4" fill="#f5c518"/>
        <rect x="15" y="0"  width="5" height="4" fill="#f5c518"/>
        <rect x="5"  y="4"  width="5" height="4" fill="#f5c518"/>
