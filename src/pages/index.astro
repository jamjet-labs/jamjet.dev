    line-height: 1.7;
    max-width: 640px;
  }
  .zn-marginal-center { text-align: center; margin: 32px auto 0; }
  .zn-marginal a {
    color: var(--text);
    border-bottom: 1px solid var(--border);
    text-decoration: none;
  }
  .zn-h2 {
    font-size: clamp(1.7rem, 3.6vw, 2.4rem);
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin: 4px 0 16px;
    font-weight: 600;
  }
  .zn-h2-tight { line-height: 1.05; }
  .zn-h2-small { font-size: clamp(1.4rem, 2.8vw, 1.8rem); }
  .zn-essay-body {
    color: var(--text);
    font-size: 1.05rem;
    line-height: 1.85;
    margin: 0 0 18px;
    max-width: 60ch;
  }
  .zn-essay-cta {
    margin-top: 24px;
    font-family: var(--font-sans);
    font-size: 0.92rem;
  }
  .zn-essay-cta a {
    color: var(--text);
    border-bottom: 1px solid var(--text);
    text-decoration: none;
    padding-bottom: 1px;
  }

  /* ─────────  buttons + install  ───────── */
  .zn-btn {
    font-family: var(--font-sans);
    font-size: 0.92rem;
    font-weight: 500;
    padding: 10px 18px;
    border-radius: 6px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    transition: transform 0.12s, background 0.12s, border-color 0.12s;
  }
  .zn-btn-primary {
    background: var(--text);
    color: var(--bg);
    border: 1px solid var(--text);
  }
  .zn-btn-primary:hover { transform: translateY(-1px); }
  .zn-btn-ghost {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border);
  }
  .zn-btn-ghost:hover { border-color: var(--text); }
  .zn-btn-light {
    background: var(--bg);
    color: var(--text);
    border: 1px solid var(--bg);
  }
  .zn-btn-light:hover { transform: translateY(-1px); }

  .zn-install {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: var(--bg-code, #0e1116);
    color: #eae8e1;
    padding: 8px 14px;
    border-radius: 6px;
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }
  .zn-install-center {
    display: inline-flex;
    margin: 24px auto;
  }
  .zn-prompt { color: #888; }
  .zn-copy {
    background: rgba(255,255,255,0.08);
    border: 0;
    color: #aaa;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 4px 8px;
    border-radius: 3px;
    cursor: pointer;
  }
  .zn-copy:hover { color: #eae8e1; background: rgba(255,255,255,0.16); }

  /* ─────────  COVER  ───────── */
  .zn-cover {
    padding: 64px 0 80px;
    border-bottom: 1px solid var(--border);
  }
  .zn-masthead {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 64px;
    flex-wrap: wrap;
    gap: 12px;
  }
  .zn-vol, .zn-issue {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--text-muted);
    font-weight: 600;
  }
  .zn-issue { font-style: italic; letter-spacing: 0.06em; text-transform: none; font-weight: 400; }
  .zn-display {
    font-size: clamp(3rem, 9vw, 6.5rem);
    line-height: 0.95;
    letter-spacing: -0.025em;
    font-weight: 600;
    margin: 0 0 32px;
  }
  .zn-display-italic { font-style: italic; font-weight: 500; }

  /* ────────  RECORDER WRAP + FLYING RECEIPT  ──────── */
  .zn-recwrap { position: relative; }
  .zn-recwrap > :global(.margin-note) { position: absolute; right: 0; top: -28px; }
  .zn-receipt-fly {
    position: absolute; right: -10px; bottom: -30px; z-index: 2;
    display: flex; flex-direction: column;
    background: var(--surface, var(--bg)); color: var(--text);
    border: 1px solid var(--border-strong, rgba(20,20,19,0.20));
    width: 230px; padding: 12px 14px 14px;
    font-family: var(--font-mono); font-size: 10.5px; line-height: 1.75;
    transform: rotate(2.5deg);
    box-shadow: 0 10px 24px rgba(20, 20, 19, 0.2);
  }
  .zn-receipt-fly :global(.seal) { position: absolute; right: 10px; bottom: 10px; }
  @media (max-width: 760px) {
    .zn-receipt-fly { position: static; transform: rotate(1deg); margin: 14px auto 0; }
    .zn-recwrap > :global(.margin-note) { display: none; }
  }

  /* ────────  RECEIPT ARTIFACT (hero proof)  ──────── */
  .zn-receipt {
    margin: 0 0 40px;
    max-width: min(720px, 100%);
    width: 100%;
    border: 1px solid var(--border-strong, rgba(20,20,19,0.20));
    background: var(--bg-alt, #edecea);
    border-radius: 2px;
    overflow: hidden;
    position: relative;
    box-sizing: border-box;
  }
  .zn-receipt::before,
  .zn-receipt::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--border-strong, rgba(20,20,19,0.20));
    opacity: 0.0;
  }
  .zn-receipt-cap {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border);
    background: var(--bg);
    flex-wrap: wrap;
  }
  .zn-receipt-name {
    color: var(--text);
    font-weight: 600;
  }
  .zn-receipt-sep {
    opacity: 0.5;
  }
  .zn-receipt-pill {
    margin-left: auto;
    padding: 2px 8px;
    background: var(--text);
    color: var(--bg);
    font-size: 10px;
    letter-spacing: 0.10em;
    border-radius: 2px;
    font-weight: 600;
  }
  .zn-receipt-body {
    margin: 0;
    padding: 18px 20px;
    background: transparent;
    border: 0;
    border-radius: 0;
    font-family: var(--font-mono);
    font-size: 11.5px;
    line-height: 1.65;
    color: var(--text);
    overflow-x: auto;
    white-space: pre;
    max-width: 100%;
    box-sizing: border-box;
  }
  .zn-receipt-body code {
    background: transparent;
    padding: 0;
    color: inherit;
    font-size: inherit;
  }
  .zn-receipt-foot {
    padding: 10px 16px;
    border-top: 1px solid var(--border);
    background: var(--bg);
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 0.02em;
  }
  .zn-receipt-foot a {
    color: var(--text);
    border-bottom: 1px solid var(--border);
    text-decoration: none;
  }
  .zn-receipt-foot a:hover {
    border-bottom-color: var(--text);
  }
  .zn-receipt .zn-rec-key   { color: var(--text-secondary, #555550); }
  .zn-receipt .zn-rec-str   { color: var(--text); }
  .zn-receipt .zn-rec-hash  { color: var(--text); font-style: italic; }
  .zn-receipt .zn-rec-hash-final {
    color: var(--text);
    font-weight: 600;
    font-style: normal;
    border-bottom: 1px solid var(--border-strong, rgba(20,20,19,0.30));
    padding-bottom: 1px;
  }
  .zn-receipt .zn-rec-punct { color: var(--text-muted); }
  @media (max-width: 640px) {
    .zn-receipt-body { font-size: 11px; padding: 14px 14px; }
  }

  /* ────────  CODE CARD (smallest adoption step)  ──────── */
  .zn-codecard {
    margin: 0 0 40px;
    max-width: min(720px, 100%);
    width: 100%;
    border: 1px solid var(--border-strong, rgba(20,20,19,0.20));
    background: var(--bg);
    border-radius: 2px;
    overflow: hidden;
    box-sizing: border-box;
  }
  .zn-codecard-cap, .zn-codecard-foot {
    padding: 10px 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .zn-codecard-cap {
    border-bottom: 1px solid var(--border);
    background: var(--bg-alt, #edecea);
    display: flex; gap: 8px; align-items: center; flex-wrap: wrap;
  }
  .zn-codecard-name { color: var(--text); font-weight: 600; }
  .zn-codecard-sep { opacity: 0.5; }
  .zn-codecard-body {
    margin: 0;
    padding: 20px 22px;
    background: transparent;
    border: 0;
    border-radius: 0;
    font-family: var(--font-mono);
    font-size: 13.5px;
    line-height: 1.7;
    color: var(--text);
    overflow-x: auto;
    white-space: pre;
    box-sizing: border-box;
  }
  .zn-codecard-body code {
    background: transparent;
    padding: 0;
    color: inherit;
    font-size: inherit;
  }
  .zn-codecard-cap-slim { padding: 6px 16px; }
  .zn-codecard-foot-slim { padding: 6px 16px; }
  .zn-codecard:has(.zn-codecard-cap-slim) .zn-codecard-body {
    font-size: 12.5px;
    padding: 12px 18px;
    line-height: 1.55;
  }
  .zn-hero-pitch {
    margin: 8px 0 28px;
    padding: 14px 18px;
    background: var(--bg-alt);
    border-left: 3px solid var(--warning);
    border-radius: 2px;
    font-size: 1.02rem;
    line-height: 1.65;
    color: var(--text);
    max-width: 60ch;
  }
  .zn-hero-pitch strong { font-weight: 600; }
  .zn-codecard-foot {
    border-top: 1px solid var(--border);
    background: var(--bg-alt, #edecea);
    text-transform: none;
    letter-spacing: 0.02em;
  }
  .zn-codecard-foot code {
    background: rgba(20,20,19,0.06);
    padding: 1px 6px;
    border-radius: 2px;
    font-size: 0.95em;
  }
  /* Sumi-ink syntax tints — minimal palette, no neon. */
  .zn-codecard .zn-tok-kw    { color: var(--text); font-weight: 700; }
  .zn-codecard .zn-tok-mod   { color: var(--text); }
  .zn-codecard .zn-tok-dec   { color: var(--text); font-weight: 700; }
  .zn-codecard .zn-tok-fn    { color: var(--text); font-weight: 600; }
  .zn-codecard .zn-tok-type  { color: var(--text-secondary, #555550); font-style: italic; }
  .zn-codecard .zn-tok-str   { color: var(--text-secondary, #555550); }
  .zn-codecard .zn-tok-op    { color: var(--text-muted); }
  @media (max-width: 640px) {
    .zn-codecard-body { font-size: 12px; padding: 16px 14px; }
  }

  .zn-lead {
    font-size: 1.2rem;
    line-height: 1.65;
    color: var(--text);
    max-width: 60ch;
    margin: 0 0 24px;
  }
  .zn-lead-italic {
    font-style: italic;
    color: var(--text-muted);
    margin-bottom: 40px;
  }
  .zn-lede {
    font-size: 1.2rem;
    line-height: 1.65;
    color: var(--text);
    max-width: 60ch;
    margin: 0 0 24px;
  }
  .zn-lede-meta {
    font-size: 0.95em;
    opacity: 0.7;
    margin-top: 0.5rem;
  }
  .zn-credentials {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--zn-rule, #e5e0d8);
