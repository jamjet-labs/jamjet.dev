---
import BaseLayout from '../layouts/BaseLayout.astro';
import Recorder from '../components/Recorder.astro';
import WhyNotLogs from '../components/WhyNotLogs.astro';
import { getCollection } from 'astro:content';
import Seal from '../components/Seal.astro';
import MarginNote from '../components/MarginNote.astro';
import ShipLogStrip from '../components/ShipLogStrip.astro';
import BrushIcon from '../components/BrushIcon.astro';

const monthShort = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const allPosts = await getCollection('blog', ({ data }) => data.draft !== true);
const log = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6)
  .map(post => ({
    date: `${monthShort[post.data.date.getUTCMonth()]} ${post.data.date.getUTCDate()}`,
    body: post.data.description,
    href: `/blog/${post.id.replace(/\.md$/, '')}/`,
  }));

const failures = [
  { num: '01', tone: 'neutral', title: 'Lost progress', line: 'A worker dies mid-run. JamJet replays the event log and resumes at the failed node.' },
  { num: '02', tone: 'error',   title: 'Unsafe tool', line: 'An agent reaches for a tool it shouldn’t. The 4-level policy hierarchy blocks the call before execution.' },
  { num: '03', tone: 'warning', title: 'Skipped approval', line: 'A high-risk action waits for a human. The run survives restarts. The decision lands in audit.' },
  { num: '04', tone: 'error',   title: 'Runaway cost', line: 'A reflection loop won’t stop spending. The runtime halts the loop before it crosses the cap.' },
  { num: '05', tone: 'neutral', title: 'Missing audit', line: 'Compliance asks what happened. Every decision is in a signed, exportable evidence package.' },
  { num: '06', tone: 'neutral', title: 'Forgotten context', line: 'The agent forgets across sessions. Engram surfaces durable facts — not raw chat history.' },
];

const adapters = [
  { name: '@jamjet/claude-code-hook', install: 'npm i -g @jamjet/claude-code-hook', host: 'Claude Code PreToolUse hook', href: 'https://npmjs.com/package/@jamjet/claude-code-hook' },
  { name: '@jamjet/mcp-shim',         install: 'npx -y @jamjet/mcp-shim …',          host: 'Any MCP client (Claude Desktop, Cursor, …)', href: 'https://npmjs.com/package/@jamjet/mcp-shim' },
  { name: '@jamjet/openai-guardrail', install: 'npm i @jamjet/openai-guardrail',     host: 'OpenAI Agents SDK tool guardrail (TS)', href: 'https://npmjs.com/package/@jamjet/openai-guardrail' },
  { name: 'jamjet.integrations.openai_guardrail', install: 'pip install jamjet',     host: 'OpenAI Agents SDK tool guardrail (Python)', href: 'https://pypi.org/project/jamjet/' },
  { name: 'jamjet',                   install: 'pip install jamjet',                 host: 'Python SDK + runtime', href: 'https://pypi.org/project/jamjet/' },
  { name: '@jamjet/cloud',            install: 'npm i @jamjet/cloud',                host: 'TypeScript SDK + shared engine', href: 'https://npmjs.com/package/@jamjet/cloud' },
  { name: '@jamjet/cli',              install: 'npm i -g @jamjet/cli',               host: 'jamjet audit show / jamjet approve', href: 'https://npmjs.com/package/@jamjet/cli' },
];

const homeLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "JamJet",
  "description": "The action-control plane for AI agents. One policy file, one audit trail, across Claude Code hooks, OpenAI Agents SDK guardrails, MCP gateways, Python and TypeScript SDKs, and custom runtimes.",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Linux, macOS, Windows",
  "url": "https://jamjet.dev",
  "downloadUrl": "https://pypi.org/project/jamjet/",
  "softwareVersion": "0.8.3",
  "license": "https://www.apache.org/licenses/LICENSE-2.0",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
};
---

<BaseLayout
  title="JamJet — Prove every agent action."
  description="JamJet controls AI-initiated production changes and emits portable receipts your security, compliance, and audit teams can verify. Open spec, Python and TypeScript SDKs, JVM runtime, free OSS, hosted Cloud."
  canonical="https://jamjet.dev/"
>
<Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify(homeLd)}></script>
</Fragment>

<!-- ────────────────────────  COVER ──────────────────────── -->
<section class="zn-cover">
  <div class="zn-shell">
    <div class="zn-masthead">
      <span class="zn-vol">JamJet · Agent Action Control</span>
      <span class="zn-issue">Prove what every agent was allowed to do</span>
    </div>

    <h1 class="zn-display">
      Prove every<br/>
      <span class="zn-display-italic">agent action.</span>
    </h1>

    <div class="zn-recwrap">
      <MarginNote rotate={-2}>a real run, not a render</MarginNote>
      <Recorder />
      <aside class="zn-receipt-fly" aria-label="signed action receipt">
        <span>receipt 0192c8d0-1f2a</span>
        <span>github.merge &middot; repo.merges v2</span>
        <span>approved &middot; sunil &middot; 14:02</span>
        <span>sig 4d905d&hellip;verified</span>
        <Seal verdict="approved" size="sm" />
      </aside>
    </div>

    <p class="zn-lede">
      That's one agent run, played back. It read files. It tried to drop a users table — blocked.
      It crashed mid-analysis — recovered. It asked to merge to production — held for a human, then signed.
      Drag the scrubber: every call is policy-checked, recoverable, and written to a receipt anyone can
      verify, independent of your agent framework.
    </p>

    <p class="zn-hero-pitch">
      <strong>Not another agent framework.</strong> The action-control layer that sits underneath them.
      Keep LangGraph, CrewAI, Claude Code, MCP, OpenAI Agents SDK, or Spring AI —
      add JamJet where tool calls need policy, approval, and audit.
    </p>

    <p class="zn-lede zn-lede-meta">
      From the lab behind the <a href="/engram">Engram memory benchmarks</a> and the AIP agent-identity work &mdash; see <a href="/research">research</a>.
    </p>

    <p class="zn-credentials">
      <span class="zn-cred-item"><strong>Engram</strong> &middot; 88.8% on <a href="/engram">LongMemEval-S</a> (proxy benchmark)</span>
      <span class="zn-cred-sep">·</span>
      <span class="zn-cred-item"><strong>AIP</strong> &middot; agent identity + delegation chains (arXiv draft)</span>
      <span class="zn-cred-sep">·</span>
      <span class="zn-cred-item"><strong>AgentBoundary v0.1</strong> &middot; open spec for AI action proof &middot; <a href="https://agentboundary.jamjet.dev/">public</a></span>
    </p>

    <div class="zn-cover-foot">
      <div class="zn-cta-row">
        <a href="#adapters" class="zn-btn zn-btn-primary">See every adapter &darr;</a>
        <a href="https://docs.jamjet.dev/en/docs/quickstart" class="zn-btn zn-btn-ghost">Get started in 60s</a>
        <a href="https://agentboundary.jamjet.dev/" class="zn-btn zn-btn-ghost">Run conformance &rarr;</a>
      </div>
      <p class="zn-cta-aside">
        Already shipping in production? <a href="https://app.jamjet.dev/signup">Try JamJet Cloud free</a>.
      </p>
      <div class="zn-install">
        <span class="zn-prompt">$</span>
        <span class="zn-cmd">pip install jamjet</span>
        <button class="zn-copy" id="copy-install" type="button">copy</button>
      </div>
    </div>

  </div>
</section>

<!-- ────────────────────  WHAT JUST HAPPENED ──────────────────── -->
<section class="zn-readback">
  <div class="zn-shell">
    <div class="zn-readback-head">
      <span class="zn-eyebrow">What just happened</span>
      <h2 class="zn-h2">
        Three moments on that tape.<br/>
        <span class="zn-display-italic">Three things JamJet did.</span>
      </h2>
    </div>

    <ol class="zn-beats">
      <li class="zn-beat zn-beat-block">
        <span class="zn-beat-tag">blocked</span>
        <Seal verdict="blocked" size="sm" />
        <strong class="zn-beat-title">It tried to drop a users table.</strong>
        <p class="zn-beat-line">
          <code>db.drop_user</code> hit a destructive-data policy and never executed.
          The attempt is recorded, not lost.
        </p>
      </li>
      <li class="zn-beat zn-beat-recover">
        <span class="zn-beat-tag">recovered</span>
        <Seal verdict="resumed" size="sm" />
        <strong class="zn-beat-title">The Analyze worker crashed.</strong>
        <p class="zn-beat-line">
          The scheduler reclaimed the lease and resumed from the last checkpoint.
          Completed steps stayed completed. Zero events lost.
        </p>
      </li>
      <li class="zn-beat zn-beat-approval">
        <span class="zn-beat-tag">signed</span>
        <Seal verdict="held" size="sm" />
        <strong class="zn-beat-title">A merge to production waited for a human.</strong>
        <p class="zn-beat-line">
          <code>github.merge</code> required approval. Once a person said yes, the action ran
          and was sealed into a receipt anyone can verify.
        </p>
      </li>
    </ol>

    <div class="zn-readback-code">
      <span class="zn-eyebrow">How a call gets on the tape</span>
      <figure class="zn-codecard" aria-label="Gate one production action with JamJet">
        <figcaption class="zn-codecard-cap zn-codecard-cap-slim">
          <span class="zn-codecard-name">merge.py</span>
        </figcaption>
        <pre class="zn-codecard-body"><code><span class="zn-tok-kw">from</span> <span class="zn-tok-mod">jamjet</span> <span class="zn-tok-kw">import</span> gate

<span class="zn-tok-dec">@gate</span>(<span class="zn-tok-str">&quot;github.merge&quot;</span>, require_approval<span class="zn-tok-op">=</span><span class="zn-tok-kw">True</span>)
<span class="zn-tok-kw">def</span> <span class="zn-tok-fn">merge_pr</span>(repo: <span class="zn-tok-type">str</span>, pr: <span class="zn-tok-type">int</span>) <span class="zn-tok-op">-&gt;</span> <span class="zn-tok-type">str</span>:
    <span class="zn-tok-kw">return</span> github.merge(repo, pr)</code></pre>
        <figcaption class="zn-codecard-foot zn-codecard-foot-slim">
          <code>pip install jamjet</code> &middot; one decorator puts the call on the tape, with the same policy across Claude Code, MCP, OpenAI Agents SDK, Spring AI
        </figcaption>
      </figure>
    </div>
  </div>
</section>

<!-- ────────────────────  MANIFESTO + STACK ──────────────────── -->
<section class="zn-manifesto">
  <div class="zn-shell zn-grid-asym">
    <aside class="zn-side">
      <span class="zn-eyebrow">Where it sits</span>
      <svg class="zn-stack" viewBox="0 0 360 280" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Three-layer stack diagram: your agent framework, JamJet safety layer in the middle, models and tools at the bottom">
        <g class="lay">
          <rect x="14" y="14" width="332" height="48" rx="6"/>
          <text x="180" y="42" text-anchor="middle">your agent framework</text>
        </g>
        <text x="32" y="74" class="lay-tag">LangGraph</text>
        <text x="118" y="74" class="lay-tag">CrewAI</text>
        <text x="180" y="74" class="lay-tag">ADK</text>
        <text x="232" y="74" class="lay-tag">OpenAI Agents</text>
        <text x="328" y="74" class="lay-tag">Spring AI</text>

        <g class="lay-jam">
          <rect x="14" y="92" width="332" height="96" rx="8"/>
          <text x="180" y="118" text-anchor="middle" class="lay-jam-title">JamJet</text>
          <text x="180" y="132" text-anchor="middle" class="lay-jam-sub">safety layer</text>
          <g class="lay-chip"><rect x="32"  y="144" width="62" height="18" rx="3"/><text x="63"  y="156" text-anchor="middle">policy</text></g>
          <g class="lay-chip"><rect x="100" y="144" width="62" height="18" rx="3"/><text x="131" y="156" text-anchor="middle">audit</text></g>
          <g class="lay-chip"><rect x="168" y="144" width="62" height="18" rx="3"/><text x="199" y="156" text-anchor="middle">approval</text></g>
          <g class="lay-chip"><rect x="32"  y="166" width="62" height="18" rx="3"/><text x="63"  y="178" text-anchor="middle">recovery</text></g>
          <g class="lay-chip"><rect x="100" y="166" width="62" height="18" rx="3"/><text x="131" y="178" text-anchor="middle">cost</text></g>
          <g class="lay-chip"><rect x="168" y="166" width="62" height="18" rx="3"/><text x="199" y="178" text-anchor="middle">memory</text></g>
        </g>

        <g class="lay">
          <rect x="14" y="218" width="332" height="48" rx="6"/>
          <text x="180" y="246" text-anchor="middle">models &middot; tools &middot; MCP &middot; A2A</text>
        </g>
        <text x="32" y="208" class="lay-tag">Claude</text>
        <text x="100" y="208" class="lay-tag">OpenAI</text>
        <text x="160" y="208" class="lay-tag">Gemini</text>
        <text x="220" y="208" class="lay-tag">Postgres</text>
        <text x="298" y="208" class="lay-tag">your APIs</text>
      </svg>
    </aside>

    <article class="zn-essay">
      <span class="zn-eyebrow">Why we built it</span>
      <p class="zn-essay-body">
        <span class="zn-dropcap">M</span>ost of what breaks an AI agent in the real world isn’t model quality.
        It’s the boring stuff: a worker dies, a tool gets called wrong, a budget runs out,
        an audit team asks what happened. We built JamJet to make those things controllable,
        recordable, and recoverable — without forcing you to abandon LangGraph or CrewAI or
        whatever’s already working.
      </p>
      <p class="zn-essay-body">
        The runtime sits between your agent and everything it touches. Models, tools, memory,
        other agents — every interaction passes through a layer that can block, wait,
        record, and resume. Open source. Apache 2.0. Cloud-neutral.
      </p>
      <p class="zn-essay-cta">
        <a href="/compare">How it fits with what you use &rarr;</a>
      </p>
    </article>
  </div>
</section>

<!-- ────────────────────  ADAPTERS GRID ──────────────────── -->
<section class="zn-adapters" id="adapters">
  <div class="zn-shell">
    <div class="zn-adapters-head">
      <span class="zn-eyebrow">Every source the recorder captures</span>
      <h2 class="zn-h2">
        Every agent toolchain is inventing its own safety layer.<br/>
        <span class="zn-display-italic">JamJet gives you one.</span>
      </h2>
      <p class="zn-essay-body">
        One <code>policy.yaml</code> in <code>~/.jamjet/</code>. Every adapter below loads it and
        emits conformant audit JSONL. Run <code>jamjet audit show</code> to tail every decision,
        from every source, on one tape.
      </p>
    </div>

    <ul class="zn-adapter-list">
      {adapters.map(a => (
        <li class="zn-adapter">
          <a class="zn-adapter-link" href={a.href} target="_blank" rel="noopener">
            <code class="zn-adapter-name">{a.name}</code>
            <span class="zn-adapter-host">{a.host}</span>
            <code class="zn-adapter-install">{a.install}</code>
          </a>
        </li>
      ))}
    </ul>

    <p class="zn-marginal zn-marginal-center">
      We respect the platforms we plug into. Claude Code gave developers a hook point —
      JamJet gives that hook point a policy engine, approval flow, and audit trail, and
      carries the same rules to OpenAI Agents SDK, MCP, and your own code.
    </p>
  </div>
</section>

<!-- ────────────────────  SIX FAILURE MODES (DARK) ──────────────────── -->
<section class="zn-dark" id="failure-modes">
  <div class="zn-shell">
    <div class="zn-dark-head">
      <span class="zn-eyebrow zn-eyebrow-light">What the recorder catches</span>
      <h2 class="zn-h2">Six failure modes.<br/>Six gates.</h2>
      <p class="zn-dark-sub">
        Other tools observe what agents do. JamJet actively prevents unsafe behavior,
        recovers from failures, and creates audit evidence — at the runtime layer.
      </p>
    </div>

    <ol class="zn-failures">
      {failures.map(f => (
        <li class={`zn-failure zn-failure-tone-${f.tone}`}>
          <span class="zn-failure-bar" aria-hidden="true"></span>
          <span class="zn-failure-num">{f.num}</span>
          <div>
            <strong class="zn-failure-title">{f.title}</strong>
            <p class="zn-failure-line">{f.line}</p>
          </div>
        </li>
      ))}
    </ol>

    <div class="zn-dark-foot">
      <a href="/showcase" class="zn-btn zn-btn-light">See each failure mode in action &rarr;</a>
    </div>
  </div>
</section>

<!-- ────────────────────  WHY NOT LOGS  ──────────────────── -->
<WhyNotLogs />

<!-- ────────────────────  PULL QUOTE 1 ──────────────────── -->
<section class="zn-pq">
  <div class="zn-shell zn-pq-shell">
    <span class="zn-pq-mark">“</span>
    <p class="zn-pq-text">
      Production isn’t a milestone. It’s the moment your code has to defend itself.
    </p>
    <span class="zn-pq-attr">— a thing every serious engineer has learned the hard way</span>
  </div>
</section>

<!-- ────────────────────  CODE MOMENT ──────────────────── -->
<section class="zn-code-section">
  <div class="zn-shell">
    <div class="zn-code-head">
      <span class="zn-eyebrow">Same runtime guarantees, two languages</span>
      <h2 class="zn-h2">Write Python or Java.<br/>JamJet handles replay, policy, and recovery.</h2>
    </div>

    <div class="zn-code-grid">
      <figure class="zn-code-fig">
        <figcaption class="zn-code-cap">
          <span>pipeline.py</span>
          <span class="zn-code-tag">Python</span>
        </figcaption>
        <pre class="zn-code-body" is:raw><span class="t-kw">from</span> <span class="t-w">jamjet</span> <span class="t-kw">import</span> <span class="t-w">task</span><span class="t-p">,</span> <span class="t-w">workflow</span><span class="t-p">,</span> <span class="t-w">approval</span>

<span class="t-p">@</span><span class="t-b">task</span><span class="t-p">(</span><span class="t-w">model</span><span class="t-p">=</span><span class="t-s">"claude-sonnet-4-6"</span><span class="t-p">,</span> <span class="t-w">max_cost</span><span class="t-p">=</span><span class="t-y">0.50</span><span class="t-p">)</span>
<span class="t-kw">async def</span> <span class="t-b">analyze</span><span class="t-p">(</span><span class="t-w">data</span><span class="t-p">:</span> <span class="t-y">dict</span><span class="t-p">) -&gt;</span> <span class="t-y">Report</span><span class="t-p">:</span>
    <span class="t-s">"""checkpointed, cost-capped"""</span>

<span class="t-p">@</span><span class="t-b">workflow</span>
<span class="t-kw">async def</span> <span class="t-b">pipeline</span><span class="t-p">(</span><span class="t-w">raw</span><span class="t-p">):</span>
    <span class="t-w">report</span> <span class="t-p">=</span> <span class="t-kw">await</span> <span class="t-b">analyze</span><span class="t-p">(</span><span class="t-w">raw</span><span class="t-p">)</span>     <span class="t-d"># crash-safe</span>
    <span class="t-kw">await</span> <span class="t-b">approval</span><span class="t-p">(</span><span class="t-w">report</span><span class="t-p">)</span>          <span class="t-d"># durable pause</span>
    <span class="t-kw">return await</span> <span class="t-b">publish</span><span class="t-p">(</span><span class="t-w">report</span><span class="t-p">)</span></pre>
      </figure>

      <figure class="zn-code-fig">
        <figcaption class="zn-code-cap">
          <span>Pipeline.java</span>
          <span class="zn-code-tag">Java</span>
        </figcaption>
        <pre class="zn-code-body" is:raw><span class="t-y">Agent</span> <span class="t-w">analyst</span> <span class="t-p">=</span> <span class="t-y">Agent</span><span class="t-p">.</span><span class="t-b">builder</span><span class="t-p">()</span>
    <span class="t-p">.</span><span class="t-b">name</span><span class="t-p">(</span><span class="t-s">"analyst"</span><span class="t-p">)</span>
    <span class="t-p">.</span><span class="t-b">model</span><span class="t-p">(</span><span class="t-s">"claude-sonnet-4-6"</span><span class="t-p">)</span>
    <span class="t-p">.</span><span class="t-b">strategy</span><span class="t-p">(</span><span class="t-y">Strategy</span><span class="t-p">.</span><span class="t-w">REFLECTION</span><span class="t-p">)</span>
    <span class="t-p">.</span><span class="t-b">maxCost</span><span class="t-p">(</span><span class="t-y">0.50</span><span class="t-p">)</span>                   <span class="t-d">// budget enforced</span>
    <span class="t-p">.</span><span class="t-b">build</span><span class="t-p">();</span>

<span class="t-y">WorkflowGraph</span> <span class="t-w">pipeline</span> <span class="t-p">=</span> <span class="t-y">WorkflowGraph</span><span class="t-p">.</span><span class="t-b">builder</span><span class="t-p">()</span>
    <span class="t-p">.</span><span class="t-b">node</span><span class="t-p">(</span><span class="t-w">analyst</span><span class="t-p">)</span>                    <span class="t-d">// crash-safe</span>
    <span class="t-p">.</span><span class="t-b">node</span><span class="t-p">(</span><span class="t-y">ApprovalGate</span><span class="t-p">.</span><span class="t-b">create</span><span class="t-p">())</span>     <span class="t-d">// durable pause</span>
    <span class="t-p">.</span><span class="t-b">node</span><span class="t-p">(</span><span class="t-w">publisher</span><span class="t-p">)</span>
    <span class="t-p">.</span><span class="t-b">build</span><span class="t-p">();</span></pre>
      </figure>
    </div>

    <p class="zn-marginal zn-marginal-center">
      Both compile to the same IR and run on the same Rust runtime.
      Java has its own native runtime too — zero sidecar, virtual threads,
      <a href="/benchmarks">8.9× faster than the REST sidecar</a> in our benchmark.
    </p>
  </div>
</section>

<!-- ────────────────────  CLOUD + ENGRAM SIDE-BY-SIDE ──────────────────── -->
<section class="zn-pair">
  <div class="zn-shell zn-pair-grid">
    <article class="zn-pair-card zn-pair-cloud">
      <span class="zn-eyebrow">When the team needs the cockpit</span>
      <h3 class="zn-pair-title">JamJet Cloud</h3>
      <p>
        The hosted control plane for agent runs. Trace timeline, policy violations,
        approval queue, cost guardrails, audit export, hosted Engram — across your team.
      </p>
      <div class="zn-pair-actions">
        <a href="/cloud" class="zn-btn zn-btn-primary">View Cloud</a>
        <a href="https://app.jamjet.dev" class="zn-btn zn-btn-ghost">Sign up free</a>
      </div>
    </article>

    <article class="zn-pair-card zn-pair-engram">
      <span class="zn-eyebrow">Need memory first?</span>
      <h3 class="zn-pair-title">Start with Engram.</h3>
      <p>
        Open-source memory for MCP-native AI agents. Fact extraction, conflict detection,
        hybrid retrieval, consolidation. Use it standalone with Claude, Cursor, or any MCP client.
      </p>
      <div class="zn-pair-actions">
        <a href="/engram" class="zn-btn zn-btn-primary">Add memory</a>
        <a href="https://github.com/jamjet-labs/jamjet/tree/main/runtime/engram-server" class="zn-btn zn-btn-ghost" target="_blank" rel="noopener">Source</a>
      </div>
    </article>
  </div>
</section>

<!-- ────────────────────  PULL QUOTE 2 ──────────────────── -->
<section class="zn-pq">
  <div class="zn-shell zn-pq-shell">
    <span class="zn-pq-mark">“</span>
    <p class="zn-pq-text">
      We don’t replace your framework. We sit underneath it, like a seatbelt.
    </p>
    <span class="zn-pq-attr">— the design intent, in one sentence</span>
  </div>
</section>

<!-- ────────────────────  RUNNING LOG ──────────────────── -->
<section class="zn-log">
  <div class="zn-shell">
    <div class="zn-log-head">
      <span class="zn-eyebrow">Running log</span>
      <h2 class="zn-h2 zn-h2-small">What we shipped lately.</h2>
    </div>
    <ol class="zn-log-list">
      {log.map(entry => (
        <li class="zn-log-entry">
          <time class="zn-log-date">{entry.date}</time>
          <a class="zn-log-link" href={entry.href}>
            <p class="zn-log-body">{entry.body}</p>
            <span class="zn-log-arrow">read &rarr;</span>
          </a>
        </li>
      ))}
    </ol>
    <p class="zn-log-foot">
      <a href="/blog">Full blog &rarr;</a>
    </p>
  </div>
</section>

<!-- ────────────────────  COMPARED WITH ──────────────────── -->
<section class="zn-compared">
  <div class="zn-shell">
    <p class="zn-marginal">
      Compared with: <a href="/compare/temporal/">Temporal</a> &middot;
      <a href="/compare/microsoft-agt/">Microsoft AGT</a> &middot;
      <a href="/compare/">all integrations</a>
    </p>
  </div>
</section>

<!-- ────────────────────  COLOPHON / CLOSING ──────────────────── -->
<section class="zn-close">
  <div class="zn-shell zn-close-shell">
    <h2 class="zn-close-tag">
      Make agent runs<br/>
      <span class="zn-close-italic">replayable, auditable,<br/>and controlled.</span>
    </h2>
    <div class="zn-install zn-install-center">
      <span class="zn-prompt">$</span>
      <span class="zn-cmd">pip install jamjet</span>
      <button class="zn-copy" id="copy-final" type="button">copy</button>
    </div>
    <div class="zn-cta-row zn-cta-center">
      <a href="https://docs.jamjet.dev/en/docs/quickstart" class="zn-btn zn-btn-primary">Run the quickstart</a>
      <a href="/cloud" class="zn-btn zn-btn-ghost">View JamJet Cloud</a>
      <a href="https://github.com/jamjet-labs/jamjet" class="zn-btn zn-btn-ghost" target="_blank" rel="noopener">GitHub</a>
    </div>
    <p class="zn-colophon">
      Apache 2.0 · Cloud-neutral · Framework-neutral ·
      Built in Rust, Python, and Java.
    </p>
  </div>
</section>

</BaseLayout>

<style>
  /* ─────────  shared scaffolding  ───────── */
  .zn-shell { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
  .zn-rule {
    margin: 36px 0;
    border-top: 1px solid var(--border);
  }
  .zn-eyebrow {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 600;
