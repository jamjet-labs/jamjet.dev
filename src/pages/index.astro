---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroAnimation from '../components/HeroAnimation.astro';
---

<BaseLayout
  title="JamJet — The Agent-Native Runtime"
  description="Production-grade orchestration for AI agents. Durable execution, native MCP + A2A, full observability. Built in Rust. Authored in Python."
  canonical="https://jamjet.dev/"
>

<!-- ── Research-First Announcement Banner ── -->
<div class="announce-banner">
  <div style="display:flex;align-items:center;justify-content:center;gap:12px;flex-wrap:wrap;max-width:900px;margin:0 auto;">
    <span class="announce-badge">New</span>
    <span class="announce-text">Research-first features shipped — ExperimentGrid, EvalNode, reflection/consensus/debate strategies</span>
    <a href="/research" class="announce-link">Explore the research toolkit &rarr;</a>
  </div>
</div>

<!-- ── Hero ── -->
<section class="hero">
  <div class="hero-inner">
    <h1>The agent-native<br/>runtime</h1>
    <p class="hero-sub">
      Durable execution. Native MCP + A2A. Full observability.<br/>
      Built in Rust. Authored in Python.
    </p>
    <div class="hero-actions">
      <a href="https://docs.jamjet.dev/en/docs/quickstart" class="btn-primary">Get started</a>
      <a href="https://github.com/jamjet-labs/jamjet" class="btn-secondary" target="_blank" rel="noopener">
        View on GitHub
      </a>
    </div>
    <div class="install-cmd">
      <span class="prompt">$</span>
      <span class="cmd">pip install jamjet</span>
      <button class="copy-btn" id="copy-install">copy</button>
    </div>

    <div class="hero-anim-wrapper">
      <HeroAnimation />
    </div>
  </div>
</section>

<!-- ── Why JamJet ── -->
<section style="background: var(--bg-alt);">
  <div class="container">
    <span class="section-label">Why JamJet</span>
    <h2 class="section-title">Production agents have<br/>unsolved problems</h2>
    <div class="problems">
      <div class="problem">
        <span class="problem-label">Reliability</span>
        <p class="problem-text">Agents crash and lose everything</p>
        <p class="problem-solution">Durable graph execution with event sourcing</p>
      </div>
      <div class="problem">
        <span class="problem-label">Interop</span>
        <p class="problem-text">Agents are locked in silos</p>
        <p class="problem-solution">Native MCP + A2A protocols</p>
      </div>
      <div class="problem">
        <span class="problem-label">Observability</span>
        <p class="problem-text">You can't see what's happening</p>
        <p class="problem-solution">OTel GenAI traces + checkpoint replay</p>
      </div>
      <div class="problem">
        <span class="problem-label">Safety</span>
        <p class="problem-text">Autonomous agents run forever</p>
        <p class="problem-solution">Compile-time autonomy constraints</p>
      </div>
      <div class="problem">
        <span class="problem-label">Process</span>
        <p class="problem-text">Human approval is bolted on</p>
        <p class="problem-solution">Human-in-the-loop as a native node type</p>
      </div>
      <div class="problem">
        <span class="problem-label">Performance</span>
        <p class="problem-text">Python orchestration doesn't scale</p>
        <p class="problem-solution">Rust async scheduler, microsecond overhead</p>
      </div>
    </div>
  </div>
</section>

<!-- ── Code Example ── -->
<section>
  <div class="container">
    <div class="code-section">
      <div class="code-text">
        <span class="section-label">Authoring</span>
        <h2>Python you<br/>already know</h2>
        <p style="color: var(--text-secondary); margin-top: 16px;">
          Decorate functions with <code style="background:var(--surface-code);padding:2px 6px;border-radius:3px;font-size:0.9em">@task</code> and <code style="background:var(--surface-code);padding:2px 6px;border-radius:3px;font-size:0.9em">@tool</code>. The runtime handles durability, cost limits, and telemetry.
        </p>
      </div>
      <div class="code-block">
        <div class="code-header">
          <span>agent.py</span>
        </div>
        <pre class="code-body" is:raw><span class="t-kw">from</span> <span class="t-w">jamjet</span> <span class="t-kw">import</span> <span class="t-w">task</span><span class="t-p">,</span> <span class="t-w">tool</span>

<span class="t-p">@</span><span class="t-b">tool</span>
<span class="t-kw">async def</span> <span class="t-b">web_search</span><span class="t-p">(</span><span class="t-w">query</span><span class="t-p">:</span> <span class="t-y">str</span><span class="t-p">) -&gt;</span> <span class="t-y">str</span><span class="t-p">:</span>
    <span class="t-s">"""Search the web for current information."""</span>
    <span class="t-p">...</span>

<span class="t-p">@</span><span class="t-b">task</span><span class="t-p">(</span><span class="t-w">model</span><span class="t-p">=</span><span class="t-s">"claude-sonnet-4-6"</span><span class="t-p">,</span> <span class="t-w">tools</span><span class="t-p">=[</span><span class="t-w">web_search</span><span class="t-p">])</span>
<span class="t-kw">async def</span> <span class="t-b">research</span><span class="t-p">(</span><span class="t-w">question</span><span class="t-p">:</span> <span class="t-y">str</span><span class="t-p">) -&gt;</span> <span class="t-y">str</span><span class="t-p">:</span>
    <span class="t-s">"""Search first, then summarize clearly."""</span>

<span class="t-w">result</span> <span class="t-p">=</span> <span class="t-kw">await</span> <span class="t-b">research</span><span class="t-p">(</span><span class="t-s">"Latest AI agent trends?"</span><span class="t-p">)</span>
<span class="t-b">print</span><span class="t-p">(</span><span class="t-w">result</span><span class="t-p">)</span></pre>
      </div>
    </div>
  </div>
</section>

<!-- ── Features ── -->
<section style="background: var(--bg-alt);">
  <div class="container">
    <span class="section-label">Capabilities</span>
    <h2 class="section-title">Everything production demands</h2>
    <div class="features">
      <div class="feature">
        <h3>Durable Graph Execution</h3>
        <p>Every step checkpointed with event sourcing. Crash the process, restart it — execution resumes exactly where it stopped.</p>
      </div>
      <div class="feature">
        <h3>Native MCP + A2A</h3>
        <p>Connect to any tool server. Expose your tools. Delegate to external agents. Both protocols built in, not bolted on.</p>
      </div>
      <div class="feature">
        <h3>Full Observability</h3>
        <p>OpenTelemetry GenAI traces. Per-node cost attribution. Checkpoint replay. Know exactly what happened and why.</p>
      </div>
      <div class="feature">
        <h3>Human-in-the-Loop</h3>
        <p>Native workflow node for approvals. Durable suspension — the process sleeps until a human responds, even across restarts.</p>
      </div>
      <div class="feature">
        <h3>Autonomy Limits</h3>
        <p>Token budgets, cost caps, iteration limits. Enforced by the runtime, not by convention. Agents can't run away.</p>
      </div>
      <div class="feature">
        <h3>Native Eval Harness</h3>
        <p>LLM-as-judge, assertion, latency, and cost scorers. Run evals as workflow nodes. CI exit codes on regression.</p>
      </div>
      <div class="feature">
        <h3>Typed Schemas</h3>
        <p>Pydantic and JSON Schema validation at every step boundary. No loose dicts. Catch errors before they propagate.</p>
      </div>
      <div class="feature">
        <h3>Rust Core</h3>
        <p>Async scheduler built in Rust. Microsecond dispatch overhead. Python is for authoring, not for orchestration.</p>
      </div>
      <div class="feature">
        <h3>Multi-Model</h3>
        <p>Any OpenAI-compatible API. Anthropic, Ollama, Groq, Azure — swap models per task with a single config change.</p>
      </div>
    </div>
  </div>
</section>

<!-- ── Built for Research ── -->
<section class="research-highlight">
  <div class="container">
    <span class="section-label">Research-First</span>
    <h2 class="section-title">Your next paper,<br/>reproducible by default</h2>
    <div class="research-grid">
      <div class="research-card">
        <span class="research-card-label">ExperimentGrid</span>
        <p>Cartesian product over models, prompts, and temperatures. Parallel execution. Results export to CSV, LaTeX, and JSON with one call.</p>
      </div>
      <div class="research-card">
        <span class="research-card-label">Built-in Strategies</span>
        <p>ReAct, plan-and-execute, critic, reflection, consensus, and debate — compiled to IR sub-DAGs. Compare strategies across the same dataset.</p>
      </div>
      <div class="research-card">
        <span class="research-card-label">Durable Replay</span>
        <p>Every decision checkpointed. Replay any execution. Fork with modified inputs. Perfect for ablation studies and failure analysis.</p>
      </div>
    </div>
    <div style="text-align:center;margin-top:48px;">
      <a href="/research" class="btn-primary">Explore the research toolkit</a>
    </div>
  </div>
</section>

<!-- ── CTA ── -->
<section>
  <div class="container" style="text-align: center; max-width: 560px;">
    <h2>Start building</h2>
    <p style="color: var(--text-secondary); margin: 16px 0 32px;">
      Get a durable workflow running locally in under 10 minutes.
    </p>
    <div style="display: flex; justify-content: center; gap: 12px; flex-wrap: wrap;">
      <a href="https://docs.jamjet.dev/en/docs/quickstart" class="btn-primary">Read the quickstart</a>
      <a href="https://github.com/jamjet-labs/jamjet" class="btn-secondary" target="_blank" rel="noopener">View on GitHub</a>
    </div>
  </div>
</section>

</BaseLayout>

<style>
  .hero {
    min-height: calc(100vh - 64px);
    display: flex; align-items: center; justify-content: center;
    padding: 80px 24px;
    text-align: center;
  }
  .hero-inner { max-width: 680px; }
  .hero-sub {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: var(--text-secondary);
    margin: 28px 0 48px;
    line-height: 1.8;
  }
  .hero-actions {
    display: flex; justify-content: center; gap: 12px; flex-wrap: wrap;
    margin-bottom: 32px;
  }
  .hero-anim-wrapper {
    margin-top: 48px;
  }

  /* Why JamJet */
  .section-title {
    margin: 8px 0 48px;
  }
  .problems {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px 48px;
  }
  .problem {
    padding: 24px 0;
    border-top: 1px solid var(--border);
  }
  .problem-label {
    display: block;
    font-size: 0.68rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    margin-bottom: 12px;
    font-family: var(--font-sans);
  }
  .problem-text {
    color: var(--text);
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.4;
    margin-bottom: 8px;
  }
  .problem-solution {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.6;
  }
  .problem-solution::before {
    content: '→ ';
    color: var(--text-muted);
  }

  /* Code section */
  .code-section {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 64px;
    align-items: center;
  }
  .code-text h2 { margin-bottom: 8px; }

  /* Features */
  .features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px 48px;
  }
  .feature {
    padding: 24px 0;
    border-top: 1px solid var(--border);
  }
  .feature h3 {
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 8px;
    color: var(--text);
  }
  .feature p {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.7;
  }

  /* ── Announcement banner ── */
  .announce-banner {
    background: var(--bg-alt);
    border-bottom: 1px solid var(--border);
    padding: 12px 24px;
    text-align: center;
  }
  .announce-badge {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--bg);
    background: var(--text);
    padding: 2px 8px;
    border-radius: 2px;
    font-family: var(--font-sans);
  }
  .announce-text {
    font-size: 0.85rem;
    color: var(--text-secondary);
    font-family: var(--font-sans);
  }
  .announce-link {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text);
    text-decoration: none;
    font-family: var(--font-sans);
  }
  .announce-link:hover {
    text-decoration: underline;
  }

  /* Research highlight */
  .research-highlight {
    background: var(--bg-alt);
  }
  .research-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px 48px;
  }
  .research-card {
    padding: 24px 0;
    border-top: 1px solid var(--border);
  }
  .research-card-label {
    display: block;
    font-size: 0.68rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    margin-bottom: 12px;
    font-family: var(--font-sans);
  }
  .research-card p {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .problems { grid-template-columns: 1fr; gap: 0; }
    .features { grid-template-columns: 1fr; gap: 0; }
    .research-grid { grid-template-columns: 1fr; gap: 0; }
    .code-section { grid-template-columns: 1fr; gap: 32px; }
  }
  @media (min-width: 769px) and (max-width: 1024px) {
    .problems { grid-template-columns: repeat(2, 1fr); }
    .features { grid-template-columns: repeat(2, 1fr); }
    .research-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<script>
  document.getElementById('copy-install')?.addEventListener('click', function() {
    navigator.clipboard.writeText('pip install jamjet').then(() => {
      this.textContent = 'copied!';
      setTimeout(() => { this.textContent = 'copy'; }, 1500);
    });
  });
</script>
