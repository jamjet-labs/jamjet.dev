---
import BaseLayout from '../layouts/BaseLayout.astro';
import Seal from '../components/Seal.astro';
import MarginNote from '../components/MarginNote.astro';

const SIGNUP = 'https://app.jamjet.dev/login';

const cloudLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "JamJet Cloud",
  "description": "The team surface for agent runs. Shared traces, an approval queue your teammates decide, budgets that halt runs, and a sealed, exportable audit trail. Free for solo developers, forever.",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Web",
  "url": "https://jamjet.dev/cloud/",
  "offers": [
    { "@type": "Offer", "name": "Free", "price": "0", "priceCurrency": "USD" },
    { "@type": "Offer", "name": "Starter", "price": "29", "priceCurrency": "USD", "priceSpecification": { "@type": "UnitPriceSpecification", "price": "29", "priceCurrency": "USD", "billingDuration": 1, "billingIncrement": 1, "unitCode": "MON" } },
    { "@type": "Offer", "name": "Team", "price": "99", "priceCurrency": "USD", "priceSpecification": { "@type": "UnitPriceSpecification", "price": "99", "priceCurrency": "USD", "unitCode": "MON" } },
    { "@type": "Offer", "name": "Business", "price": "499", "priceCurrency": "USD", "priceSpecification": { "@type": "UnitPriceSpecification", "price": "499", "priceCurrency": "USD", "unitCode": "MON" } }
  ],
};
---

<BaseLayout
  title="JamJet Cloud — Your agents have a team now."
  description="Everything on jamjet.dev so far has been you alone. Cloud is the day it stops being just you: shared traces, an approval queue your teammates decide, budgets that halt runs, and a sealed audit trail you can export. Connect an agent free, forever."
  canonical="https://jamjet.dev/cloud/"
  ogImage="https://jamjet.dev/og/cloud.png"
  currentPage="cloud"
>
<Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify(cloudLd)}></script>
</Fragment>

<!-- ────────────────────────  HERO ──────────────────────── -->
<section class="cl-hero">
  <div class="cl-shell">
    <div class="cl-hero-grid">
      <div class="cl-hero-copy">
        <span class="cl-kicker">JamJet Cloud</span>
        <h1 class="cl-h1">
          Your agents<br/>
          <span class="cl-h1-italic">have a team now.</span>
        </h1>
        <p class="cl-hero-lede">
          Two lines drop in next to your existing agent. No rewrite, no sidecar.
        </p>

        <figure class="cl-codecard" aria-label="Connect an agent to JamJet Cloud">
          <figcaption class="cl-codecard-cap">
            <span class="cl-codecard-name">agent.py</span>
          </figcaption>
          <pre class="cl-codecard-body" is:raw><span class="cl-tok-kw">import</span> <span class="cl-tok-mod">jamjet.cloud</span> <span class="cl-tok-kw">as</span> <span class="cl-tok-mod">jamjet</span>

<span class="cl-tok-fn">jamjet</span>.<span class="cl-tok-fn">configure</span>(api_key=<span class="cl-tok-str">"jj_xxxx"</span>, project=<span class="cl-tok-str">"my-agent"</span>)
<span class="cl-tok-cm"># every OpenAI / Anthropic call is now on the tape</span></pre>
        </figure>

        <p class="cl-hero-sub">
          The call shows up in the dashboard in seconds.
          <strong>Free for you, forever.</strong>
        </p>

        <div class="cl-cta-row">
          <a href={SIGNUP} class="cl-btn cl-btn-primary">Connect an agent free</a>
          <a href="#pricing" class="cl-btn cl-btn-ghost">See pricing</a>
        </div>
      </div>

      <div class="cl-hero-panel">
        <MarginNote rotate={-3}>this is the real dashboard</MarginNote>
        <figure class="cl-panel">
          <figcaption class="cl-panel-plate">
            <span class="cl-panel-dot" aria-hidden="true"></span>
            app.jamjet.dev · home
          </figcaption>
          <img
            src="/cloud/dashboard-home.png"
            alt="JamJet Cloud dashboard home: a production-readiness ring at 90, an attention queue of held approval requests, and a row of recent allow and hold decisions."
            width="1440"
            height="900"
            loading="eager"
            decoding="async"
          />
        </figure>
      </div>
    </div>
  </div>
</section>

<!-- ────────────────────  GATE BRIDGE STRIP ──────────────────── -->
<section class="cl-bridge">
  <div class="cl-shell">
    <p class="cl-bridge-line">
      You approved a held merge on the <a href="/gate/">Gate</a> yourself.
      This is where your team does it.
    </p>
  </div>
</section>

<!-- ────────────────────  ACT I — OBSERVE ──────────────────── -->
<section class="cl-act" id="observe">
  <div class="cl-shell">
    <div class="cl-act-head">
      <span class="cl-eyebrow">Act I · Observe</span>
      <h2 class="cl-h2">The team sees.</h2>
      <p class="cl-act-lede">
        Traces, signals, and costs from every run land in one place your whole team can open.
        Token usage by the minute, the model and tool calls behind each trace, and the spend trend
        rolling up across agents and environments.
      </p>
    </div>

    <figure class="cl-panel cl-panel-wide">
      <figcaption class="cl-panel-plate">
        <span class="cl-panel-dot" aria-hidden="true"></span>
        app.jamjet.dev · signals
      </figcaption>
      <img
        src="/cloud/signals.png"
        alt="JamJet Cloud signals view: a live token-usage area chart with input and output bands, totals for input, output, and cache tokens, and a live events feed below."
        width="1440"
        height="900"
        loading="lazy"
        decoding="async"
      />
    </figure>

    <div class="cl-vignette">
      <p class="cl-vignette-text">
        The morning the token bill jumps, this chart is how you find out, and the budget cap is how
        it never ships an invoice.
      </p>
    </div>

    <p class="cl-act-seed">Seeing your own runs is free, forever.</p>
  </div>
</section>

<!-- ────────────────────  ACT II — ENFORCE ──────────────────── -->
<section class="cl-act cl-act-alt" id="enforce">
  <div class="cl-shell">
    <div class="cl-act-head">
      <span class="cl-eyebrow">Act II · Enforce</span>
      <h2 class="cl-h2">The team decides.</h2>
      <p class="cl-act-lede">
        Held actions land in a queue your teammates work, each with an SLA timer counting down.
        Approve or reject in one click, with a reason that lands in the audit log.
        Budgets sit alongside, ready to halt a run before it spends past the cap.
      </p>
    </div>

    <div class="cl-panel-wrap">
      <MarginNote rotate={-3}>you, plural</MarginNote>
      <figure class="cl-panel cl-panel-wide">
        <figcaption class="cl-panel-plate">
          <span class="cl-panel-dot" aria-hidden="true"></span>
          app.jamjet.dev · approvals
        </figcaption>
        <img
          src="/cloud/approvals-queue.png"
          alt="JamJet Cloud approvals queue: three held actions, a bulk email, a payment refund, and a github merge, each with an SLA-in-59-minutes chip, the requesting agent and reason, and Approve and Reject buttons."
          width="1440"
          height="900"
          loading="lazy"
          decoding="async"
        />
      </figure>
    </div>

    <div class="cl-vignette">
      <p class="cl-vignette-text">
        A queue is only a queue when it is shared. The held merge you approved on the Gate becomes a
        line your reviewers see, with a timer and a name attached.
      </p>
    </div>

    <p class="cl-act-seed">A shared queue is where the team turn starts. That is the Team plan.</p>
  </div>
</section>

<!-- ────────────────────  ACT III — PROVE ──────────────────── -->
<section class="cl-act" id="prove">
  <div class="cl-shell">
    <div class="cl-act-head">
      <span class="cl-eyebrow">Act III · Prove</span>
      <h2 class="cl-h2">The team proves.</h2>
      <p class="cl-act-lede">
        Every decision is retained and sealed into a receipt. Export a window as a signed PDF,
        check production readiness, and hand compliance evidence instead of a story.
      </p>
    </div>

    <div class="cl-receipt-wrap">
      <aside class="cl-receipt" aria-label="sealed audit receipt">
        <div class="cl-receipt-cap">
          <span class="cl-receipt-name">receipt</span>
          <span class="cl-receipt-sep">·</span>
          <span>audit.export</span>
          <span class="cl-receipt-pill">SEALED</span>
        </div>
        <pre class="cl-receipt-body"><code><span class="cl-rk">receipt_id</span><span class="cl-rp">:</span> <span class="cl-rs">0192c8d0-1f2a-4e7b-93a1</span>
<span class="cl-rk">tool</span><span class="cl-rp">:</span> <span class="cl-rs">github.merge</span>
<span class="cl-rk">policy.decision</span><span class="cl-rp">:</span> <span class="cl-rs">require-approval</span>
<span class="cl-rk">decided_by</span><span class="cl-rp">:</span> <span class="cl-rs">human:sunil</span>
<span class="cl-rk">reason</span><span class="cl-rp">:</span> <span class="cl-rs">release notes reviewed, ship it</span>
<span class="cl-rk">decided_at</span><span class="cl-rp">:</span> <span class="cl-rs">2026-03-14T14:02:09Z</span>
<span class="cl-rk">arguments_hash</span><span class="cl-rp">:</span> <span class="cl-rh">7c1f9a3e2b8d4056…</span>
<span class="cl-rk">receipt_hash</span><span class="cl-rp">:</span> <span class="cl-rh cl-rh-final">4d905d6e0a17bc92…verified</span></code></pre>
        <div class="cl-receipt-foot">
          Tamper-evident per <a href="https://agentboundary.jamjet.dev/">the AgentBoundary receipt schema</a>.
          Change any byte and the hash breaks.
        </div>
        <Seal verdict="approved" size="md" />
      </aside>
    </div>

    <div class="cl-vignette">
      <p class="cl-vignette-text">
        Compliance asks for March. You export a sealed PDF, not a Slack archaeology dig.
      </p>
    </div>

    <p class="cl-act-seed">Retention and export are what an audit actually asks for. That is Business.</p>
  </div>
</section>

<!-- ────────────────────  PROMISE TABLE ──────────────────── -->
<section class="cl-promise">
  <div class="cl-shell">
    <span class="cl-eyebrow">The split</span>
    <h2 class="cl-h2">Everything local stays free.</h2>
    <p class="cl-promise-intro">
      The runtime, the policy engine, Engram, and the Gate are Apache 2.0 forever.
      Cloud is the team surface on top. That split is the business model, in the open.
    </p>
    <div class="osvc-table">
      <div class="osvc-row osvc-head">
        <div>Capability</div>
        <div>OSS runtime</div>
        <div>JamJet Cloud</div>
      </div>
      <div class="osvc-row"><div>Local execution &amp; durability</div><div class="yes" data-h="OSS runtime">Yes</div><div class="yes" data-h="JamJet Cloud">Yes</div></div>
      <div class="osvc-row"><div>Policy engine</div><div class="yes" data-h="OSS runtime">Yes</div><div class="yes" data-h="JamJet Cloud">Yes</div></div>
      <div class="osvc-row"><div>Audit log (local)</div><div class="yes" data-h="OSS runtime">Yes</div><div class="yes" data-h="JamJet Cloud">Yes</div></div>
      <div class="osvc-row"><div>Engram memory</div><div class="yes" data-h="OSS runtime">Self-hosted</div><div class="yes" data-h="JamJet Cloud">Hosted</div></div>
      <div class="osvc-row"><div>Trace dashboard</div><div class="partial" data-h="OSS runtime">Local web companion</div><div class="yes" data-h="JamJet Cloud">Team-wide</div></div>
      <div class="osvc-row"><div>Approval queue across reviewers</div><div class="partial" data-h="OSS runtime">API only</div><div class="yes" data-h="JamJet Cloud">Hosted UI + SLA</div></div>
      <div class="osvc-row"><div>Retention &amp; audit export</div><div class="no" data-h="OSS runtime">Manual</div><div class="yes" data-h="JamJet Cloud">Built-in</div></div>
      <div class="osvc-row"><div>SSO / RBAC / projects</div><div class="no" data-h="OSS runtime">&mdash;</div><div class="yes" data-h="JamJet Cloud">Team / Enterprise</div></div>
      <div class="osvc-row"><div>Cross-agent trace propagation</div><div class="partial" data-h="OSS runtime">Manual</div><div class="yes" data-h="JamJet Cloud">W3C traceparent</div></div>
    </div>
  </div>
</section>

<!-- ────────────────────  PRICING ──────────────────── -->
<section class="cl-pricing" id="pricing">
  <div class="cl-shell">
    <span class="cl-eyebrow">Pricing</span>
    <h2 class="cl-h2">You pay for the team surface.</h2>
    <p class="cl-promise-intro">
      Solo is free, forever. The paid tiers are where more than one person is involved:
      higher trace volumes and longer retention.
    </p>

    <div class="cl-plans">
      <div class="cl-plan cl-plan-free">
        <div class="cl-plan-name">Free</div>
        <div class="cl-plan-price">$0<span class="cl-plan-per"> forever</span></div>
        <p class="cl-plan-desc">For you. Connect an agent, watch your runs, solo everything.</p>
        <ul class="cl-plan-list">
          <li>5K traces / month</li>
          <li>Traces, signals, and costs</li>
          <li>Policies and audit log</li>
          <li>7-day retention</li>
          <li>Hosted Engram memory</li>
        </ul>
        <a href={SIGNUP} class="cl-btn cl-btn-primary cl-plan-cta">Connect an agent free</a>
      </div>

      <div class="cl-plan">
        <div class="cl-plan-name">Starter</div>
        <div class="cl-plan-price">$29<span class="cl-plan-per">/mo</span></div>
        <p class="cl-plan-desc">For the first run that outgrows solo.</p>
        <ul class="cl-plan-list">
          <li>50K traces / month</li>
          <li>30-day retention</li>
          <li>Everything in Free</li>
        </ul>
        <a href={SIGNUP} class="cl-btn cl-btn-ghost cl-plan-cta">Start on Starter</a>
      </div>

      <div class="cl-plan cl-plan-featured">
        <div class="cl-plan-flag">the team turn</div>
        <div class="cl-plan-name">Team</div>
        <div class="cl-plan-price">$99<span class="cl-plan-per">/mo</span></div>
        <p class="cl-plan-desc">When the queue stops being just yours.</p>
        <ul class="cl-plan-list">
          <li>250K traces / month</li>
          <li>90-day retention</li>
          <li>PII redaction</li>
          <li>Shared queue and seats, arriving with the bench</li>
          <li>Everything in Starter</li>
        </ul>
        <a href={SIGNUP} class="cl-btn cl-btn-primary cl-plan-cta">Move the team to Team</a>
      </div>

      <div class="cl-plan">
        <div class="cl-plan-flag cl-plan-flag-muted">the audit turn</div>
        <div class="cl-plan-name">Business</div>
        <div class="cl-plan-price">$499<span class="cl-plan-per">/mo</span></div>
        <p class="cl-plan-desc">When someone outside the team asks for proof.</p>
        <ul class="cl-plan-list">
          <li>1M traces / month</li>
          <li>180-day retention</li>
          <li>Audit export</li>
          <li>SSO when available</li>
        </ul>
        <a href={SIGNUP} class="cl-btn cl-btn-ghost cl-plan-cta">Go Business</a>
      </div>
    </div>

    <p class="cl-pricing-foot">
      Regulated team, self-hosted control plane, or a volume that breaks these brackets?
      <a href="mailto:hello@jamjet.dev?subject=JamJet%20Cloud%20Enterprise">Talk to us</a>.
    </p>
  </div>
</section>

<!-- ────────────────────  CTA CLOSE ──────────────────── -->
<section class="cl-close">
  <div class="cl-shell cl-close-shell">
    <h2 class="cl-close-tag">
      Send your first trace.<br/>
      <span class="cl-close-italic">Bring the team to it later.</span>
    </h2>
    <p class="cl-close-sub">
      Two lines next to your agent and the dashboard fills in. Free for you, forever.
      The paid line shows up the day someone else needs to see, decide, or prove.
    </p>
    <div class="cl-cta-row cl-cta-center">
      <a href={SIGNUP} class="cl-btn cl-btn-primary">Connect an agent free</a>
      <a href="https://docs.jamjet.dev/en/docs/cloud-quickstart" class="cl-btn cl-btn-ghost">Read the quickstart</a>
    </div>
  </div>
</section>

<style>
  /* ── shared scaffolding ── */
  .cl-shell { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
  .cl-eyebrow {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--text-muted);
    margin-bottom: 16px;
  }
  .cl-kicker {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--text-muted);
    margin-bottom: 18px;
  }
  .cl-h2 {
    font-size: clamp(1.7rem, 3.6vw, 2.4rem);
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin: 4px 0 16px;
    font-weight: 600;
  }

  /* ── buttons ── */
  .cl-btn {
    font-family: var(--font-sans);
    font-size: 0.92rem;
    font-weight: 500;
    padding: 10px 18px;
    border-radius: 6px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    transition: transform 0.12s, background 0.12s, border-color 0.12s;
  }
  .cl-btn-primary {
    background: var(--text);
    color: var(--bg);
    border: 1px solid var(--text);
  }
  .cl-btn-primary:hover { transform: translateY(-1px); }
  .cl-btn-ghost {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border);
  }
  .cl-btn-ghost:hover { border-color: var(--text); }
  .cl-cta-row { display: inline-flex; gap: 12px; flex-wrap: wrap; }
  .cl-cta-center { justify-content: center; }

  /* ── instrument panel (frames every real capture) ── */
  .cl-panel {
    margin: 0;
    border: 1px solid var(--border-strong);
    border-radius: 10px;
    overflow: hidden;
    background: var(--surface);
    box-shadow: 0 10px 28px -16px rgba(20, 20, 19, 0.35);
  }
  .cl-panel-plate {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--text-muted);
    background: var(--bg-alt);
    border-bottom: 1px solid var(--border);
  }
  .cl-panel-dot {
    width: 8px; height: 8px; border-radius: 999px;
    background: var(--success);
    flex-shrink: 0;
  }
  .cl-panel img {
    display: block;
    width: 100%;
    height: auto;
    border: 0;
  }
  .cl-panel-wide { margin-top: 8px; }
  .cl-panel-wrap { position: relative; }
  .cl-panel-wrap > :global(.margin-note) {
    position: absolute;
    right: 6px;
    top: -26px;
    z-index: 2;
  }

  /* ── HERO ── */
  .cl-hero {
    padding: 72px 0 64px;
    border-bottom: 1px solid var(--border);
  }
  .cl-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
    gap: 56px;
    align-items: center;
  }
  .cl-hero-copy { min-width: 0; }
  .cl-h1 {
    font-size: clamp(2.6rem, 6vw, 4.4rem);
    line-height: 1.02;
    letter-spacing: -0.025em;
    font-weight: 600;
    margin: 0 0 20px;
  }
  .cl-h1-italic { font-style: italic; font-weight: 500; }
  .cl-hero-lede {
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0 0 20px;
    max-width: 46ch;
  }
  .cl-hero-sub {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 16px 0 26px;
    max-width: 46ch;
  }
  .cl-hero-sub strong { color: var(--text); font-weight: 600; }
  .cl-hero-panel { position: relative; min-width: 0; }
  .cl-hero-panel > :global(.margin-note) {
    position: absolute;
    left: 8px;
    top: -28px;
    z-index: 2;
  }

  /* hero code card */
  .cl-codecard {
    margin: 0 0 4px;
    border: 1px solid var(--border-strong);
    background: var(--bg);
    border-radius: 8px;
    overflow: hidden;
    max-width: 100%;
  }
  .cl-codecard-cap {
    padding: 7px 14px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-muted);
    background: var(--bg-alt);
    border-bottom: 1px solid var(--border);
  }
  .cl-codecard-name { color: var(--text); font-weight: 600; }
  .cl-codecard-body {
    margin: 0;
    padding: 14px 16px;
    font-family: var(--font-mono);
    font-size: 12.5px;
    line-height: 1.7;
    color: var(--text);
    overflow-x: auto;
    white-space: pre;
  }
  .cl-tok-kw  { color: var(--text); font-weight: 700; }
  .cl-tok-mod { color: var(--text); }
  .cl-tok-fn  { color: var(--text); font-weight: 600; }
  .cl-tok-str { color: var(--text-secondary); }
  .cl-tok-cm  { color: var(--text-muted); font-style: italic; }

  /* ── GATE BRIDGE ── */
  .cl-bridge {
    padding: 26px 0;
    background: var(--bg-alt);
    border-bottom: 1px solid var(--border);
  }
  .cl-bridge-line {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 1.08rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0;
    max-width: 70ch;
  }
  .cl-bridge-line a {
    color: var(--text);
    font-style: normal;
    border-bottom: 1px solid var(--border-strong);
    text-decoration: none;
  }
  .cl-bridge-line a:hover { border-bottom-color: var(--text); }

  /* ── ACTS ── */
  .cl-act {
    padding: var(--space-section-sm) 0;
    border-bottom: 1px solid var(--border);
  }
  .cl-act-alt { background: var(--bg-alt); }
  .cl-act-head { max-width: 720px; margin-bottom: 28px; }
  .cl-act-lede {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text-secondary);
    margin: 0;
    max-width: 64ch;
  }
  .cl-act-seed {
    margin: 24px 0 0;
    font-family: var(--font-body);
    font-style: italic;
    font-size: 1.05rem;
    color: var(--text);
  }

  /* vignette callout */
  .cl-vignette {
    margin-top: 28px;
    padding: 18px 22px;
    background: var(--surface);
    border-left: 3px solid var(--warning);
    border-radius: 2px;
    max-width: 72ch;
  }
  .cl-vignette-text {
    margin: 0;
    font-size: 1.02rem;
    line-height: 1.7;
    color: var(--text);
  }

  /* ── PROVE receipt artifact ── */
  .cl-receipt-wrap {
