---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroAnimation from '../components/HeroAnimation.astro';
import TerminalReplay from '../components/TerminalReplay.astro';
import UseCaseCard from '../components/UseCaseCard.astro';
import SocialProofBar from '../components/SocialProofBar.astro';

const terminalLines = [
  '$ jamjet run research-pipeline.yaml',
  '▸ Starting execution exec_7f3a...',
  '▸ [Plan]       ✓ completed  420ms',
  '▸ [Research]   ✓ completed  1.2s',
  '▸ [Analyze]    ✗ worker crashed',
  '▸ Lease expired · reclaiming...',
  '▸ [Analyze]    ✓ resumed    890ms',
  '▸ [Review]     ✓ completed  650ms',
  '▸ [Synthesize] ✓ completed  1.1s',
  '▸ Execution complete · 5/5 nodes · 0 events lost',
];

const card0Code = `<span class="t-p">@</span><span class="t-b">task</span><span class="t-p">(</span><span class="t-w">model</span><span class="t-p">=</span><span class="t-s">"claude-sonnet-4-6"</span><span class="t-p">,</span> <span class="t-w">tools</span><span class="t-p">=[</span><span class="t-w">market_data</span><span class="t-p">,</span> <span class="t-w">sec_filings</span><span class="t-p">])</span>
<span class="t-kw">async def</span> <span class="t-b">analyze_company</span><span class="t-p">(</span><span class="t-w">ticker</span><span class="t-p">:</span> <span class="t-y">str</span><span class="t-p">) -&gt;</span> <span class="t-y">Report</span><span class="t-p">:</span>
    <span class="t-s">"""Deep financial analysis with risk assessment."""</span>`;

const card1Code = `<span class="t-p">@</span><span class="t-b">task</span><span class="t-p">(</span><span class="t-w">tools</span><span class="t-p">=[</span><span class="t-w">search</span><span class="t-p">,</span> <span class="t-w">retrieve</span><span class="t-p">,</span> <span class="t-w">summarize</span><span class="t-p">])</span>
<span class="t-kw">async def</span> <span class="t-b">answer</span><span class="t-p">(</span><span class="t-w">question</span><span class="t-p">:</span> <span class="t-y">str</span><span class="t-p">) -&gt;</span> <span class="t-y">str</span><span class="t-p">:</span>
    <span class="t-s">"""Search knowledge base, retrieve docs, synthesize answer."""</span>`;

const card2Code = `<span class="t-p">@</span><span class="t-b">workflow.step</span><span class="t-p">(</span><span class="t-w">type</span><span class="t-p">=</span><span class="t-s">"human_approval"</span><span class="t-p">)</span>
<span class="t-kw">async def</span> <span class="t-b">approve</span><span class="t-p">(</span><span class="t-w">state</span><span class="t-p">):</span>
    <span class="t-kw">return await</span> <span class="t-w">state</span><span class="t-p">.</span><span class="t-b">wait_for_approval</span><span class="t-p">()</span>`;

const card3Code = `<span class="t-p">@</span><span class="t-b">task</span><span class="t-p">(</span><span class="t-w">tools</span><span class="t-p">=[</span><span class="t-w">web_search</span><span class="t-p">,</span> <span class="t-w">calculator</span><span class="t-p">],</span> <span class="t-w">strategy</span><span class="t-p">=</span><span class="t-s">"react"</span><span class="t-p">)</span>
<span class="t-kw">async def</span> <span class="t-b">research</span><span class="t-p">(</span><span class="t-w">q</span><span class="t-p">:</span> <span class="t-y">str</span><span class="t-p">) -&gt;</span> <span class="t-y">str</span><span class="t-p">:</span>
    <span class="t-s">"""Research with MCP tools, crash-safe."""</span>`;

const card4Code = `<span class="t-w">card</span> <span class="t-p">=</span> <span class="t-kw">await</span> <span class="t-b">discover</span><span class="t-p">(</span><span class="t-s">"/.well-known/agent.json"</span><span class="t-p">)</span>
<span class="t-w">result</span> <span class="t-p">=</span> <span class="t-kw">await</span> <span class="t-b">delegate</span><span class="t-p">(</span><span class="t-w">card</span><span class="t-p">,</span> <span class="t-w">task</span><span class="t-p">=</span><span class="t-s">"analyze report"</span><span class="t-p">)</span>`;

const proofCode = `<span class="t-kw">from</span> <span class="t-w">jamjet</span> <span class="t-kw">import</span> <span class="t-b">task</span><span class="t-p">,</span> <span class="t-b">workflow</span>

<span class="t-p">@</span><span class="t-b">task</span>
<span class="t-kw">async def</span> <span class="t-b">analyze</span><span class="t-p">(</span><span class="t-w">data</span><span class="t-p">:</span> <span class="t-y">dict</span><span class="t-p">)</span> <span class="t-p">-></span> <span class="t-y">dict</span><span class="t-p">:</span>
    <span class="t-d"># your logic here — crash-safe by default</span>
    <span class="t-kw">return</span> <span class="t-p">{</span><span class="t-s">"summary"</span><span class="t-p">:</span> <span class="t-b">llm</span><span class="t-p">.</span><span class="t-b">call</span><span class="t-p">(</span><span class="t-w">data</span><span class="t-p">)}</span>

<span class="t-p">@</span><span class="t-b">workflow</span>
<span class="t-kw">async def</span> <span class="t-b">pipeline</span><span class="t-p">():</span>
    <span class="t-w">raw</span>  <span class="t-p">=</span> <span class="t-kw">await</span> <span class="t-b">fetch_data</span><span class="t-p">()</span>
    <span class="t-w">out</span>  <span class="t-p">=</span> <span class="t-kw">await</span> <span class="t-b">analyze</span><span class="t-p">(</span><span class="t-w">raw</span><span class="t-p">)</span>
    <span class="t-kw">return</span> <span class="t-w">out</span>`;
---

<BaseLayout
  title="Showcase — JamJet Durable Agent Runtime"
  description="See JamJet in action: crash-safe agent workflows, multi-agent deliberation, human approval loops, A2A delegation, and more — in 12 lines of Python."
  canonical="https://jamjet.dev/showcase"
  currentPage="showcase"
>

<script type="application/ld+json" slot="head">{JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "JamJet",
  "description": "The durable runtime for AI agents. Checkpoint replay, crash recovery, and full execution traces.",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Linux, macOS, Windows",
  "url": "https://jamjet.dev",
  "downloadUrl": "https://pypi.org/project/jamjet/",
  "softwareVersion": "0.2.0",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
})}</script>

<!-- ── Zone 1: Hero ── -->
<section class="showcase-hero">
  <HeroAnimation />
  <div class="hero-text">
    <h1>Your agents crash.<br/>Ours recover.</h1>
    <p class="hero-sub">
      JamJet checkpoints every step as it happens. When a worker dies mid-run,
      the scheduler reclaims the lease and resumes from exactly where it stopped —
      no lost work, no duplicate actions, no reruns.
    </p>
    <div class="hero-actions">
      <div class="install-cmd">
        <span class="prompt">$</span>
        <span class="cmd">pip install jamjet</span>
        <button class="copy-btn" onclick="navigator.clipboard.writeText('pip install jamjet')">copy</button>
      </div>
      <a href="https://docs.jamjet.dev/en/docs/quickstart" class="btn-secondary">Read the docs</a>
    </div>
  </div>
</section>

<!-- ── Zone 2: Code Proof ── -->
<section>
  <div class="container">
    <span class="section-label">Live execution</span>
    <h2>See it run</h2>
    <div class="code-proof">
      <div>
        <TerminalReplay lines={terminalLines} title="jamjet · research-pipeline.yaml" />
        <a
          href="https://github.com/jamjet-labs/jamjet/tree/main/examples/research-deliberation"
          target="_blank"
          rel="noopener"
          class="code-github"
        >View full example on GitHub →</a>
      </div>
      <div>
        <div class="code-block">
          <div class="code-header">
            <span>pipeline.py</span>
            <span>Python · 12 lines</span>
          </div>
          <pre class="code-body" set:html={proofCode} />
        </div>
      </div>
    </div>
    <p class="code-proof-tagline">12 lines of Python. Crash-safe by default.</p>
  </div>
</section>

<!-- ── Why Teams Care ── -->
<section style="background: var(--bg-alt);">
  <div class="container">
    <span class="section-label">Impact</span>
    <h2>Why teams care</h2>
    <div class="teams-care-grid">
      <div class="teams-care-item">
        <strong>Lower rerun cost</strong>
        <p>Completed steps stay completed. No wasted tokens after failure.</p>
      </div>
      <div class="teams-care-item">
        <strong>Safer side effects</strong>
        <p>Downstream actions are less likely to be repeated after failure.</p>
      </div>
      <div class="teams-care-item">
        <strong>Faster debugging</strong>
        <p>Replay the exact execution instead of reconstructing it from logs.</p>
      </div>
      <div class="teams-care-item">
        <strong>More reliable operations</strong>
        <p>Long-running workflows survive crashes, restarts, and lease handoffs.</p>
      </div>
    </div>
  </div>
</section>

<!-- ── Zone 3: Use Case Cards ── -->
<section>
  <div class="container">
    <span class="section-label">Examples</span>
    <h2>How teams use JamJet in production</h2>
    <p class="usecase-intro">Click any card to expand the code.</p>
    <div class="usecase-grid">
      <UseCaseCard
        index={0}
        title="Investment Due Diligence"
        description="A durable multi-agent workflow for report generation, risk review, and compliance checks."
        tags={["multi-agent", "a2a", "durable"]}
        code={card0Code}
        codeFile="due-diligence.py"
        githubUrl="https://github.com/jamjet-labs/jamjet/tree/main/examples/wealth-management-agents"
      />
      <UseCaseCard
        index={1}
        title="RAG Assistant"
        description="A retrieval-and-synthesis workflow where every step is checkpointed, traceable, and replayable."
        tags={["rag", "tools", "durable"]}
        code={card1Code}
        codeFile="rag-agent.py"
        githubUrl="https://github.com/jamjet-labs/jamjet/tree/main/examples/rag-assistant"
      />
      <UseCaseCard
        index={2}
        title="Human Approval Workflow"
        description="Pause durably for a human decision, then resume without losing state or re-running prior work."
        tags={["hitl", "durable", "production"]}
        code={card2Code}
        codeFile="approval.py"
        githubUrl="https://github.com/jamjet-labs/jamjet/tree/main/examples/hitl-approval"
      />
      <UseCaseCard
        index={3}
        title="MCP Tool Integration"
        description="Use external tools through MCP while keeping each tool call inside the durable runtime."
        tags={["mcp", "tools", "interop"]}
        code={card3Code}
        codeFile="mcp-agent.py"
        githubUrl="https://github.com/jamjet-labs/jamjet/tree/main/examples/mcp-tool-consumer"
      />
      <UseCaseCard
        index={4}
        title="Agent-to-Agent Delegation"
        description="Delegate to specialized agents via A2A with identity-aware, cost-aware, replayable execution."
        tags={["a2a", "routing", "production"]}
        code={card4Code}
        codeFile="delegation.py"
        githubUrl="https://github.com/jamjet-labs/jamjet/tree/main/examples/a2a-delegation"
      />
    </div>
  </div>
</section>

<!-- ── Zone 4: Social Proof ── -->
<SocialProofBar />

</BaseLayout>

<style>
  /* ── Zone 1: Hero ── */
  .showcase-hero {
    min-height: calc(100vh - 64px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 80px 24px 64px;
  }

  .hero-text {
    max-width: 640px;
    margin-top: 48px;
    text-align: center;
  }

  .hero-text h1 {
    margin-bottom: 20px;
  }

  .hero-sub {
    font-size: clamp(0.95rem, 2vw, 1.1rem);
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 36px;
  }

  .hero-actions {
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  /* ── Zone 2: Code Proof ── */
  .code-proof {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    margin-top: 32px;
  }

  .code-github {
    display: block;
    margin-top: 12px;
    color: var(--text-muted);
    font-size: 0.82rem;
    text-decoration: none;
    font-family: var(--font-sans);
    transition: color 0.15s;
  }

  .code-github:hover {
    color: var(--text-secondary);
  }

  .code-proof-tagline {
    text-align: center;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-top: 40px;
    letter-spacing: 0.01em;
  }

  /* ── Zone 3: Use Case Cards ── */
  .usecase-intro {
    color: var(--text-muted);
    font-size: 0.85rem;
    margin-top: 8px;
    margin-bottom: 32px;
    font-family: var(--font-sans);
  }

  .usecase-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px 40px;
  }

  /* ── Why Teams Care ── */
  .teams-care-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px 48px;
    margin-top: 24px;
  }
  .teams-care-item {
    padding: 20px 0;
    border-top: 1px solid var(--border);
  }
  .teams-care-item strong {
    display: block;
    font-size: 0.92rem;
    margin-bottom: 6px;
    color: var(--text);
  }
  .teams-care-item p {
    color: var(--text-secondary);
    font-size: 0.85rem;
    line-height: 1.6;
    margin: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .showcase-hero {
      padding: 48px 24px 40px;
      justify-content: flex-start;
      min-height: auto;
    }

    .hero-text {
      margin-top: 32px;
    }

    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .hero-actions .install-cmd {
      justify-content: center;
    }

    .hero-actions .btn-secondary {
      justify-content: center;
    }

    .code-proof {
      grid-template-columns: 1fr;
    }

    .teams-care-grid { grid-template-columns: 1fr; }

    .usecase-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    .usecase-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
