<script>
  const fmTabs = document.querySelectorAll<HTMLButtonElement>('.fm-tab');
  const fmPanels = document.querySelectorAll<HTMLElement>('.fm-panel');
  fmTabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = tab.getAttribute('data-fm');
      fmTabs.forEach((t) => t.classList.toggle('active', t === tab));
      fmPanels.forEach((p) => {
        const match = p.getAttribute('data-fm') === target;
        p.classList.toggle('active', match);
        if (match) {
          p.removeAttribute('hidden');
        } else {
          p.setAttribute('hidden', '');
        }
      });
    });
  });
</script>
