---
import '../styles/index-page.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#f5c518" />
  <title>Use Cases — JamJet</title>
  <meta name="description" content="Real production use cases for JamJet: investment due diligence, customer support, code review pipelines, research automation, and more." />
  <meta property="og:title" content="Use Cases — JamJet" />
  <meta property="og:description" content="Real production use cases built on JamJet: multi-agent A2A pipelines, durable workflows, RAG + LLM synthesis, human-in-the-loop approval flows." />
  <meta property="og:image" content="https://jamjet.dev/og.svg" />
  <meta property="og:url" content="https://jamjet.dev/usecases" />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@jamjetdev" />
  <link rel="canonical" href="https://jamjet.dev/usecases" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    .uc-hero { padding: 80px 24px 60px; text-align: center; }
    .uc-tag-row { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 24px; justify-content: center; }
    .uc-tag { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em;
              padding: 4px 10px; border-radius: 4px; border: 1px solid var(--border); color: var(--text-muted); }
    .uc-tag.yellow { background: var(--yellow-dim); border-color: var(--yellow); color: var(--yellow); }

    /* Featured case study */
    .case-hero { background: var(--bg-2); border: 1px solid var(--border); border-radius: 12px;
                 padding: 56px; max-width: 1060px; margin: 0 auto 64px; }
    .case-eyebrow { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em;
                    color: var(--yellow); margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
    .case-eyebrow::after { content: ''; flex: 1; height: 1px; background: var(--border); }
    .case-title { font-size: clamp(1.6rem, 3vw, 2.4rem); font-weight: 800; letter-spacing: -0.03em; margin-bottom: 12px; }
    .case-lead { color: var(--text-muted); font-size: 1.05rem; line-height: 1.7; max-width: 640px; }
    .case-meta { display: flex; gap: 24px; flex-wrap: wrap; margin: 28px 0; }
    .case-meta-item { }
    .case-meta-item .label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-dim); margin-bottom: 4px; }
    .case-meta-item .value { font-size: 0.9rem; color: var(--text); font-weight: 600; }

    /* Architecture diagram */
    .arch-block { background: var(--bg); border: 1px solid var(--border-sub); border-radius: 8px;
                  padding: 28px; font-family: 'JetBrains Mono', monospace; font-size: 0.78rem;
                  line-height: 1.6; color: var(--text-muted); white-space: pre; overflow-x: auto; }

    /* Metrics row */
    .metrics-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 16px; margin: 32px 0; }
    .metric-card { background: var(--bg); border: 1px solid var(--border); border-radius: 8px; padding: 20px; text-align: center; }
    .metric-num { font-size: 2rem; font-weight: 800; color: var(--yellow); letter-spacing: -0.04em; font-family: 'JetBrains Mono', monospace; }
    .metric-label { font-size: 0.75rem; color: var(--text-muted); margin-top: 4px; }

    /* Two-column layout */
    .case-body { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-top: 48px; }
    @media (max-width: 760px) { .case-body { grid-template-columns: 1fr; } }

    .body-block h3 { font-size: 1rem; font-weight: 700; margin-bottom: 12px; }
    .body-block ul { list-style: none; padding: 0; }
    .body-block ul li { font-size: 0.88rem; color: var(--text-muted); padding: 6px 0; border-bottom: 1px solid var(--border-sub); }
    .body-block ul li:last-child { border-bottom: none; }
    .body-block ul li::before { content: '→ '; color: var(--yellow); font-family: 'JetBrains Mono', monospace; }

    /* Code block */
    .code-block { background: var(--bg); border: 1px solid var(--border-sub); border-radius: 8px; overflow: hidden; margin: 24px 0; }
    .code-header { background: var(--bg-3); padding: 10px 16px; font-size: 0.72rem; font-family: 'JetBrains Mono', monospace;
                   color: var(--text-dim); display: flex; justify-content: space-between; border-bottom: 1px solid var(--border-sub); }
    .code-body { padding: 20px; font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; line-height: 1.7;
                 color: var(--text-muted); overflow-x: auto; }
    .c-k { color: #f472b6; }    /* keyword */
    .c-d { color: var(--yellow); } /* decorator */
    .c-s { color: #a3e635; }    /* string */
    .c-c { color: #6b7280; }    /* comment */
    .c-f { color: #60a5fa; }    /* function */
    .c-n { color: var(--text); } /* name */
    .c-p { color: var(--text-muted); } /* punct */

    /* Agent flow diagram (visual) */
    .flow-visual { display: flex; flex-direction: column; align-items: center; gap: 0; margin: 32px 0; }
    .flow-agent { background: var(--bg-2); border: 1px solid var(--border); border-radius: 8px;
                  padding: 14px 20px; min-width: 200px; text-align: center; }
    .flow-agent.orchestrator { border-color: var(--yellow); }
    .flow-agent .agent-name { font-size: 0.78rem; font-weight: 700; }
    .flow-agent .agent-desc { font-size: 0.68rem; color: var(--text-muted); margin-top: 2px; }
    .flow-arrow { color: var(--text-dim); font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; padding: 4px 0; }
    .flow-parallel { display: flex; gap: 24px; align-items: stretch; }
    .flow-parallel-line { display: flex; flex-direction: column; align-items: center; gap: 0; }

    /* Secondary use cases grid */
    .uc-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin-top: 32px; }
    .uc-card { background: var(--bg-2); border: 1px solid var(--border); border-radius: 10px; padding: 28px; }
    .uc-card:hover { border-color: rgba(245,197,24,0.3); }
    .uc-card-icon { font-size: 1.4rem; margin-bottom: 12px; }
    .uc-card h3 { font-size: 0.95rem; font-weight: 700; margin-bottom: 8px; }
    .uc-card .tagline { font-size: 0.82rem; color: var(--yellow); font-weight: 600; margin-bottom: 12px; }
    .uc-card p { font-size: 0.82rem; color: var(--text-muted); line-height: 1.6; }
    .uc-card .features { margin-top: 16px; display: flex; flex-direction: column; gap: 6px; }
    .uc-card .features span { font-size: 0.75rem; color: var(--text-muted); }
    .uc-card .features span::before { content: '✓ '; color: var(--success); }

    .section-title { font-size: clamp(1.5rem, 3vw, 2.2rem); font-weight: 800; letter-spacing: -0.03em; margin-bottom: 12px; }
    .section-sub { color: var(--text-muted); font-size: 0.95rem; line-height: 1.6; max-width: 540px; }
  </style>
</head>
<body class="pixelgrid">

<!-- ── Navigation ── -->
<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="JamJet home">
      <img class="logo-mark" src="/logo-pixel.png" alt="" width="18" height="36" />
      <span>JamJet</span>
    </a>
    <ul class="nav-links">
      <li><a href="/quickstart">Docs</a></li>
      <li><a href="/usecases" style="color:var(--yellow)">Use Cases</a></li>
      <li><a href="/benchmarks">Benchmarks</a></li>
      <li><a href="/examples">Examples</a></li>
      <li><a href="/blog">Blog</a></li>
      <li><a href="https://github.com/jamjet-labs/jamjet" target="_blank" rel="noopener">GitHub ↗</a></li>
    </ul>
