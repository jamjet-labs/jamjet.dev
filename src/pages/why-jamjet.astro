---
import BaseLayout from '../layouts/BaseLayout.astro';
import CopyButton from '../components/CopyButton.astro';

const canonical = 'https://jamjet.dev/why-jamjet/';

const capabilities = [
  {
    label: 'POLICY ENFORCEMENT',
    title: 'Block unsafe tool calls before they execute',
    failure: 'An agent reaches for a tool it shouldn\'t — a destructive shell command, a payment API, an unscoped database write. By the time you read the trace, the damage is done.',
    mechanism: 'JamJet evaluates a 4-level policy hierarchy (global → tenant → workflow → node) at every tool call. Glob-pattern blocking, model allowlists, delegated-token scope narrowing. Unsafe calls are denied at the call site — your trace shows the deny, not the damage.',
  },
  {
    label: 'DURABLE EXECUTION',
    title: 'Resume from crashes, never restart from scratch',
    failure: 'A worker dies mid-run. Without durable execution, the run dies with it — partial side effects, no audit of what happened, no way to continue from where you stopped.',
    mechanism: 'Every step writes a checkpoint before execution. On crash, JamJet replays completed steps from the event log and resumes at the exact failure point. Rust core or embedded Java runtime — 8.9x faster than a REST sidecar in our benchmarks.',
  },
  {
    label: 'HUMAN-IN-THE-LOOP',
    title: 'Approval as a durable workflow primitive',
    failure: 'A high-risk action needs a human decision. Bolt-on approval queues lose state on restart, lose context in the routing UI, and lose evidence in the audit trail.',
    mechanism: 'Approval is a first-class node. The workflow pauses, routes the decision to Slack or email with SLA tracking, survives restarts, and resumes when the human decides. Every decision lands in the signed audit log with the approver\'s identity.',
  },
  {
    label: 'COST GOVERNANCE',
    title: 'Stop runaway loops before the bill arrives',
    failure: 'A reflection loop won\'t stop calling the model. By the time someone notices, you\'ve burned through a month\'s budget on a single run.',
    mechanism: 'Token and dollar caps enforced at runtime, at workflow and per-agent granularity. Exceeding the cap halts the execution or routes it to a configurable fallback node — before the bill happens, not after.',
  },
  {
    label: 'SIGNED AUDIT EVIDENCE',
    title: 'Compliance-ready, not a JSON dump',
    failure: 'Auditors ask what your agent did, when, on whose authority, and how you\'d prove it tomorrow. A trace export is a starting point — it\'s not an evidence package.',
    mechanism: 'Every policy decision, tool call, approval, and outcome is persisted as a durable event. Exports render as Ed25519-signed packages in PDF, OTLP, Splunk, and Datadog formats with per-entry retention. Designed for EU AI Act, financial, and healthcare review.',
  },
  {
    label: 'AGENT MEMORY',
    title: 'Durable facts, not raw chat history',
    failure: 'The agent forgets what it learned in the last session. You either stuff the full chat history into the prompt (slow, expensive, lossy) or your agent has amnesia between runs.',
    mechanism: 'Engram is JamJet\'s memory primitive — a temporal knowledge graph with fact extraction, conflict detection, hybrid retrieval, and consolidation. Open source on PyPI, crates.io, Maven Central, and the MCP Registry. Governed by the same runtime as the rest of the agent.',
  },
];

const differentiators = [
  { title: 'Agent-native primitives', desc: 'Policy, durability, memory, HITL, audit, cost caps ship as runtime features — not user code you maintain.' },
  { title: 'Wrap or native', desc: 'Keep LangChain, LangChain4j, Spring AI, OpenAI Agents SDK. JamJet wraps them — no rewrite required.' },
  { title: 'Protocol-native', desc: 'MCP + A2A clients and servers built into the runtime. Listed on the MCP Registry.' },
  { title: 'Cloud-neutral', desc: 'Apache 2.0. Self-host on Docker/JVM today; full Kubernetes bundle on the roadmap.' },
];
---

<BaseLayout
  title="Why JamJet — The safety layer behind your AI agents"
  description="Six failure modes that turn agent demos into production incidents — and how JamJet's runtime addresses them: policy, durability, HITL, cost caps, signed audit, and memory in one fabric."
  canonical={canonical}
>

<!-- ── Hero ── -->
<section class="why-hero">
  <div class="container">
    <h1>The six failure modes that turn agent demos into production incidents.</h1>
    <p class="why-hero-sub">
      Most agent failures aren't model failures. They're missing primitives — no way to block an unsafe
      tool, no way to resume after a crash, no way to gate a high-risk action, no way to cap a runaway
      loop, no compliance-grade evidence, no durable memory. JamJet ships them as one runtime.
    </p>
  </div>
</section>

<!-- ── Six Capabilities ── -->
{capabilities.map((cap, i) => (
  <section style={i % 2 === 0 ? '' : 'background: var(--bg-alt);'}>
    <div class="container">
      <span class="section-label">{cap.label}</span>
      <h2 class="cap-title">{cap.title}</h2>
      <div class="cap-content">
        <div class="cap-context">
          <h3>The failure mode</h3>
          <p>{cap.failure}</p>
        </div>
        <div class="cap-mechanism">
          <h3>How JamJet addresses it</h3>
          <p>{cap.mechanism}</p>
        </div>
      </div>
    </div>
  </section>
))}

<!-- ── Differentiation Strip ── -->
<section style="background: var(--bg-alt);">
  <div class="container">
    <span class="section-label">What makes JamJet different</span>
    <div class="diff-grid">
      {differentiators.map(d => (
        <div class="diff-item">
          <strong>{d.title}</strong>
          <p>{d.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ── Two-Path CTA ── -->
<section style="background: var(--bg-alt);">
  <div class="container">
    <div class="two-path">
      <div class="path-card">
        <h3>Try it now</h3>
        <div class="install-cmd" style="margin: 16px 0 20px;">
          <span class="prompt">$</span>
          <span class="cmd">pip install jamjet</span>
          <CopyButton text="pip install jamjet" />
        </div>
        <a href="https://docs.jamjet.dev/en/docs/quickstart" class="btn-primary">Read the quickstart →</a>
      </div>
      <div class="path-card">
        <h3>See it next to what you already have</h3>
        <p class="path-desc">Honest comparisons with LangSmith, Helicone, Temporal, and Microsoft AGT — no vendor takedowns, just where each tool fits.</p>
        <a href="/compare" class="btn-secondary">Browse comparisons →</a>
      </div>
    </div>
  </div>
</section>

</BaseLayout>

<style>
  .why-hero {
    padding: var(--space-section) 0;
    text-align: center;
  }
  .why-hero h1 {
    max-width: 820px;
    margin: 0 auto 24px;
  }
  .why-hero-sub {
    max-width: 680px;
    margin: 0 auto;
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .cap-title {
    margin-bottom: 32px;
  }
  .cap-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
  }
  .cap-content h3 {
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--text-muted);
    font-family: var(--font-sans);
    margin-bottom: 12px;
  }
  .cap-content p {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.75;
  }

  .diff-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
    margin-top: 32px;
  }
  .diff-item strong {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    margin-bottom: 8px;
  }
  .diff-item p {
    font-size: 0.88rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .two-path {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    max-width: 800px;
    margin: 0 auto;
  }
  .path-card {
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 32px;
  }
  .path-card h3 {
    font-family: var(--font-body);
    font-size: 1.3rem;
    font-weight: 500;
    margin-bottom: 8px;
  }
  .path-desc {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 20px;
  }

  @media (max-width: 768px) {
    .cap-content {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .diff-grid {
      grid-template-columns: 1fr 1fr;
    }
    .two-path {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 480px) {
    .diff-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
