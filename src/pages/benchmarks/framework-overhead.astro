---
import BaseLayout from '../../layouts/BaseLayout.astro';

const runs = [
  {
    label: 'llama3.2 · Ollama · Apple M-series · 2026-03-08',
    model: 'llama3.2',
    endpoint: 'http://localhost:11434/v1 (Ollama)',
    runs: 20,
    warmup: 3,
    results: [
      { name: 'Raw (baseline)',  mean: 947.2, median: 943.7, p95: 970.3, p99: 972.2, min: 935.6, max: 972.7, stdev: 9.9,  overhead: null },
      { name: 'JamJet 0.1.1',   mean: 948.6, median: 948.2, p95: 959.0, p99: 964.2, min: 941.3, max: 965.5, stdev: 6.0,  overhead: +1.4 },
      { name: 'LangGraph',       mean: 944.0, median: 943.0, p95: 953.8, p99: 961.1, min: 930.2, max: 963.0, stdev: 8.1,  overhead: -3.2 },
    ],
    note: 'All three frameworks within measurement noise (~1ms). JamJet\'s in-process executor adds zero observable overhead over a raw LLM call.',
  },
  {
    label: 'qwen3:8b (thinking mode) · Ollama · Apple M-series · 2026-03-08',
    model: 'qwen3:8b',
    endpoint: 'http://localhost:11434/v1 (Ollama)',
    runs: 15,
    warmup: 3,
    results: [
      { name: 'Raw (baseline)',  mean: 8429.5, median: 8303.4, p95: 8940.3, p99: 9427.6, min: 8128.1, max: 9549.4, stdev: 352.3, overhead: null },
      { name: 'JamJet 0.1.1',   mean: 10140.1, median: 10139.1, p95: 10487.0, p99: 10519.5, min: 9539.4, max: 10527.6, stdev: 285.1, overhead: +1710.6 },
      { name: 'LangGraph',       mean: 11902.9, median: 11923.3, p95: 12761.8, p99: 12823.5, min: 11035.0, max: 12838.9, stdev: 551.7, overhead: +3473.3 },
    ],
    note: 'qwen3:8b generates variable-length chain-of-thought. High stdev dominates — overhead numbers reflect token generation variance, not framework overhead.',
  },
];

const overheadLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": "Framework overhead — JamJet vs raw vs LangGraph",
      "description": "JamJet adds zero observable framework overhead vs raw LLM calls. Reproducible llama3.2 + qwen3:8b measurements with the code.",
      "datePublished": "2026-03-08",
      "author": { "@type": "Person", "name": "Sunil Prakash" },
      "publisher": { "@type": "Organization", "name": "JamJet" },
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jamjet.dev/" },
        { "@type": "ListItem", "position": 2, "name": "Benchmarks", "item": "https://jamjet.dev/benchmarks/" },
        { "@type": "ListItem", "position": 3, "name": "Framework overhead", "item": "https://jamjet.dev/benchmarks/framework-overhead/" },
      ],
    },
  ],
};
---

<BaseLayout
  title="Framework overhead — JamJet vs raw vs LangGraph · JamJet Benchmarks"
  description="JamJet adds zero observable framework overhead vs raw LLM calls. Reproducible llama3.2 + qwen3:8b measurements with the code."
  canonical="https://jamjet.dev/benchmarks/framework-overhead/"
>
<Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify(overheadLd)}></script>
</Fragment>

<div class="fwo-wrap">
  <a class="back-link" href="/benchmarks/">← Back to JamJet benchmarks</a>

  <header class="fwo-header">
    <span class="section-label">Runtime · Framework tax</span>
    <h1>Framework overhead — zero-cost orchestration</h1>
    <p class="fwo-subhead">JamJet vs raw LLM calls vs LangGraph, reproducible end-to-end.</p>
    <p class="fwo-intro">
      Across two reader models — a fast 3B (llama3.2) and a slower 8B chain-of-thought model
      (qwen3:8b) — JamJet's in-process executor adds zero observable overhead vs raw LLM calls.
      LangGraph is similarly tied within measurement noise. The numbers are below; the reproduction
      script is in the methodology section.
    </p>
    <p class="last-updated">Last updated 2026-03-08</p>
  </header>

  {runs.map((run) => {
    const maxMean = Math.max(...run.results.map(r => r.mean));
    return (
      <div>
        <h3 class="run-heading">{run.label}</h3>
        <div class="run-meta">
          <span>Model: <strong>{run.model}</strong></span>
          <span>Endpoint: <strong>{run.endpoint}</strong></span>
          <span>Runs: <strong>{run.runs}</strong> (+{run.warmup} warmup)</span>
        </div>

        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th style="text-align:left">Framework</th>
                <th>mean (ms)</th>
                <th>median</th>
                <th>p95</th>
                <th>p99</th>
                <th>stdev</th>
                <th>overhead</th>
                <th>visual</th>
              </tr>
            </thead>
            <tbody>
              {run.results.map((r) => {
                const isJamjet = r.name.startsWith('JamJet');
                const isRaw = r.name === 'Raw (baseline)';
                const barClass = isRaw ? 'bar-raw' : isJamjet ? 'bar-jamjet' : 'bar-other';
                const barWidth = Math.round((r.mean / maxMean) * 180);
                const overheadStr = r.overhead === null
                  ? '—'
                  : r.overhead >= 0
                    ? `+${r.overhead.toFixed(1)}ms`
                    : `${r.overhead.toFixed(1)}ms`;
                return (
                  <tr class={isJamjet ? 'jamjet-row' : ''}>
                    <td style="text-align:left;font-weight:600">{r.name}</td>
                    <td>{r.mean.toFixed(1)}</td>
                    <td>{r.median.toFixed(1)}</td>
                    <td>{r.p95.toFixed(1)}</td>
                    <td>{r.p99.toFixed(1)}</td>
                    <td>{r.stdev.toFixed(1)}</td>
                    <td class="overhead-cell">{overheadStr}</td>
                    <td>
                      <div class="bar-wrap">
                        <div class={`bar ${barClass}`} style={`width:${barWidth}px`}></div>
                      </div>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>

        <p class="note"><strong>Note:</strong> {run.note}</p>
      </div>
    );
  })}

  <div class="methodology">
    <h2>Methodology</h2>
    <p>
      All benchmarks measure wall-clock time per call. Each framework makes the
      <strong>identical LLM call</strong> through the same OpenAI-compatible client — what we measure is framework orchestration overhead.
    </p>
    <ul>
      <li><strong>Raw (baseline)</strong> — bare openai.OpenAI().chat.completions.create() call</li>
      <li><strong>JamJet</strong> — Workflow.run_sync() in-process executor</li>
      <li><strong>LangGraph</strong> — StateGraph.compile().invoke() with a single node</li>
    </ul>

    <div class="code-block" style="margin:1rem 0">
      <pre class="code-body"><span class="t-d"># Reproduce locally (Ollama)</span>
export OPENAI_API_KEY="ollama"
export OPENAI_BASE_URL="http://localhost:11434/v1"
export MODEL_NAME="llama3.2"

git clone https://github.com/jamjet-labs/jamjet-benchmarks
cd jamjet-benchmarks/benchmarks
pip install -r requirements.txt
python bench_single_call.py --json results/my-run.json</pre>
    </div>

    <ul>
      <li>Warmup runs excluded from measurements</li>
      <li>Each timed run is independent — no shared state</li>
      <li>Benchmarks run sequentially to avoid contention</li>
      <li>Hardware: Apple M-series, 16GB RAM, Ollama local</li>
    </ul>
  </div>

  <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:2rem">
    <a href="https://github.com/jamjet-labs/jamjet-benchmarks" class="btn-primary" target="_blank" rel="noopener">Reproduce these benchmarks</a>
    <a href="https://docs.jamjet.dev/en/docs/compare" class="btn-secondary">Feature comparison</a>
    <a href="https://docs.jamjet.dev/en/docs/quickstart" class="btn-secondary">Quickstart</a>
  </div>

  <p class="fwo-crosslinks">
    <strong>More:</strong>
    <a href="/benchmarks/">JamJet benchmarks index</a> &middot;
    <a href="/benchmarks/engram-longmemeval/">Engram LongMemEval-S leaderboard</a> &middot;
    <a href="/compare/">JamJet comparisons</a>
  </p>
</div>

</BaseLayout>

<style>
  .fwo-wrap {
    max-width: 1000px;
    margin: 0 auto;
    padding: 3rem 24px 5rem;
  }

  .back-link {
    color: var(--accent);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    display: inline-block;
    margin-bottom: 24px;
  }
  .back-link:hover { text-decoration: underline; }

  .fwo-header { margin-bottom: 48px; }
  .section-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    display: block;
    margin-bottom: 8px;
  }
  .fwo-header h1 {
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    margin: 8px 0 12px;
  }
  .fwo-subhead {
    font-size: 1.05rem;
    color: var(--text-secondary);
    margin: 0 0 24px;
  }
  .fwo-intro {
    color: var(--text-secondary);
    line-height: 1.8;
    margin: 0 0 16px;
  }
  .last-updated {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin: 8px 0 24px;
  }

  .run-heading {
    font-size: 1rem; font-weight: 600; margin: 3rem 0 0.5rem;
    padding-top: 1.5rem; border-top: 1px solid var(--border);
  }
  .run-meta { font-size: 0.82rem; color: var(--text-muted); margin-bottom: 1rem; }
  .run-meta span { margin-right: 1.5rem; }
  .run-meta strong { color: var(--text); }

  .table-wrap { overflow-x: auto; border-radius: 8px; border: 1px solid var(--border-strong); }
  table { width: 100%; border-collapse: collapse; font-size: 0.82rem; font-family: var(--font-mono); }
  thead th { text-align: right; padding: 8px 12px; color: var(--text-muted); font-weight: 500; border-bottom: 1px solid var(--border); font-size: 0.75rem; }
  tbody tr:hover { background: var(--accent-bg); }
  tbody td { padding: 8px 12px; text-align: right; border-bottom: 1px solid var(--border); color: var(--text-secondary); }
  .jamjet-row td:first-child { color: var(--accent); }

  .bar-wrap { display: flex; align-items: center; gap: 8px; }
  .bar { height: 6px; border-radius: 2px; min-width: 2px; }
  .bar-raw { background: var(--text-muted); }
  .bar-jamjet { background: var(--accent); }
  .bar-other { background: #4a7ab5; }

  .note {
    font-size: 0.82rem; color: var(--text-muted);
    background: var(--bg-alt); border-left: 3px solid var(--border-strong);
    padding: 0.75rem 1rem; border-radius: 0 4px 4px 0; margin-top: 1rem;
  }
  .note strong { color: var(--text-secondary); }

  .overhead-cell { font-family: var(--font-mono); }

  .methodology {
    background: var(--bg-alt); border: 1px solid var(--border); border-radius: 8px;
    padding: 2rem; margin-top: 3rem;
  }
  .methodology h2 { margin-top: 0; margin-bottom: 0.75rem; }
  .methodology p { color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 1rem; }
  .methodology strong { color: var(--text); }
  .methodology ul { padding-left: 1.25rem; color: var(--text-secondary); font-size: 0.88rem; }
  .methodology ul li { margin-bottom: 0.4rem; }

  .code-block { border-radius: 8px; overflow: hidden; border: 1px solid var(--border); }
  .code-header {
    background: var(--bg-alt); padding: 8px 16px; font-size: 0.78rem;
    color: var(--text-muted); border-bottom: 1px solid var(--border);
  }
  .code-body {
    margin: 0; padding: 16px; background: var(--bg-code, var(--bg-alt));
    font-family: var(--font-mono); font-size: 0.82rem; line-height: 1.6;
    color: var(--text); overflow-x: auto;
  }
  .t-d { color: var(--text-muted); }
  .t-p { color: var(--text-secondary); }
  .t-b { color: var(--accent); }
  .t-s { color: #c3a556; }
  .t-kw { color: #b06cc4; font-weight: 600; }
  .t-y { color: #4a9cd6; }

  .btn-primary {
    display: inline-block;
    padding: 10px 20px;
    background: var(--accent);
    color: var(--bg);
    border-radius: 6px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
  }
  .btn-secondary {
    display: inline-block;
    padding: 10px 20px;
    border: 1px solid var(--border-strong);
    color: var(--text);
    border-radius: 6px;
    text-decoration: none;
    font-size: 0.9rem;
  }
  .btn-secondary:hover { border-color: var(--accent); color: var(--accent); }

  .fwo-crosslinks {
    margin-top: 64px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
    font-size: 0.9rem;
    color: var(--text-muted);
  }
  .fwo-crosslinks a { color: var(--accent); }
</style>
