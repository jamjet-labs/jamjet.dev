---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props as { post: CollectionEntry<'blog'> };
const { Content } = await post.render();
const site = 'https://jamjet.dev';
const canonical = `${site}/blog/${post.slug}/`;
const pageTitle = `${post.data.title} | JamJet Blog`;
const image = `${site}/og.png`;
const tweetText = encodeURIComponent(`${post.data.title}\n\n${canonical}`);
const linkedinUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(canonical)}`;
const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString(),
  dateModified: post.data.date.toISOString(),
  author: {
    '@type': 'Person',
    name: post.data.author ?? 'JamJet Team',
  },
  publisher: {
    '@type': 'Organization',
    name: 'JamJet',
    logo: { '@type': 'ImageObject', url: `${site}/favicon.svg` },
  },
  mainEntityOfPage: canonical,
  image,
  ...(post.data.category ? { articleSection: post.data.category } : {}),
};
---

<BaseLayout
  title={pageTitle}
  description={post.data.description}
  canonical={canonical}
  ogImage={image}
  ogType="article"
  currentPage="blog"
>
  <Fragment slot="head">
    <meta property="article:published_time" content={post.data.date.toISOString()} />
    <meta property="article:author" content={post.data.author ?? 'JamJet Team'} />
    {post.data.category && <meta property="article:section" content={post.data.category} />}
    <script type="application/ld+json" set:html={JSON.stringify(articleLd)}></script>
  </Fragment>

  <div class="article-wrap">
    <a class="back-link" href="/blog/">Back to blog</a>

    <header class="post-header">
      <h1>{post.data.title}</h1>
      <p class="meta">
        <time>{post.data.date.toISOString().slice(0, 10)}</time>
        {post.data.author && (
          <span> · <a href={`mailto:${post.data.author === 'Sunil Prakash' ? 'sunil@jamjet.dev' : 'hello@jamjet.dev'}`} class="author-link">{post.data.author}</a></span>
        )}
      </p>
    </header>

    <div class="share-bar">
      <span class="share-label">Share</span>
      <a class="share-btn" href={`https://x.com/intent/tweet?text=${tweetText}`} target="_blank" rel="noopener">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622 5.911-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        Post on X
      </a>
      <a class="share-btn" href={linkedinUrl} target="_blank" rel="noopener">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
        LinkedIn
      </a>
      <button class="share-btn" id="copy-btn">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
        <span id="copy-label">Copy link</span>
      </button>
    </div>

    <article class="article">
      <Content />
    </article>

    <div class="share-bar-bottom">
      <p>Found this useful? Share it.</p>
      <div class="share-bar" style="border:none;padding:0;margin:0.75rem 0 0;">
        <a class="share-btn" href={`https://x.com/intent/tweet?text=${tweetText}`} target="_blank" rel="noopener">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622 5.911-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          Post on X
        </a>
        <button class="share-btn" id="copy-btn-bottom">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
          <span id="copy-label-bottom">Copy link</span>
        </button>
      </div>
    </div>
  </div>

</BaseLayout>

<style>
  .article-wrap { max-width: 780px; margin: 0 auto; padding: 2rem 24px 4rem; }

  .back-link {
    color: var(--accent); text-decoration: none; font-size: 0.9rem; font-weight: 500;
    display: inline-block; margin-bottom: 24px;
  }
  .back-link:hover { text-decoration: underline; }

  .post-header h1 { font-size: clamp(1.6rem, 3vw, 2.2rem); line-height: 1.2; margin-bottom: 8px; }
  .meta { color: var(--text-muted); font-size: 0.88rem; margin-bottom: 20px; }
  .author-link { color: var(--text-muted); text-decoration: none; border-bottom: 1px solid var(--border); transition: color 0.15s, border-color 0.15s; }
  .author-link:hover { color: var(--text); border-color: var(--text); }

  .share-bar {
    display: flex; align-items: center; gap: 10px;
    padding: 14px 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
    margin-bottom: 2rem; flex-wrap: wrap;
  }
  .share-label {
    font-size: 0.78rem; color: var(--text-muted); text-transform: uppercase;
    letter-spacing: 0.08em; font-weight: 600; margin-right: 4px;
  }
  .share-btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 6px 14px; border-radius: 6px;
    font-size: 0.82rem; font-weight: 600; text-decoration: none;
    border: 1px solid var(--border-strong); color: var(--text-muted);
    background: transparent; cursor: pointer; font-family: inherit;
    transition: border-color 0.15s, color 0.15s;
  }
  .share-btn:hover { border-color: var(--accent); color: var(--accent); }

  .article :global(h1) { display: none; }
  .article :global(h2) { font-size: 1.35rem; font-weight: 700; margin: 2.2rem 0 0.75rem; line-height: 1.2; }
  .article :global(h3) { font-size: 1.1rem; font-weight: 600; color: var(--text-secondary); margin: 1.6rem 0 0.5rem; }
  .article :global(p), .article :global(li) { color: var(--text-secondary); line-height: 1.8; }
  .article :global(p) { margin-bottom: 1.1rem; }
  .article :global(ul), .article :global(ol) { padding-left: 1.4rem; margin-bottom: 1.1rem; }
  .article :global(li) { margin-bottom: 0.4rem; }
  .article :global(a) { color: var(--accent); text-decoration: none; }
  .article :global(a:hover) { text-decoration: underline; }
  .article :global(.expressive-code) { margin: 1.25rem 0; }
  .article :global(.expressive-code .frame) { background: var(--bg-code) !important; border-radius: 10px; overflow: hidden; }
  .article :global(.expressive-code pre) { background: var(--bg-code) !important; padding: 1rem; overflow: auto; }
  .article :global(.expressive-code code) { font-family: var(--font-mono); font-size: 0.85rem; }
  .article :global(.expressive-code .ec-line span) { color: var(--0) !important; }
  .article :global(pre) { overflow: auto; border-radius: 10px; padding: 1rem; margin: 1.25rem 0; background: var(--bg-code); }
  .article :global(code) { font-family: var(--font-mono); font-size: 0.85rem; }
  .article :global(pre code) { color: #eae8e1; }
  .article :global(img) {
    max-width: 100%; height: auto; border-radius: 8px; margin: 1.5rem 0;
    display: block;
  }
  .article :global(blockquote) { border-left: 3px solid var(--accent); padding-left: 1rem; color: var(--text-muted); margin: 1.25rem 0; font-style: italic; }
  .article :global(hr) { border: none; border-top: 1px solid var(--border); margin: 2rem 0; }
  .article :global(strong) { color: var(--text); font-weight: 600; }

  /* Tables */
  .article :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.88rem;
    margin: 1.5rem 0;
    border: 1px solid rgba(26,26,24,0.10);
    border-radius: 8px;
    overflow: hidden;
  }
  .article :global(thead) {
    background: var(--bg-alt, #f5f4f0);
  }
  .article :global(th) {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted, #8b8578);
    font-weight: 600;
    padding: 0.75rem 1rem;
    border-bottom: 2px solid rgba(26,26,24,0.12);
    text-align: left;
    white-space: nowrap;
  }
  .article :global(td) {
    padding: 0.65rem 1rem;
    border-bottom: 1px solid rgba(26,26,24,0.06);
    color: var(--text-secondary, #6b6b63);
    vertical-align: top;
    line-height: 1.5;
  }
  .article :global(tr:last-child td) {
    border-bottom: none;
  }
  .article :global(tr:hover td) {
    background: rgba(139,115,85,0.03);
  }
  .article :global(td code),
  .article :global(th code) {
    font-size: 0.78rem;
    background: rgba(26,26,24,0.06);
    padding: 0.15em 0.4em;
    border-radius: 3px;
    white-space: nowrap;
  }

  .share-bar-bottom { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--border); }
  .share-bar-bottom p { color: var(--text-muted); font-size: 0.9rem; }
</style>

<script>
  function setupCopyBtn(btnId: string, labelId: string) {
    const btn = document.getElementById(btnId);
    const label = document.getElementById(labelId);
    if (!btn || !label) return;
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        label.textContent = 'Copied!';
        setTimeout(() => { label.textContent = 'Copy link'; }, 2000);
      } catch {}
    });
  }
  setupCopyBtn('copy-btn', 'copy-label');
  setupCopyBtn('copy-btn-bottom', 'copy-label-bottom');
</script>
