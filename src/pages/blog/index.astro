---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Group posts by category, preserving display order
const categoryOrder = [
  'Strategy & Vision',
  'Architecture & Deep Dives',
  'Enterprise & Security',
  'Testing & Evaluation',
  'Releases & Updates',
];

const grouped = new Map<string, typeof posts>();
for (const cat of categoryOrder) {
  grouped.set(cat, []);
}
for (const post of posts) {
  const cat = post.data.category ?? 'Releases & Updates';
  if (!grouped.has(cat)) grouped.set(cat, []);
  grouped.get(cat)!.push(post);
}

const blogLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'JamJet Blog',
  description: 'Engineering deep dives, architectural patterns, and strategic thinking on building durable, production AI agents.',
  url: 'https://jamjet.dev/blog/',
  publisher: {
    '@type': 'Organization',
    name: 'JamJet',
    logo: { '@type': 'ImageObject', url: 'https://jamjet.dev/favicon.svg' },
  },
  blogPost: posts.slice(0, 10).map((post) => ({
    '@type': 'BlogPosting',
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.date.toISOString(),
    url: `https://jamjet.dev/blog/${post.slug}/`,
  })),
};
---

<BaseLayout
  title="Blog | JamJet — Durable AI Agent Runtime"
  description="Engineering deep dives, architectural patterns, and strategic thinking on building durable, production AI agents."
  canonical="https://jamjet.dev/blog/"
  currentPage="blog"
>

<Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify(blogLd)}></script>
</Fragment>

<div class="blog-page">

  <header class="blog-header">
    <h1>Blog</h1>
    <p class="blog-intro">Engineering, architecture, and strategy for durable AI agents.</p>
  </header>

  {categoryOrder.map((category) => {
    const catPosts = grouped.get(category);
    if (!catPosts || catPosts.length === 0) return null;
    return (
      <section class="category-section">
        <h2 class="category-title">{category}</h2>
        <div class="post-list">
          {catPosts.map((post, i) => (
            <a class="post-entry" href={`/blog/${post.slug}/`} style={`--delay: ${0.08 + i * 0.03}s`}>
              <div class="post-entry-content">
                <h3 class="post-entry-title">{post.data.title}</h3>
                <p class="post-entry-desc">{post.data.description}</p>
              </div>
              <div class="post-entry-meta">
                <time>{post.data.date.toISOString().slice(0, 10)}</time>
                <span class="read-link">Read</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    );
  })}

</div>

</BaseLayout>

<style>
  .blog-page {
    max-width: 820px;
    margin: 0 auto;
    padding: 3rem 24px 6rem;
  }

  /* ── Header ── */
  .blog-header {
    margin-bottom: 3.5rem;
  }

  .blog-header h1 {
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .blog-intro {
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.6;
    max-width: 540px;
  }

  /* ── Category Sections ── */
  .category-section {
    margin-bottom: 3rem;
  }

  .category-title {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 0;
  }

  /* ── Post Entries ── */
  .post-list {
    display: flex;
    flex-direction: column;
  }

  .post-entry {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    opacity: 0;
    transform: translateY(12px);
    animation: fadeInUp 0.4s ease forwards;
    animation-delay: var(--delay, 0s);
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .post-entry:hover .post-entry-title {
    color: var(--accent-hover);
  }

  .post-entry:hover .read-link {
    opacity: 1;
  }

  .post-entry-content {
    flex: 1;
    min-width: 0;
  }

  .post-entry-title {
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.35;
    margin-bottom: 0.35rem;
    transition: color 0.15s;
  }

  .post-entry-desc {
    color: var(--text-secondary);
    font-size: 0.88rem;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-entry-meta {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.4rem;
    padding-top: 2px;
  }

  .post-entry-meta time {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .read-link {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-muted);
    opacity: 0;
    transition: opacity 0.15s;
  }

  /* ── Responsive ── */
  @media (max-width: 600px) {
    .post-entry {
      flex-direction: column;
      gap: 0.5rem;
    }

    .post-entry-meta {
      flex-direction: row;
      align-items: center;
      gap: 1rem;
    }

    .read-link {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .post-entry {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>
