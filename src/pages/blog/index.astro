---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const fullPosts = posts.slice(0, 3);
const olderPosts = posts.slice(3);

const rendered = await Promise.all(fullPosts.map((p) => p.render()));
---

<BaseLayout
  title="JamJet Blog | Engineering, Releases, and Production Agent Patterns"
  description="Latest JamJet updates, release notes, and deep dives on building durable, production AI agents."
  canonical="https://jamjet.dev/blog/"
  currentPage="blog"
>

<div class="blog-page">

  <main>
    <div class="feed-header">
      <h1>Blog</h1>
      <p>Engineering, releases, and practical patterns for durable AI agents — from crash recovery and human approval to reproducible research and enterprise deployment.</p>
    </div>

    {fullPosts.map((post, i) => {
      const { Content } = rendered[i];
      const postUrl = `https://jamjet.dev/blog/${post.slug}/`;
      const tweetText = encodeURIComponent(`${post.data.title}\n\n${postUrl}`);
      const linkedinUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(postUrl)}`;
      return (
        <article class="post">
          {i === 0 && <p class="post-eyebrow">Latest</p>}
          <h2 class="post-title">
            <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
          </h2>
          <p class="post-meta">
            {post.data.date.toISOString().slice(0, 10)}
            {post.data.author ? ` · ${post.data.author}` : ''}
          </p>
          <div class="post-body">
            <Content />
          </div>
          <div class="post-footer">
            <a class="share-btn" href={`https://x.com/intent/tweet?text=${tweetText}`} target="_blank" rel="noopener">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622 5.911-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              Share on X
            </a>
            <a class="share-btn" href={linkedinUrl} target="_blank" rel="noopener">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
              LinkedIn
            </a>
            <button class="share-btn" data-copy-url={postUrl} aria-label="Copy link">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              <span>Copy link</span>
            </button>
            <a class="share-btn" href={`/blog/${post.slug}/`} style="margin-left:auto">
              Read full post
            </a>
          </div>
          {i < fullPosts.length - 1 && <hr class="post-divider" />}
        </article>
      );
    })}
  </main>

  {olderPosts.length > 0 && (
    <aside class="sidebar">
      <div class="sidebar-section">
        <p class="sidebar-title">Older posts</p>
        {olderPosts.map((post) => (
          <a class="sidebar-post" href={`/blog/${post.slug}/`}>
            <p class="sidebar-post-title">{post.data.title}</p>
            <p class="sidebar-post-date">{post.data.date.toISOString().slice(0, 10)}</p>
          </a>
        ))}
      </div>
    </aside>
  )}

</div>

</BaseLayout>

<style>
  .blog-page {
    max-width: 1080px; margin: 0 auto; padding: 3rem 24px 6rem;
    display: grid; grid-template-columns: 1fr 260px; gap: 4rem; align-items: start;
  }
  @media (max-width: 900px) { .blog-page { grid-template-columns: 1fr; gap: 3rem; } }

  .blog-page main { min-width: 0; overflow-wrap: break-word; }

  .feed-header { margin-bottom: 2.5rem; }
  .feed-header h1 { font-size: 2rem; font-weight: 700; margin-bottom: 0.4rem; }
  .feed-header p { color: var(--text-secondary); font-size: 0.95rem; }

  .post + .post { margin-top: 0; }
  .post-divider { border: none; border-top: 1px solid var(--border); margin: 3.5rem 0; }

  .post-eyebrow {
    font-size: 0.75rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.1em; color: var(--accent); margin-bottom: 0.6rem;
  }
  .post-title { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 700; line-height: 1.2; margin-bottom: 0.5rem; }
  .post-title a { color: inherit; text-decoration: none; }
  .post-title a:hover { color: var(--accent); }
  .post-meta { font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1.8rem; }

  .post-body :global(h1) { display: none; }
  .post-body :global(h2) { font-size: 1.3rem; font-weight: 700; margin: 2rem 0 0.75rem; }
  .post-body :global(h3) { font-size: 1.1rem; font-weight: 600; color: var(--text-secondary); margin: 1.5rem 0 0.5rem; }
  .post-body :global(p) { color: var(--text-secondary); line-height: 1.8; margin-bottom: 1.1rem; }
  .post-body :global(ul), .post-body :global(ol) { color: var(--text-secondary); padding-left: 1.4rem; margin-bottom: 1.1rem; }
  .post-body :global(li) { margin-bottom: 0.4rem; line-height: 1.7; }
  .post-body :global(a) { color: var(--accent); text-decoration: none; }
  .post-body :global(a:hover) { text-decoration: underline; }
  .post-body :global(.expressive-code) { margin: 1.25rem 0; }
  .post-body :global(.expressive-code .frame) { background: var(--bg-code) !important; border-radius: 10px; overflow: hidden; }
  .post-body :global(.expressive-code pre) { background: var(--bg-code) !important; padding: 1rem; overflow: auto; }
  .post-body :global(.expressive-code code) { font-family: var(--font-mono); font-size: 0.85rem; }
  .post-body :global(.expressive-code .ec-line span) { color: var(--0) !important; }
  .post-body :global(pre) { background: var(--bg-code); border-radius: 8px; padding: 1rem; overflow-x: auto; margin: 1.25rem 0; }
  .post-body :global(code) { font-family: var(--font-mono); font-size: 0.85rem; }
  .post-body :global(pre code) { color: #eae8e1; }
  .post-body :global(blockquote) { border-left: 3px solid var(--accent); padding-left: 1rem; color: var(--text-muted); margin: 1.25rem 0; font-style: italic; }
  .post-body :global(hr) { border: none; border-top: 1px solid var(--border); margin: 2rem 0; }
  .post-body :global(strong) { color: var(--text); font-weight: 600; }

  .post-footer {
    display: flex; align-items: center; gap: 10px; margin-top: 2rem;
    padding-top: 1rem; border-top: 1px solid var(--border); flex-wrap: wrap;
  }
  .share-btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 5px 12px; border-radius: 6px;
    font-size: 0.78rem; font-weight: 600; text-decoration: none;
    border: 1px solid var(--border-strong); color: var(--text-muted);
    background: transparent; cursor: pointer; font-family: inherit;
    transition: border-color 0.15s, color 0.15s;
  }
  .share-btn:hover { border-color: var(--accent); color: var(--accent); }

  .sidebar { position: sticky; top: 80px; }
  .sidebar-title {
    font-size: 0.75rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.1em; color: var(--accent); margin-bottom: 1rem;
    padding-bottom: 0.5rem; border-bottom: 1px solid var(--border);
  }
  .sidebar-post {
    display: block; padding: 0.75rem 0; border-bottom: 1px solid var(--border);
    text-decoration: none; color: inherit;
  }
  .sidebar-post:last-child { border-bottom: none; }
  .sidebar-post:hover .sidebar-post-title { color: var(--accent); }
  .sidebar-post-title { font-size: 0.9rem; font-weight: 600; line-height: 1.3; margin-bottom: 0.3rem; }
  .sidebar-post-date { font-size: 0.78rem; color: var(--text-muted); }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('button[data-copy-url]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const url = btn.dataset.copyUrl ?? window.location.href;
      const label = btn.querySelector('span');
      try {
        await navigator.clipboard.writeText(url);
        if (label) label.textContent = 'Copied!';
        setTimeout(() => {
          if (label) label.textContent = 'Copy link';
        }, 2000);
      } catch {}
    });
  });
</script>
