---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const now = new Date();
const fourteenDaysAgo = new Date(now.getTime() - 14 * 24 * 60 * 60 * 1000);

function isNew(date: Date) {
  return date >= fourteenDaysAgo;
}

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

function initials(name: string | undefined) {
  if (!name) return 'JJ';
  const parts = name.trim().split(/\s+/);
  if (parts.length === 1) return parts[0].slice(0, 2).toUpperCase();
  return (parts[0][0] + parts[parts.length - 1][0]).toUpperCase();
}

// Stable hue per author so the avatar color stays consistent across visits.
function authorHue(name: string | undefined) {
  const seed = name ?? 'jamjet';
  let h = 0;
  for (let i = 0; i < seed.length; i++) h = (h * 31 + seed.charCodeAt(i)) % 360;
  return h;
}

function readTime(body: string | undefined) {
  if (!body) return null;
  const words = body.split(/\s+/).length;
  return Math.max(1, Math.round(words / 220));
}

const categories = [...new Set(posts.map((p) => p.data.category).filter(Boolean))] as string[];

const blogLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'JamJet Blog',
  description: 'Runtime safety, agent governance, and engineering deep dives for teams building AI agents that need to work beyond demos.',
  url: 'https://jamjet.dev/blog/',
  publisher: {
    '@type': 'Organization',
    name: 'JamJet',
    logo: { '@type': 'ImageObject', url: 'https://jamjet.dev/favicon.svg' },
  },
  blogPost: posts.slice(0, 10).map((post) => ({
    '@type': 'BlogPosting',
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.date.toISOString(),
    url: `https://jamjet.dev/blog/${post.slug}/`,
  })),
};
---

<BaseLayout
  title="Blog — JamJet | The safety layer behind your AI agents"
  description="Runtime safety, agent governance, and engineering deep dives for teams building AI agents that need to work beyond demos."
  canonical="https://jamjet.dev/blog/"
  currentPage="blog"
>

<Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify(blogLd)}></script>
</Fragment>

<div class="blog-shell">

  <header class="blog-masthead">
    <div class="masthead-line">
      <span class="masthead-eyebrow">JamJet · Field notes from the runtime</span>
      <a class="masthead-rss" href="/rss.xml" aria-label="RSS feed">
        <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor" aria-hidden="true"><path d="M2 2v3a8 8 0 018 8h3A11 11 0 002 2zm0 5v3a3 3 0 013 3h3a6 6 0 00-6-6zm1.75 4.5a1.25 1.25 0 100 2.5 1.25 1.25 0 000-2.5z"/></svg>
        <span>RSS</span>
      </a>
    </div>
    <h1 class="masthead-title">Things we learned<br/>by running agents.</h1>
    <p class="masthead-sub">
      Engineering posts on durable execution, policy, audit, memory, and the boring
      reliability work that makes AI agents survive past the demo.
    </p>

    {categories.length > 0 && (
      <div class="filter-strip" id="filter-strip" role="tablist">
        <button class="filter-pill active" data-cat="all" role="tab" aria-selected="true">
          <span class="pill-dot"></span>All posts
        </button>
        {categories.map((cat) => (
          <button class="filter-pill" data-cat={cat} role="tab" aria-selected="false">
            <span class="pill-dot" style={`background: hsl(${authorHue(cat)}, 60%, 55%)`}></span>{cat}
          </button>
        ))}
      </div>
    )}
  </header>

  <ol class="feed" id="feed">
    {posts.map((post, idx) => (
      <li class="feed-item" data-category={post.data.category ?? ''}>
        <a class="feed-link" href={`/blog/${post.slug}/`}>
          <div class="feed-rail">
            <span class="feed-num">{String(idx + 1).padStart(2, '0')}</span>
          </div>
          <div class="feed-body">
            <div class="feed-meta">
              {post.data.category && (
                <span class="feed-cat">
                  <span class="pill-dot" style={`background: hsl(${authorHue(post.data.category)}, 60%, 55%)`}></span>
                  {post.data.category}
                </span>
              )}
              <time class="feed-date">{formatDate(post.data.date)}</time>
              {isNew(post.data.date) && <span class="feed-new">just shipped</span>}
              {readTime(post.body) && <span class="feed-read">· {readTime(post.body)} min read</span>}
            </div>
            <h2 class="feed-title">{post.data.title}</h2>
            <p class="feed-desc">{post.data.description}</p>
            <div class="feed-foot">
              {post.data.author && (
                <span class="feed-author">
                  <span class="feed-avatar" style={`background: hsl(${authorHue(post.data.author)}, 55%, 78%); color: hsl(${authorHue(post.data.author)}, 70%, 22%)`}>{initials(post.data.author)}</span>
                  <span class="feed-author-name">{post.data.author}</span>
                </span>
              )}
              <span class="feed-arrow">Read &rarr;</span>
            </div>
          </div>
        </a>
      </li>
    ))}
  </ol>

  <footer class="blog-footer-note">
    <span>That's all for now.</span>
    <a href="/rss.xml">Subscribe via RSS</a>
    <span>·</span>
    <a href="https://x.com/jamjetdev" target="_blank" rel="noopener">Follow @jamjetdev</a>
  </footer>

</div>

</BaseLayout>

<style>
  .blog-shell {
    max-width: 920px;
    margin: 0 auto;
    padding: 56px 24px 96px;
  }

  /* ── Masthead ── */
  .blog-masthead {
    margin-bottom: 56px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--border);
  }
  .masthead-line {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 28px;
  }
  .masthead-eyebrow {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--text-muted);
  }
  .masthead-rss {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--text-muted);
    text-decoration: none;
    padding: 6px 12px;
    border: 1px solid var(--border);
    border-radius: 999px;
    transition: color 0.15s, border-color 0.15s;
  }
  .masthead-rss:hover { color: var(--text); border-color: var(--text); }
  .masthead-title {
    font-size: clamp(2.4rem, 6vw, 3.6rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0 0 18px;
    font-weight: 600;
  }
  .masthead-sub {
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 580px;
    margin: 0 0 28px;
  }

  .filter-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .filter-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 14px;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: transparent;
    color: var(--text-muted);
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s;
  }
  .filter-pill:hover {
    color: var(--text);
    border-color: var(--text-muted);
  }
  .filter-pill.active {
    background: var(--text);
    color: var(--bg);
    border-color: var(--text);
  }
  .filter-pill.active .pill-dot { background: var(--bg) !important; opacity: 0.8; }
  .pill-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--text-muted);
    display: inline-block;
  }

  /* ── Feed ── */
  .feed {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .feed-item {
    border-top: 1px solid var(--border);
  }
  .feed-item.hidden { display: none; }
  .feed-item:last-child { border-bottom: 1px solid var(--border); }
  .feed-link {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: 28px;
    padding: 36px 0;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
  }
  .feed-link:hover {
    background: linear-gradient(90deg, var(--bg-alt) 0%, transparent 70%);
  }
  .feed-link:hover .feed-title {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 5px;
  }
  .feed-link:hover .feed-arrow { transform: translateX(4px); color: var(--text); }
  .feed-rail {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 4px;
  }
  .feed-num {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-muted);
    font-weight: 500;
    letter-spacing: 0.05em;
  }
  .feed-body { min-width: 0; }
  .feed-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 14px;
    margin-bottom: 12px;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--text-muted);
  }
  .feed-cat {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--text);
    font-weight: 500;
  }
  .feed-date { color: var(--text-muted); }
  .feed-new {
    padding: 2px 8px;
    background: var(--text);
    color: var(--bg);
    border-radius: 999px;
    font-size: 0.66rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .feed-read { color: var(--text-muted); }
  .feed-title {
    font-size: clamp(1.4rem, 2.8vw, 1.85rem);
    line-height: 1.18;
    margin: 0 0 10px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--text);
  }
  .feed-desc {
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.65;
    margin: 0 0 18px;
    max-width: 640px;
  }
  .feed-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .feed-author {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .feed-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }
  .feed-author-name {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--text);
    font-weight: 500;
  }
  .feed-arrow {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--text-muted);
    font-weight: 500;
    transition: transform 0.15s, color 0.15s;
  }

  .blog-footer-note {
    margin-top: 64px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
    text-align: center;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--text-muted);
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
  }
  .blog-footer-note a {
    color: var(--text);
    text-decoration: none;
    border-bottom: 1px solid var(--border);
  }
  .blog-footer-note a:hover { border-bottom-color: var(--text); }

  @media (max-width: 720px) {
    .feed-link { grid-template-columns: 1fr; gap: 0; padding: 28px 0; }
    .feed-rail { flex-direction: row; justify-content: flex-start; padding: 0 0 8px; }
    .masthead-title { font-size: 2rem; }
    .feed-foot { flex-direction: column; align-items: flex-start; gap: 14px; }
  }
</style>

<script>
  const pills = document.querySelectorAll<HTMLButtonElement>('.filter-pill');
  const items = document.querySelectorAll<HTMLElement>('.feed-item');

  pills.forEach((pill) => {
    pill.addEventListener('click', () => {
      const cat = pill.getAttribute('data-cat');
      pills.forEach((p) => {
        const active = p === pill;
        p.classList.toggle('active', active);
        p.setAttribute('aria-selected', String(active));
      });
      items.forEach((item) => {
        const itemCat = item.getAttribute('data-category');
        const show = cat === 'all' || itemCat === cat;
        item.classList.toggle('hidden', !show);
      });
    });
  });
</script>
