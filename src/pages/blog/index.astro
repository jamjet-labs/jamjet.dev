---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const featured = posts[0];
const recent = posts.slice(1, 5);
const older = posts.slice(5);

const now = new Date();
const fourteenDaysAgo = new Date(now.getTime() - 14 * 24 * 60 * 60 * 1000);

function isNew(date: Date) {
  return date >= fourteenDaysAgo;
}

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

// Unique categories for filter
const categories = [...new Set(posts.map(p => p.data.category).filter(Boolean))] as string[];

const blogLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'JamJet Blog',
  description: 'Production safety, agent governance, and engineering deep dives for teams building AI agents that need to work beyond demos.',
  url: 'https://jamjet.dev/blog/',
  publisher: {
    '@type': 'Organization',
    name: 'JamJet',
    logo: { '@type': 'ImageObject', url: 'https://jamjet.dev/favicon.svg' },
  },
  blogPost: posts.slice(0, 10).map((post) => ({
    '@type': 'BlogPosting',
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.date.toISOString(),
    url: `https://jamjet.dev/blog/${post.slug}/`,
  })),
};
---

<BaseLayout
  title="Blog — JamJet | Production-Safe AI Agents"
  description="Production safety, agent governance, and engineering deep dives for teams building AI agents that need to work beyond demos."
  canonical="https://jamjet.dev/blog/"
  currentPage="blog"
>

<Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify(blogLd)}></script>
</Fragment>

<div class="blog-page">

  <header class="blog-header">
    <h1>Blog</h1>
    <p class="blog-intro">Production safety, governance, and engineering for AI agents that need to work beyond demos.</p>
  </header>

  <!-- ── Featured (Latest) Post ── -->
  {featured && (
    <a class="featured-post" href={`/blog/${featured.slug}/`}>
      <div class="featured-content">
        <div class="featured-badges">
          <span class="badge-latest">Latest</span>
          {featured.data.category && <span class="badge-cat">{featured.data.category}</span>}
        </div>
        <h2 class="featured-title">{featured.data.title}</h2>
        <p class="featured-desc">{featured.data.description}</p>
        <div class="featured-meta">
          <time>{formatDate(featured.data.date)}</time>
          {featured.data.author && <span class="featured-author">{featured.data.author}</span>}
        </div>
      </div>
      <span class="featured-read">Read article &rarr;</span>
    </a>
  )}

  <!-- ── Recent Posts Grid ── -->
  {recent.length > 0 && (
    <section class="recent-section">
      <h2 class="section-heading">Recent</h2>
      <div class="recent-grid">
        {recent.map((post) => (
          <a class="post-card" href={`/blog/${post.slug}/`}>
            {isNew(post.data.date) && <span class="badge-new">New</span>}
            <h3 class="card-title">{post.data.title}</h3>
            <p class="card-desc">{post.data.description}</p>
            <div class="card-meta">
              <time>{formatDate(post.data.date)}</time>
              {post.data.category && <span class="card-cat">{post.data.category}</span>}
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- ── Category Filter + All Posts ── -->
  <section class="all-section">
    <div class="all-header">
      <h2 class="section-heading">All posts</h2>
      <div class="filter-tabs" id="filter-tabs">
        <button class="filter-tab active" data-cat="all">All</button>
        {categories.map((cat) => (
          <button class="filter-tab" data-cat={cat}>{cat}</button>
        ))}
      </div>
    </div>
    <div class="all-list" id="all-list">
      {posts.map((post) => (
        <a class="list-entry" href={`/blog/${post.slug}/`} data-category={post.data.category ?? ''}>
          <div class="list-entry-main">
            <div class="list-title-row">
              <h3 class="list-title">{post.data.title}</h3>
              {isNew(post.data.date) && <span class="badge-new-sm">New</span>}
            </div>
            <p class="list-desc">{post.data.description}</p>
          </div>
          <div class="list-meta">
            <time>{formatDate(post.data.date)}</time>
            {post.data.category && <span class="list-cat">{post.data.category}</span>}
          </div>
        </a>
      ))}
    </div>
  </section>

</div>

</BaseLayout>

<style>
  .blog-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 3rem 24px 6rem;
  }

  .blog-header {
    margin-bottom: 3rem;
  }
  .blog-header h1 {
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  .blog-intro {
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.6;
    max-width: 540px;
  }

  .section-heading {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
  }

  /* ── Featured Post ── */
  .featured-post {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    padding: 2rem;
    background: var(--bg-alt);
    border: 1.5px solid var(--border-strong);
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    margin-bottom: 3.5rem;
    transition: border-color 0.2s, transform 0.2s;
  }
  .featured-post:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .featured-content { flex: 1; }
  .featured-badges {
    display: flex;
    gap: 8px;
    margin-bottom: 12px;
  }
  .badge-latest {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 4px 10px;
    background: var(--accent);
    color: var(--bg);
    border-radius: 4px;
  }
  .badge-cat {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 4px 10px;
    border: 1px solid var(--border-strong);
    border-radius: 4px;
    color: var(--text-muted);
  }
  .featured-title {
    font-size: clamp(1.3rem, 2.5vw, 1.6rem);
    font-weight: 600;
    line-height: 1.25;
    margin-bottom: 10px;
    color: var(--text);
  }
  .featured-desc {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 16px;
  }
  .featured-meta {
    display: flex;
    gap: 12px;
    align-items: center;
  }
  .featured-meta time {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .featured-author {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .featured-read {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-muted);
    white-space: nowrap;
    flex-shrink: 0;
    padding-top: 4px;
    transition: color 0.15s;
  }
  .featured-post:hover .featured-read {
    color: var(--accent);
  }

  /* ── Recent Grid ── */
  .recent-section {
    margin-bottom: 3.5rem;
  }
  .recent-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
  .post-card {
    display: flex;
    flex-direction: column;
    padding: 20px;
    border: 1px solid var(--border);
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, transform 0.15s;
    position: relative;
  }
  .post-card:hover {
    border-color: var(--accent);
    transform: translateY(-1px);
  }
  .badge-new {
    position: absolute;
    top: 12px;
    right: 12px;
    font-family: var(--font-sans);
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 3px 8px;
    background: var(--success);
    color: #fff;
    border-radius: 3px;
  }
  .card-title {
    font-family: var(--font-body);
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.3;
    margin-bottom: 8px;
    color: var(--text);
    padding-right: 40px;
  }
  .card-desc {
    color: var(--text-secondary);
    font-size: 0.85rem;
    line-height: 1.6;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 12px;
  }
  .card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
  }
  .card-meta time {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--text-muted);
  }
  .card-cat {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* ── Filter Tabs ── */
  .all-section {
    margin-top: 1rem;
  }
  .all-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0;
    flex-wrap: wrap;
    gap: 12px;
  }
  .filter-tabs {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
  }
  .filter-tab {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    padding: 5px 12px;
    border: 1px solid var(--border);
    border-radius: 20px;
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.15s;
  }
  .filter-tab:hover {
    border-color: var(--text-muted);
    color: var(--text-secondary);
  }
  .filter-tab.active {
    background: var(--accent);
    color: var(--bg);
    border-color: var(--accent);
  }

  /* ── All Posts List ── */
  .all-list {
    display: flex;
    flex-direction: column;
  }
  .list-entry {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    padding: 1.1rem 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    transition: background 0.1s;
  }
  .list-entry:first-child {
    border-top: 1px solid var(--border);
  }
  .list-entry:hover {
    background: var(--accent-bg);
  }
  .list-entry:hover .list-title {
    color: var(--accent-hover);
  }
  .list-entry.hidden {
    display: none;
  }
  .list-entry-main {
    flex: 1;
    min-width: 0;
  }
  .list-title-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .list-title {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.3;
    transition: color 0.15s;
  }
  .badge-new-sm {
    font-family: var(--font-sans);
    font-size: 0.58rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 2px 6px;
    background: var(--success);
    color: #fff;
    border-radius: 3px;
    flex-shrink: 0;
  }
  .list-desc {
    color: var(--text-secondary);
    font-size: 0.85rem;
    line-height: 1.5;
    margin-top: 4px;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .list-meta {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
    padding-top: 2px;
  }
  .list-meta time {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--text-muted);
    white-space: nowrap;
  }
  .list-cat {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .featured-post {
      flex-direction: column;
      gap: 1rem;
    }
    .featured-read { display: none; }
    .recent-grid { grid-template-columns: 1fr; }
    .list-entry {
      flex-direction: column;
      gap: 0.5rem;
    }
    .list-meta {
      flex-direction: row;
      align-items: center;
      gap: 12px;
    }
    .all-header {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

<script>
  const tabs = document.querySelectorAll('.filter-tab');
  const entries = document.querySelectorAll('.list-entry');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const cat = tab.getAttribute('data-cat');

      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');

      entries.forEach(entry => {
        const entryCat = entry.getAttribute('data-category');
        if (cat === 'all' || entryCat === cat) {
          entry.classList.remove('hidden');
        } else {
          entry.classList.add('hidden');
        }
      });
    });
  });
</script>
