    <p class="rt-start-foot">
      Full guide &mdash; <a href="https://docs.jamjet.dev/en/docs/open-source/jvm-native-runtime">JVM-native runtime docs</a> &middot;
      GitHub &mdash; <a href="https://github.com/jamjet-labs/jamjet-runtime-java" target="_blank" rel="noopener">jamjet-runtime-java</a>,
      <a href="https://github.com/jamjet-labs/jamjet" target="_blank" rel="noopener">jamjet</a>
    </p>
  </div>
</section>

<!-- ────────────────────  AGENTBOUNDARY CALLOUT (demoted)  ──────────────────── -->
<section class="rt-ab">
  <div class="zn-shell rt-ab-shell">
    <p class="rt-ab-text">
      JamJet Runtime is also the Level 4 reference implementation of <strong>AgentBoundary v0.1</strong>.
      40/40 conformance scenarios &middot;
      <a href="https://agentboundary.jamjet.dev/" target="_blank" rel="noopener">cross-vendor matrix &rarr;</a>
    </p>
  </div>
</section>

<!-- ────────────────────  CLOSING  ──────────────────── -->
<section class="zn-close">
  <div class="zn-shell zn-close-shell">
    <h2 class="zn-close-tag">
      Stop wiring durability<br/>
      <span class="zn-close-italic">into every agent by hand.</span>
    </h2>
    <div class="zn-install zn-install-center">
      <span class="zn-prompt">$</span>
      <span class="zn-cmd">pip install jamjet</span>
      <button class="zn-copy" id="copy-rt-final" type="button">copy</button>
    </div>
