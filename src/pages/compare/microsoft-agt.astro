const compareLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "JamJet vs Microsoft Agent Governance Toolkit — Honest Comparison",
  "description": "Microsoft AGT is a policy library. JamJet adds durability, memory, replay, and signed audit evidence — wrap, native, or hosted.",
