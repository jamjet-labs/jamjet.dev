  .ftable code {
    font-size: 0.8rem;
    background: var(--bg-alt);
    padding: 2px 6px;
    border-radius: 3px;
  }

  .pros-list {
    padding-left: 1.4rem;
    margin-bottom: 20px;
  }
  .pros-list li {
    color: var(--text-secondary);
    font-size: 0.92rem;
    line-height: 1.7;
    margin-bottom: 8px;
  }
  .pros-list li strong { color: var(--text); }

  .tradeoff-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }
