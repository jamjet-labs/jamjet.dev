---
import BaseLayout from '../layouts/BaseLayout.astro';

const compareLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "How JamJet fits with what you already use",
  "description": "JamJet isn't a replacement for your agent framework, orchestrator, or observability tool. It's the safety layer underneath. Here's how it fits with LangGraph, CrewAI, Temporal, LangSmith, hosted clouds, and more.",
  "author": { "@type": "Person", "name": "Sunil Prakash" },
  "publisher": { "@type": "Organization", "name": "JamJet" },
};

type FitRow = {
  name: string;
  category: string;
  keepFor: string;
  addJamjetFor: string;
  link?: string;
};

const fits: FitRow[] = [
  {
    name: 'LangGraph / LangChain',
    category: 'Authoring',
    keepFor: 'Graph authoring, prompt templates, the LangChain integration ecosystem.',
    addJamjetFor: 'Durable steps that survive crashes, runtime-enforced policy, replay, audit trails, and cost caps.',
    link: 'https://docs.jamjet.dev/en/docs/migrate/from-langgraph',
  },
  {
    name: 'CrewAI',
    category: 'Authoring',
    keepFor: 'Role-based agent design and the multi-agent collaboration patterns you already wrote.',
    addJamjetFor: 'Durable execution, first-class human approval, cost limits, and audit evidence.',
    link: 'https://docs.jamjet.dev/en/docs/migrate/from-crewai',
  },
  {
    name: 'Pydantic AI',
    category: 'Authoring',
    keepFor: 'Typed agent SDKs, structured output, and the Pydantic mental model.',
    addJamjetFor: 'Governance and replay across the whole runtime — not just inside one agent call.',
  },
  {
    name: 'Google ADK',
    category: 'Authoring',
    keepFor: 'Google-native agent suites tightly coupled to Vertex and Gemini.',
    addJamjetFor: 'A cloud-neutral audit and governance surface that follows your agents off Google.',
  },
  {
    name: 'OpenAI Agents SDK',
    category: 'Authoring',
    keepFor: 'OpenAI-hosted agents, function calling, and the OpenAI runtime.',
    addJamjetFor: 'Policy enforcement, replay, and audit that live outside OpenAI’s cloud.',
  },
  {
    name: 'Temporal',
    category: 'Orchestration',
    keepFor: 'Battle-tested durability for general distributed workflows. Massive scale, broad SDKs.',
    addJamjetFor: 'Agent-specific concerns: memory, MCP/A2A, policy, approvals, cost caps.',
    link: '/compare/temporal',
  },
  {
    name: 'LangSmith / Arize / Phoenix',
    category: 'Observability',
    keepFor: 'Tracing and offline evaluation. Dashboards your data team already uses.',
    addJamjetFor: 'Active enforcement — blocking unsafe tools, halting runs at cost limits, gating high-risk actions — not just observing them.',
  },
  {
    name: 'AWS Bedrock / Azure AI Foundry / Vertex',
    category: 'Cloud platforms',
    keepFor: 'Managed LLM access and cloud-native infra for the rest of your stack.',
    addJamjetFor: 'An open-source, self-hostable control layer your compliance team can run anywhere.',
  },
  {
    name: 'Vanilla Python / direct LLM calls',
    category: 'Authoring',
    keepFor: 'Simplicity and short-lived prototypes — nothing beats a function call.',
    addJamjetFor: 'When the prototype goes live: durability, policy, audit, cost limits, and memory in one runtime.',
    link: 'https://docs.jamjet.dev/en/docs/quickstart',
  },
];

const categories = [...new Set(fits.map(f => f.category))];
---

<BaseLayout
  title="Compare — How JamJet fits with what you already use"
  description="JamJet isn't a replacement for your agent framework or orchestrator. It's the safety layer underneath. See how JamJet fits with LangGraph, CrewAI, Temporal, LangSmith, and the hosted clouds."
  canonical="https://jamjet.dev/compare"
  currentPage="compare"
>
<Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify(compareLd)}></script>
</Fragment>

<!-- ── Hero ── -->
<section class="cmp-hero">
  <div class="cmp-hero-inner">
    <span class="cmp-pill">Compare</span>
    <h1>How JamJet fits<br/>with what you already use.</h1>
    <p class="cmp-sub">
      JamJet is not a replacement for your agent framework, your workflow orchestrator,
      or your observability tool. It's the safety layer underneath. Keep what's working.
      Add JamJet for the parts that need to be replayable, auditable, and controlled.
    </p>
  </div>

  <!-- Stack diagram -->
  <div class="cmp-stack">
    <svg viewBox="0 0 720 280" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Stack diagram: your agent framework calls into the JamJet safety layer, which mediates calls to models, tools, and memory">
      <!-- top layer: agent frameworks -->
      <g class="layer">
        <rect x="40" y="20" width="640" height="44" rx="8"/>
        <text x="360" y="48" text-anchor="middle" class="layer-title">your agent framework</text>
      </g>
      <text x="60" y="78" class="layer-tag">LangGraph</text>
      <text x="160" y="78" class="layer-tag">CrewAI</text>
      <text x="240" y="78" class="layer-tag">Pydantic AI</text>
      <text x="350" y="78" class="layer-tag">OpenAI Agents</text>
      <text x="470" y="78" class="layer-tag">ADK</text>
      <text x="540" y="78" class="layer-tag">Spring AI</text>
      <text x="630" y="78" class="layer-tag">vanilla</text>

      <!-- middle layer: JamJet -->
      <g class="layer-jam">
        <rect x="40" y="100" width="640" height="80" rx="10"/>
        <text x="360" y="128" text-anchor="middle" class="layer-jam-title">JamJet — safety layer</text>
        <g class="layer-chip"><rect x="62" y="142" width="84" height="22" rx="4"/><text x="104" y="157" text-anchor="middle">policy</text></g>
        <g class="layer-chip"><rect x="156" y="142" width="84" height="22" rx="4"/><text x="198" y="157" text-anchor="middle">audit</text></g>
        <g class="layer-chip"><rect x="250" y="142" width="84" height="22" rx="4"/><text x="292" y="157" text-anchor="middle">approval</text></g>
        <g class="layer-chip"><rect x="344" y="142" width="84" height="22" rx="4"/><text x="386" y="157" text-anchor="middle">recovery</text></g>
        <g class="layer-chip"><rect x="438" y="142" width="84" height="22" rx="4"/><text x="480" y="157" text-anchor="middle">cost</text></g>
        <g class="layer-chip"><rect x="532" y="142" width="84" height="22" rx="4"/><text x="574" y="157" text-anchor="middle">memory</text></g>
      </g>

      <!-- bottom layer: tools/models -->
      <g class="layer">
        <rect x="40" y="216" width="640" height="44" rx="8"/>
        <text x="360" y="244" text-anchor="middle" class="layer-title">models &middot; tools &middot; MCP &middot; A2A</text>
      </g>
      <text x="60" y="208" class="layer-tag">Claude</text>
      <text x="135" y="208" class="layer-tag">OpenAI</text>
      <text x="210" y="208" class="layer-tag">Gemini</text>
      <text x="290" y="208" class="layer-tag">Bedrock</text>
      <text x="380" y="208" class="layer-tag">Postgres</text>
      <text x="470" y="208" class="layer-tag">SaaS APIs</text>
      <text x="565" y="208" class="layer-tag">your tools</text>
    </svg>
    <p class="cmp-stack-caption">
      Your framework keeps writing code. Your tools keep doing work. JamJet is the
      band in the middle that decides what's allowed, what's recorded, and what survives.
    </p>
  </div>
</section>

<!-- ── Fits matrix ── -->
<section class="cmp-section cmp-section-alt">
  <div class="cmp-section-inner">
    <span class="section-label">Where JamJet fits</span>
    <h2>Keep what's working. Add JamJet around the risky parts.</h2>
    <p class="cmp-section-intro">
      For each ecosystem you might already use, here's the honest sentence: what to keep it for,
      and what to add JamJet for. No vendor takedowns. No "JamJet does everything" tables.
    </p>

    <div class="fits">
      {categories.map(cat => (
        <div class="fits-group">
          <div class="fits-cat">{cat}</div>
          {fits.filter(f => f.category === cat).map(f => (
            <div class="fits-row">
              <div class="fits-name">{f.name}</div>
              <div class="fits-cell">
                <span class="fits-cell-label">Keep it for</span>
                <p>{f.keepFor}</p>
              </div>
              <div class="fits-cell fits-cell-add">
                <span class="fits-cell-label">Add JamJet for</span>
                <p>{f.addJamjetFor}</p>
              </div>
              <div class="fits-link">
                {f.link ? (
                  <a href={f.link}>Deep dive &rarr;</a>
                ) : (
                  <span class="fits-link-soon">coming soon</span>
                )}
              </div>
            </div>
          ))}
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ── Honest disclaimers ── -->
<section class="cmp-section">
  <div class="cmp-section-inner cmp-honest">
    <span class="section-label">Honest disclaimers</span>
    <h2>What this comparison <em>doesn't</em> say.</h2>
    <div class="honest-grid">
      <div class="honest-card">
        <strong>JamJet is early-stage.</strong>
        <p>Some of the tools above have ten thousand stars, dozens of enterprise customers, and battle-tested production deployments. JamJet does not. We're transparent about that.</p>
      </div>
      <div class="honest-card">
        <strong>JamJet doesn't replace everything.</strong>
        <p>If you only need tracing, you don't need JamJet. If you only need a graph DSL, you don't need JamJet. The fit matrix above shows the specific gaps the runtime fills.</p>
      </div>
      <div class="honest-card">
        <strong>The other tools keep evolving.</strong>
        <p>Capabilities change quickly in this space. Treat this page as a snapshot, not a permanent verdict. Check each project's docs for the latest.</p>
      </div>
      <div class="honest-card">
        <strong>You can use JamJet alongside, not instead.</strong>
        <p>Most adoptions look like: keep the framework, add JamJet's runtime around the calls that need policy, approval, replay, and audit. That's the design intent.</p>
      </div>
    </div>
  </div>
</section>

<!-- ── Deep dives ── -->
<section class="cmp-section cmp-section-alt">
  <div class="cmp-section-inner">
    <span class="section-label">Deep dives</span>
    <h2>Long-form comparisons.</h2>
    <p class="cmp-section-intro">
      For ecosystems where the design tradeoffs deserve more than a sentence, we write them up in full.
    </p>
    <div class="deep-grid">
      <a class="deep-card deep-ready" href="/compare/temporal">
        <div class="deep-head">
          <span class="deep-name">Temporal</span>
          <span class="deep-status">Available</span>
        </div>
        <p>The gold standard for durable workflows. Where JamJet adds agent-native concerns and where Temporal stays the better choice.</p>
        <span class="deep-arrow">Read &rarr;</span>
      </a>
      <a class="deep-card deep-ready" href="https://docs.jamjet.dev/en/docs/migrate/from-langgraph">
        <div class="deep-head">
          <span class="deep-name">LangGraph</span>
          <span class="deep-status">Migration guide</span>
        </div>
        <p>Mental-model mapping for graph-based authoring + the durability and governance you get on the JamJet runtime.</p>
        <span class="deep-arrow">Read &rarr;</span>
      </a>
      <a class="deep-card deep-ready" href="https://docs.jamjet.dev/en/docs/migrate/from-crewai">
        <div class="deep-head">
          <span class="deep-name">CrewAI</span>
          <span class="deep-status">Migration guide</span>
        </div>
        <p>How role-based crews map onto JamJet's coordinator + agent-as-tool primitives.</p>
        <span class="deep-arrow">Read &rarr;</span>
      </a>
      <div class="deep-card deep-soon">
        <div class="deep-head">
          <span class="deep-name">LangSmith</span>
          <span class="deep-status">Coming soon</span>
        </div>
        <p>Observability vs. enforcement. Why "tracing" alone doesn't stop unsafe agent behavior.</p>
      </div>
      <div class="deep-card deep-soon">
        <div class="deep-head">
          <span class="deep-name">Bedrock / Vertex / Foundry</span>
          <span class="deep-status">Coming soon</span>
        </div>
        <p>The case for a cloud-neutral, self-hostable control layer when your agents are bound to one cloud's models.</p>
      </div>
      <div class="deep-card deep-soon">
        <div class="deep-head">
          <span class="deep-name">OpenAI Agents SDK</span>
          <span class="deep-status">Coming soon</span>
        </div>
        <p>What durable execution and governance look like when your agent runtime sits inside someone else's cloud.</p>
      </div>
    </div>
  </div>
</section>

<!-- ── CTA ── -->
<section class="cmp-cta">
  <div class="cmp-cta-inner">
    <h2>Try it next to what you already have.</h2>
    <p>Install once. Wrap one risky tool call. See traces, policy decisions, and replay points light up.</p>
    <div class="cmp-cta-actions">
      <a href="https://docs.jamjet.dev/en/docs/quickstart" class="btn-primary">Run the quickstart</a>
      <a href="/cloud" class="btn-secondary">View JamJet Cloud</a>
      <a href="https://github.com/jamjet-labs/jamjet" class="btn-secondary" target="_blank" rel="noopener">GitHub</a>
    </div>
  </div>
</section>

<style>
  /* ── Hero ── */
  .cmp-hero {
    padding: 5rem 1.5rem 2rem;
    text-align: center;
  }
  .cmp-hero-inner { max-width: 760px; margin: 0 auto; }
  .cmp-pill {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 999px;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 0.72rem;
    font-family: var(--font-sans);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 18px;
  }
  .cmp-hero h1 {
    font-size: clamp(2.4rem, 5.5vw, 3.6rem);
    line-height: 1.05;
    margin: 8px 0 24px;
    letter-spacing: -0.01em;
  }
  .cmp-sub {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--text-secondary);
    max-width: 660px;
    margin: 0 auto;
  }

  /* Stack diagram */
  .cmp-stack {
    max-width: 880px;
    margin: 56px auto 0;
    padding: 0 1rem;
    text-align: center;
  }
  .cmp-stack svg { width: 100%; height: auto; color: var(--text); }
  .cmp-stack .layer rect {
    fill: var(--surface);
    stroke: var(--border);
    stroke-width: 1;
  }
  .cmp-stack .layer-title {
    font-size: 13px;
    fill: var(--text);
    font-family: var(--font-sans);
    font-weight: 500;
  }
  .cmp-stack .layer-tag {
    font-size: 10px;
    fill: var(--text-muted);
    font-family: var(--font-sans);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .cmp-stack .layer-jam rect {
    fill: var(--text);
    stroke: var(--text);
  }
  .cmp-stack .layer-jam-title {
    font-size: 14px;
    fill: var(--bg);
    font-family: var(--font-sans);
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .cmp-stack .layer-chip rect { fill: var(--bg); opacity: 0.18; }
  .cmp-stack .layer-chip text {
    font-size: 11px;
    fill: var(--bg);
    font-family: var(--font-sans);
    font-weight: 500;
  }
  .cmp-stack-caption {
    color: var(--text-muted);
    font-size: 0.88rem;
    line-height: 1.6;
    margin-top: 18px;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Sections */
  .cmp-section { padding: 5rem 1.5rem; }
  .cmp-section-alt { background: var(--bg-alt); }
  .cmp-section-inner { max-width: 1080px; margin: 0 auto; }
  .cmp-section h2 {
    font-size: clamp(1.6rem, 3.6vw, 2.25rem);
    margin: 8px 0 16px;
    line-height: 1.15;
  }
  .cmp-section h2 em { font-style: italic; }
  .cmp-section-intro {
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 680px;
    margin: 0 0 36px;
  }

  /* Fits matrix */
  .fits {
    display: grid;
    gap: 36px;
  }
  .fits-cat {
    font-size: 0.72rem;
    font-family: var(--font-sans);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    padding-bottom: 8px;
    margin-bottom: 12px;
    border-bottom: 1px solid var(--border);
  }
  .fits-row {
    display: grid;
    grid-template-columns: 1.2fr 2fr 2fr 0.8fr;
    gap: 20px;
    padding: 18px 0;
    border-bottom: 1px solid var(--border);
    align-items: start;
  }
  .fits-row:last-child { border-bottom: 0; }
  .fits-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
    padding-top: 18px;
  }
  .fits-cell-label {
    display: block;
    font-size: 0.66rem;
    font-family: var(--font-sans);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    font-weight: 600;
    margin-bottom: 4px;
  }
  .fits-cell p {
    color: var(--text-secondary);
    font-size: 0.92rem;
    line-height: 1.65;
    margin: 0;
  }
  .fits-cell-add p { color: var(--text); }
  .fits-link {
    padding-top: 18px;
    text-align: right;
  }
  .fits-link a {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--text);
    text-decoration: none;
    border-bottom: 1px solid var(--border);
    padding-bottom: 1px;
    white-space: nowrap;
  }
  .fits-link a:hover { border-bottom-color: var(--text); }
  .fits-link-soon {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    color: var(--text-muted);
    font-style: italic;
  }

  /* Honest disclaimers */
  .cmp-honest h2 em { font-weight: 500; }
  .honest-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-top: 8px;
  }
  .honest-card {
    padding: 22px 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    border-left: 3px solid var(--text);
  }
  .honest-card strong {
    display: block;
    font-size: 0.98rem;
    margin-bottom: 8px;
    color: var(--text);
  }
  .honest-card p {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.65;
    margin: 0;
  }

  /* Deep dives */
  .deep-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .deep-card {
    display: flex;
    flex-direction: column;
    padding: 22px 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, transform 0.15s;
  }
  .deep-ready:hover {
    border-color: var(--text);
    transform: translateY(-2px);
  }
  .deep-soon {
    opacity: 0.6;
    cursor: default;
  }
  .deep-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 10px;
  }
  .deep-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
  }
  .deep-status {
    font-size: 0.66rem;
    font-family: var(--font-sans);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
  }
  .deep-card p {
    color: var(--text-secondary);
    font-size: 0.88rem;
    line-height: 1.6;
    margin: 0 0 14px;
    flex: 1;
  }
  .deep-arrow {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--text);
    font-weight: 500;
  }

  /* Final CTA */
  .cmp-cta {
    padding: 5rem 1.5rem;
    text-align: center;
  }
  .cmp-cta-inner { max-width: 600px; margin: 0 auto; }
  .cmp-cta h2 {
    font-size: clamp(1.6rem, 3.4vw, 2rem);
    margin-bottom: 12px;
  }
  .cmp-cta p {
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 28px;
  }
  .cmp-cta-actions {
    display: flex;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  @media (max-width: 900px) {
    .fits-row { grid-template-columns: 1fr; gap: 12px; padding: 22px 0; }
    .fits-name { padding-top: 0; }
    .fits-link { text-align: left; padding-top: 0; }
    .honest-grid { grid-template-columns: 1fr; }
    .deep-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .deep-grid { grid-template-columns: 1fr; }
  }
</style>

</BaseLayout>
