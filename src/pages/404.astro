---
import BaseLayout from '../layouts/BaseLayout.astro';
import BrushIcon from '../components/BrushIcon.astro';
---

<BaseLayout
  title="Page not found — JamJet"
  description="The page you're looking for doesn't exist."
>
  <Fragment slot="head">
    <meta name="robots" content="noindex" />
  </Fragment>

  <div class="notfound">
    <BrushIcon name="tool" stroke="var(--text-muted)" />
    <p class="code">404</p>
    <h1>Page not found</h1>
    <p class="lede">
      The page you're looking for doesn't exist, or has moved. If you followed a link from
      somewhere, the destination may have changed.
    </p>

    <ul class="links">
      <li><a href="/">Home</a></li>
      <li><a href="/blog/">Field notes</a></li>
      <li><a href="/engram/">Engram</a></li>
      <li><a href="/cloud/">Cloud</a></li>
      <li><a href="/gate/">The Gate</a></li>
      <li><a href="https://docs.jamjet.dev/en" target="_blank" rel="noopener">Docs</a></li>
    </ul>
  </div>
</BaseLayout>

<style>
  .notfound {
    max-width: 640px;
    margin: 0 auto;
    padding: 6rem 24px 5rem;
    text-align: left;
  }
  .notfound :global(.brush-icon) {
    color: var(--text-muted);
    margin-bottom: 1.25rem;
    opacity: 0.55;
  }
  .code {
    font-family: 'DM Mono', ui-monospace, monospace;
    color: var(--text-muted);
    font-size: 0.95rem;
    letter-spacing: 0.08em;
    margin: 0 0 0.75rem;
  }
  .notfound h1 {
    margin: 0 0 1rem;
    font-size: clamp(2rem, 4vw, 2.75rem);
    line-height: 1.15;
  }
  .lede {
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.7;
    margin: 0 0 2rem;
  }
  .links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 8px;
  }
  .links a {
    display: block;
    padding: 12px 16px;
    background: var(--surface);
    border: 1px solid var(--border-strong);
    border-radius: 10px;
    box-shadow: 1px 2px 0 rgba(20,20,19,0.06);
    color: inherit;
    text-decoration: none;
    transition: transform 0.12s ease, box-shadow 0.12s ease;
  }
  .links a:hover {
    transform: translateY(-1px);
    box-shadow: 2px 4px 0 rgba(20,20,19,0.1);
  }
</style>
