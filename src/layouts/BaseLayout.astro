---
import '../styles/base.css';

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogImage?: string;
  currentPage?: string;
}

const {
  title,
  description,
  canonical,
  ogImage = 'https://jamjet.dev/og.svg',
  currentPage,
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#fafaf8" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={canonical} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@jamjetdev" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <slot name="head" />
</head>
<body>

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="JamJet home">JamJet</a>
    <ul class="nav-links">
      <li><a href="/quickstart" aria-current={currentPage === 'docs' ? 'page' : undefined}>Docs</a></li>
      <li><a href="/usecases" aria-current={currentPage === 'usecases' ? 'page' : undefined}>Use Cases</a></li>
      <li><a href="/benchmarks" aria-current={currentPage === 'benchmarks' ? 'page' : undefined}>Benchmarks</a></li>
      <li><a href="/examples" aria-current={currentPage === 'examples' ? 'page' : undefined}>Examples</a></li>
      <li><a href="/blog" aria-current={currentPage === 'blog' ? 'page' : undefined}>Blog</a></li>
      <li>
        <a href="https://github.com/jamjet-labs/jamjet" target="_blank" rel="noopener" class="nav-github" aria-label="GitHub">
          <svg width="20" height="20" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
        </a>
      </li>
    </ul>
  </div>
</nav>

<main style="padding-top: 64px;">
  <slot />
</main>

<footer>
  <div class="container">
    <div class="footer-grid">
      <div>
        <a href="/" class="nav-logo">JamJet</a>
        <p class="footer-desc">The agent-native runtime.<br/>Built in Rust. Authored in Python.<br/>Open source — Apache 2.0.</p>
      </div>
      <div class="footer-col">
        <h4>Product</h4>
        <ul>
          <li><a href="/quickstart">Quickstart</a></li>
          <li><a href="/concepts">Concepts</a></li>
          <li><a href="/usecases">Use Cases</a></li>
          <li><a href="/benchmarks">Benchmarks</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Learn</h4>
        <ul>
          <li><a href="/mcp">MCP guide</a></li>
          <li><a href="/a2a">A2A guide</a></li>
          <li><a href="/examples">Examples</a></li>
          <li><a href="/blog">Blog</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Community</h4>
        <ul>
          <li><a href="https://github.com/jamjet-labs/jamjet" target="_blank" rel="noopener">GitHub</a></li>
          <li><a href="https://x.com/jamjetdev" target="_blank" rel="noopener">X / Twitter</a></li>
          <li><a href="mailto:hello@jamjet.dev">hello@jamjet.dev</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>&copy; 2026 JamJet. Apache 2.0 license.</span>
      <div style="display:flex;gap:20px">
        <a href="/privacy">Privacy</a>
        <a href="/terms">Terms</a>
      </div>
    </div>
  </div>
</footer>

</body>
</html>
