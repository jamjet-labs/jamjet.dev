---
import '../styles/base.css';
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogImage?: string;
  ogType?: string;
  currentPage?: string;
}

const {
  title,
  description,
  canonical,
  ogImage = 'https://jamjet.dev/og.png',
  ogType = 'website',
  currentPage,
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#f6f5f1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content="AI agents, agent framework, durable execution, MCP, Model Context Protocol, A2A, agent-to-agent, Rust runtime, Python SDK, Java SDK, workflow orchestration, multi-agent systems, agent memory" />
  <link rel="canonical" href={canonical} />
  <link rel="alternate" type="text/plain" title="LLMs.txt" href="https://jamjet.dev/llms.txt" />
  <link rel="alternate" type="application/rss+xml" title="JamJet Blog" href="/rss.xml" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={canonical} />
  <meta property="og:type" content={ogType} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@jamjetdev" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <link rel="alternate" hreflang="en" href={canonical} />
  <link rel="alternate" hreflang="x-default" href={canonical} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400&family=DM+Mono:wght@400;500&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-44L683PK96"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-44L683PK96');
  </script>
  <ViewTransitions />
  <slot name="head" />
</head>
<body>
<div class="reading-progress" id="reading-progress"></div>

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="JamJet home">
      <svg width="22" height="22" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="1" y="1" width="30" height="30" rx="3" fill="#141413"/>
        <path d="M12.5 8.5v12c0 1.66-1.34 3-3 3" stroke="#f6f5f1" stroke-width="2.5" stroke-linecap="round" fill="none"/>
        <line x1="17" y1="8" x2="22.5" y2="14" stroke="#f6f5f1" stroke-width="2.5" stroke-linecap="round"/>
      </svg>
      JamJet
    </a>
    <button class="nav-toggle" id="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>
    <ul class="nav-links" id="nav-links">
      <li><a href="/showcase" aria-current={currentPage === 'showcase' ? 'page' : undefined}>Showcase</a></li>
      <li><a href="/research" aria-current={currentPage === 'research' ? 'page' : undefined}>Research</a></li>
      <li><a href="/benchmarks" aria-current={currentPage === 'benchmarks' ? 'page' : undefined}>Benchmarks</a></li>
      <li><a href="/blog" aria-current={currentPage === 'blog' ? 'page' : undefined}>Blog</a></li>
      <li><a href="https://docs.jamjet.dev/en/docs" target="_blank" rel="noopener">Docs<span style="font-size:0.7em;margin-left:2px;opacity:0.5">↗</span></a></li>
      <li>
        <a href="https://discord.gg/SAYnEj86fr" target="_blank" rel="noopener" class="nav-github" aria-label="Discord">
          <svg width="20" height="20" viewBox="0 0 16 16" fill="currentColor"><path d="M13.545 2.907a13.227 13.227 0 0 0-3.257-1.011.05.05 0 0 0-.052.025c-.141.25-.297.577-.406.833a12.19 12.19 0 0 0-3.658 0 8.258 8.258 0 0 0-.412-.833.051.051 0 0 0-.052-.025c-1.125.194-2.22.534-3.257 1.011a.041.041 0 0 0-.021.018C.356 6.024-.213 9.047.066 12.032c.001.014.01.028.021.037a13.276 13.276 0 0 0 3.995 2.02.05.05 0 0 0 .056-.019c.308-.42.582-.863.818-1.329a.05.05 0 0 0-.028-.07 8.735 8.735 0 0 1-1.248-.595.05.05 0 0 1-.005-.084c.084-.063.168-.129.248-.195a.05.05 0 0 1 .051-.007c2.619 1.196 5.454 1.196 8.041 0a.05.05 0 0 1 .053.007c.08.066.164.132.248.195a.05.05 0 0 1-.004.084c-.399.232-.813.43-1.249.596a.05.05 0 0 0-.027.07c.24.465.515.909.817 1.329a.05.05 0 0 0 .056.019 13.235 13.235 0 0 0 4.001-2.02.049.049 0 0 0 .021-.037c.334-3.451-.559-6.449-2.366-9.106a.034.034 0 0 0-.02-.019z"/></svg>
        </a>
      </li>
      <li>
        <a href="https://github.com/jamjet-labs/jamjet" target="_blank" rel="noopener" class="nav-github" aria-label="GitHub">
          <svg width="20" height="20" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
        </a>
      </li>
    </ul>
  </div>
</nav>

<main style="padding-top: 64px;">
  <slot />
</main>

<footer>
  <div class="container">
    <div class="footer-grid">
      <div>
        <a href="/" class="nav-logo">
          <svg width="22" height="22" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="1" y="1" width="30" height="30" rx="3" fill="#141413"/>
            <path d="M12.5 8.5v12c0 1.66-1.34 3-3 3" stroke="#f6f5f1" stroke-width="2.5" stroke-linecap="round" fill="none"/>
            <line x1="17" y1="8" x2="22.5" y2="14" stroke="#f6f5f1" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
          JamJet
        </a>
        <p class="footer-desc">The durable runtime for AI agents.<br/>Write Python. Run with Rust reliability.<br/>Open source — Apache 2.0.</p>
      </div>
      <div class="footer-col">
        <h4>Product</h4>
        <ul>
          <li><a href="/showcase">Showcase</a></li>
          <li><a href="/research">Research</a></li>
          <li><a href="/benchmarks">Benchmarks</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Learn</h4>
        <ul>
          <li><a href="https://docs.jamjet.dev/en/docs/quickstart" target="_blank" rel="noopener">Quickstart</a></li>
          <li><a href="https://docs.jamjet.dev/en/docs/mcp" target="_blank" rel="noopener">MCP guide</a></li>
          <li><a href="https://docs.jamjet.dev/en/docs/a2a" target="_blank" rel="noopener">A2A guide</a></li>
          <li><a href="https://docs.jamjet.dev/en/docs/research-guide" target="_blank" rel="noopener">Research guide</a></li>
          <li><a href="/blog">Blog</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Community</h4>
        <ul>
          <li><a href="https://github.com/jamjet-labs/jamjet" target="_blank" rel="noopener">GitHub</a></li>
          <li><a href="https://github.com/jamjet-labs/jamjet/discussions" target="_blank" rel="noopener">Discussions</a></li>
          <li><a href="https://x.com/jamjetdev" target="_blank" rel="noopener">X / Twitter</a></li>
          <li><a href="https://discord.gg/SAYnEj86fr" target="_blank" rel="noopener">Discord</a></li>
          <li><a href="mailto:hello@jamjet.dev">hello@jamjet.dev</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>&copy; 2026 JamJet. Apache 2.0 license.</span>
      <div style="display:flex;gap:20px">
        <a href="/privacy">Privacy</a>
        <a href="/terms">Terms</a>
        <a href="/security">Security</a>
      </div>
    </div>
  </div>
</footer>

<script>
  const toggle = document.getElementById('nav-toggle');
  const links = document.getElementById('nav-links');
  if (toggle && links) {
    toggle.addEventListener('click', () => {
      const open = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!open));
      links.classList.toggle('open');
    });
  }

  // Reading progress bar
  const progress = document.getElementById('reading-progress');
  if (progress) {
    window.addEventListener('scroll', () => {
      const scrollTop = document.documentElement.scrollTop;
      const scrollHeight = document.documentElement.scrollHeight - window.innerHeight;
      const pct = scrollHeight > 0 ? (scrollTop / scrollHeight) * 100 : 0;
      progress.style.width = pct + '%';
    }, { passive: true });
  }
</script>
<script data-goatcounter="https://jamjet.goatcounter.com/count"
        async src="//gc.zgo.at/count.js"></script>
</body>
</html>
