---
// Deploy section: local → self-host → Cloud
const tiers = [
  {
    name: 'Local',
    sub: 'pip install + run',
    detail: 'SQLite. Zero infrastructure. Your laptop. The same IR runs identically here as in production.',
    cmd: 'pip install jamjet && python agent.py',
    highlight: false,
  },
  {
    name: 'Self-host',
    sub: 'Docker + Postgres',
    detail: 'Docker Compose or Kubernetes. Bring Postgres for the event log and artifact store. You own the infra.',
    cmd: 'docker compose up jamjet-runtime',
    highlight: false,
  },
  {
    name: 'JamJet Cloud',
    sub: 'Managed cells',
    detail: 'Managed control plane on Fly.io. Policy dashboard, approval inbox, cost analytics, Engram memory, multi-tenant. No infra to run.',
    cmd: 'app.jamjet.dev/signup',
    highlight: true,
  },
];
---

<section id="deploy" class="deploy">
  <div class="container">
    <p class="section-label">Deploy</p>
    <h2>Local. Self-host. Cloud.</h2>
    <p class="deploy-intro">
      The IR artifact runs identically across all three. Start on SQLite,
      ship to a cell. No rewriting.
    </p>

    <div class="deploy-tiers">
      {tiers.map(t => (
        <div class={`deploy-card ${t.highlight ? 'deploy-card-highlight' : ''}`}>
          <div class="deploy-card-head">
            <h3>{t.name}</h3>
            <span class="deploy-sub">{t.sub}</span>
          </div>
          <p class="deploy-detail">{t.detail}</p>
          <div class="install-cmd deploy-cmd">
            <span class="prompt">$</span>
            <span class="cmd">{t.cmd}</span>
          </div>
        </div>
      ))}
    </div>

    <p class="deploy-note">
      One artifact (the IR) runs identically across all three tiers.
      Develop on SQLite, ship to a cell when you're ready.
    </p>
  </div>
</section>

<style>
  .deploy {
    background: var(--bg-alt);
    border-bottom: 1px solid var(--border);
  }
  .deploy-intro {
    color: var(--text-secondary);
    max-width: 520px;
    margin-top: 16px;
    margin-bottom: 40px;
  }
  .deploy-tiers {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 32px;
  }
  .deploy-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .deploy-card-highlight {
    border-color: var(--border-strong);
    background: var(--bg);
  }
  .deploy-card-head {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .deploy-sub {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
  }
  .deploy-detail {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }
  .deploy-cmd {
    font-size: 0.75rem;
    padding: 10px 14px;
    margin-top: auto;
  }
  .deploy-note {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-family: var(--font-sans);
  }

  @media (max-width: 900px) {
    .deploy-tiers { grid-template-columns: 1fr; }
  }
</style>
